<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- SEO METADATA -->
  <title>Apply for Commercial Fleet Fuel Card | Hire7 Fuel</title>
  <meta name="description" content="Apply for the Hire7 Fuel Card in minutes. Complete our secure onboarding form for fast credit approvals, next-day shipping, and dedicated 24/7 dispatcher support.">
  
  <!-- Open Graph Protocol (OG) -->
  <meta property="og:title" content="Apply for Commercial Fleet Fuel Card | Hire7 Fuel">
  <meta property="og:description" content="Submit your fleet application securely. Access low-cost fuel lanes, dynamic geofencing tools, and automated IFTA tax logs.">
  <meta property="og:url" content="https://hire7fuel.com/apply">
  <meta property="og:type" content="website">
  <meta property="og:image" content="/assets/logo.png">

  <!-- Style links -->
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  
  <%- include('partials/header') %>

  <!-- Page Header -->
  <section class="hero-mesh" style="padding: 5rem 0 4rem 0;">
    <div class="container text-center">
      <h1 class="hero-title" style="font-size: 2.75rem; margin-bottom: 1rem;">Secure Onboarding Application</h1>
      <p class="hero-subtitle" style="margin: 0 auto; max-width: 650px;">
        Complete our streamlined fuel card application. Once submitted, our commercial credit underwriters will evaluate your fleet parameters and establish credit lines in 24 business hours.
      </p>
    </div>
  </section>

  <!-- Application Form Section -->
  <section class="section" id="application-form-section">
    <div class="container">
      
      <div class="apply-layout">
        <!-- Left Column: Visual representation of card + trust badges -->
        <div style="position: sticky; top: 110px;">
          <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--color-white);">Join the Hire7 Fuel Network</h2>
          <p style="color: var(--color-muted); margin-bottom: 2.5rem; font-size: 1.05rem;">By enrolling in our fuel program, your fleet gains access to pre-negotiated wholesale fuel prices, real-time geofence alerts, and comprehensive tax compliance bookkeeping tools.</p>
          
          <!-- Premium visual card display -->
          <div class="apply-card-preview-wrapper">
            <div class="glow-ring highlight-glow"></div>
            <img src="/assets/physical_card.png" alt="Premium Hire7 Fuel Physical Card" class="apply-premium-card">
          </div>

          <!-- Trust badges rows -->
          <div class="badges-row">
            <!-- Badge 1 -->
            <div class="badge-item">
              <div class="badge-icon"><i class="fas fa-lock"></i></div>
              <h4>Secure Submission</h4>
              <span>256-bit encryption</span>
            </div>
            <!-- Badge 2 -->
            <div class="badge-item">
              <div class="badge-icon"><i class="fas fa-bolt"></i></div>
              <h4>Quick Approvals</h4>
              <span>Under 24 hours</span>
            </div>
            <!-- Badge 3 -->
            <div class="badge-item">
              <div class="badge-icon"><i class="fas fa-circle-question"></i></div>
              <h4>24/7 Support</h4>
              <span>Dedicated dispatch</span>
            </div>
          </div>
        </div>

        <!-- Right Column: Card Application Form -->
        <div class="form-card" id="apply-form">
          <% if (success) { %>
            <div class="alert alert-success" role="alert">
              <i class="fas fa-circle-check" style="margin-right: 0.5rem;"></i>
              <strong>Application Received!</strong> Thank you for applying. A commercial credit manager is already processing your file. We will contact you shortly.
            </div>
          <% } %>

          <form action="/submit-application" method="POST" needs-validation novalidate>
            <h3 style="font-size: 1.35rem; margin-bottom: 1.5rem; color: var(--color-white); border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.75rem;">Company & Contact Details</h3>

            <div class="form-group">
              <label for="name">Contact Person Full Name <span style="color: var(--color-error);">*</span></label>
              <input type="text" id="name" name="name" class="form-control" placeholder="Johnathan Smith" required minlength="2" aria-required="true">
            </div>

            <div class="form-group">
              <label for="company">Registered Company Name <span style="color: var(--color-error);">*</span></label>
              <input type="text" id="company" name="company" class="form-control" placeholder="Smith Freight Logistics LLC" required minlength="2" aria-required="true">
            </div>

            <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
              <div class="form-group">
                <label for="phone">Phone Number <span style="color: var(--color-error);">*</span></label>
                <input type="tel" id="phone" name="phone" class="form-control" placeholder="(905) 555-0144" required pattern="^\(?([0-9]{3})\)?[-. ]?([0-9]{3})[-. ]?([0-9]{4})$" aria-required="true">
              </div>
              <div class="form-group">
                <label for="email">Business Email Address <span style="color: var(--color-error);">*</span></label>
                <input type="email" id="email" name="email" class="form-control" placeholder="jsmith@smithfreight.com" required aria-required="true">
              </div>
            </div>

            <div class="form-group">
              <label for="message">Fleet Detail Notes (Optional)</label>
              <textarea id="message" name="message" class="form-control" placeholder="Help expedite your application: specify estimated monthly fuel spend, active lanes, and total truck count..."></textarea>
            </div>

            <div class="form-group checkbox-group" style="margin: 2rem 0;">
              <input type="checkbox" id="consent" name="consent" required aria-required="true">
              <label for="consent">
                I hereby consent to Hire7 Fuel performing necessary commercial credit inquiries to establish a fleet credit account. I agree to receive transactional updates and operational program alerts. <span style="color: var(--color-error);">*</span>
              </label>
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-large">Submit Secure Application</button>
          </form>
        </div>
      </div>

    </div>
  </section>

  <%- include('partials/footer') %>
