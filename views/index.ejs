<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- SEO METADATA -->
  <title>Fuel Card Solutions & Fleet Fuel Management | KSG Fuel</title>
  <meta name="description" content="KSG Fuel provides premium fleet fuel cards and management tools. Empower your fleet with unmatched transaction security, 100% pricing transparency, and superior fuel efficiency.">
  
  <!-- Open Graph Protocol (OG) -->
  <meta property="og:title" content="Fuel Card Solutions & Fleet Fuel Management | KSG Fuel">
  <meta property="og:description" content="Empower your commercial fleet operations with KSG Fuel. Maximize efficiency, block fraud instantly, and access real-time online management.">
  <meta property="og:url" content="https://ksgfuel.com/">
  <meta property="og:type" content="website">
  <meta property="og:image" content="/assets/logo.png">

  <!-- Style links -->
  <link rel="stylesheet" href="/css/styles.css">
  
  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="hero-mesh">
    <div class="hero-glow"></div>
    <div class="container hero-layout">
      <div>
        <h1 class="hero-title" id="heroTitle">
          Drive Fleet Efficiency <br>
          <span class="text-accent">With Every Single Drop</span>
        </h1>
        <p class="hero-subtitle" id="heroSubtitle">
          Discover a commercial fuel program designed for ultimate transaction transparency, robust fraud safeguards, and comprehensive route optimization across North America.
        </p>
        <div class="button-group">
          <a href="/apply" class="btn btn-primary btn-large" id="heroApplyBtn">Apply Now</a>
          <a href="/fuelcard" class="btn btn-outline btn-large" id="heroLearnBtn">Learn More</a>
        </div>
      </div>
      <div class="fuelcard-visual">
        <!-- credit card visual layout -->
        <div class="payment-card">
          <div class="card-top">
            <div class="card-chip"></div>
            <div class="card-brand">KSG Fuel</div>
          </div>
          <div class="card-number">5038 9625 0834 1172</div>
          <div class="card-bottom">
            <div>
              <div class="card-holder">Card Member</div>
              <div class="card-name">COMMERCIAL FLEET</div>
            </div>
            <div class="card-expiry">
              <div class="card-holder">Expires</div>
              <div style="font-weight: 500;">12/28</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props Section -->
  <section class="section" id="value-props">
    <div class="container">
      <div class="section-title-wrap">
        <h2>Built on Core Fleet Pillars</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">Our customized fleet programs focus on delivering results that keep your business profitable, responsive, and secure.</p>
      </div>

      <div class="pillars-grid">
        <!-- Card 1: Efficiency -->
        <div class="pillar-card" id="propEfficiency">
          <div class="pillar-icon-wrapper">
            <i class="fas fa-gas-pump"></i>
          </div>
          <h3>Efficiency</h3>
          <p>Streamline your route logistics and refueling speed. Eliminate out-of-route mileage by utilizing our expansive network of premium stations across all main corridors.</p>
        </div>

        <!-- Card 2: Transparency -->
        <div class="pillar-card" id="propTransparency">
          <div class="pillar-icon-wrapper">
            <i class="fas fa-search-dollar"></i>
          </div>
          <h3>Transparency</h3>
          <p>Enjoy complete, unvarnished visibility into every transaction. Avoid hidden processing premiums or unexpected network fees with our clear pricing matrices.</p>
        </div>

        <!-- Card 3: Security -->
        <div class="pillar-card" id="propSecurity">
          <div class="pillar-icon-wrapper">
            <i class="fas fa-user-shield"></i>
          </div>
          <h3>Security</h3>
          <p>Lock down spending parameters immediately. Prevent employee card abuse by assigning distinct product classifications and daily transaction limits on every card.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Fraud Guarantee Alert Strip -->
  <section class="guarantee-banner" id="guarantee-banner">
    <div class="container">
      <div class="guarantee-layout">
        <i class="fas fa-shield-halved guarantee-icon"></i>
        <div class="guarantee-text">
          <h2>Zero-Liability Fraud Protection Guarantee</h2>
          <p>Sleep easy knowing your fleet transactions are locked down. KSG Fuel shields you from unauthorized activities through real-time notifications and instant online freeze controls.</p>
          <span class="guarantee-footnote">*Subject to immediate transaction review and prompt activation of card block settings. Terms apply.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Features Section -->
  <section class="section section-light-teal" id="features">
    <div class="container">
      <div class="section-title-wrap">
        <h2>Features Designed for Commercial Growth</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">Take back control of your operations. Our backend portal provides powerful utilities tailored to modern logistics.</p>
      </div>

      <div class="features-grid">
        <!-- Feature 1 -->
        <div class="feature-card" id="featRealTime">
          <div class="feature-icon-circle">
            <i class="fas fa-clock"></i>
          </div>
          <h3>Real-Time Alerts</h3>
          <p>Receive immediate updates on the exact location, quantity, and time of every fill-up right to your smartphone.</p>
        </div>
        <!-- Feature 2 -->
        <div class="feature-card" id="featGeofencing">
          <div class="feature-icon-circle">
            <i class="fas fa-map-location-dot"></i>
          </div>
          <h3>Station Geofencing</h3>
          <p>Restrict cards so they only operate within pre-approved zip codes or specific highway corridors.</p>
        </div>
        <!-- Feature 3 -->
        <div class="feature-card" id="featLimits">
          <div class="feature-icon-circle">
            <i class="fas fa-sliders"></i>
          </div>
          <h3>Flexible Limits</h3>
          <p>Adjust limits on diesel fuel, shop repair allowances, and driver lodging fees individually, instantly.</p>
        </div>
        <!-- Feature 4 -->
        <div class="feature-card" id="featReporting">
          <div class="feature-icon-circle">
            <i class="fas fa-file-invoice-dollar"></i>
          </div>
          <h3>IFTA Reporting</h3>
          <p>Export pre-formatted, tax-compliant fuel purchase logs, saving your back-office staff hours of manual math.</p>
        </div>
        <!-- Feature 5 -->
        <div class="feature-card" id="featPricing">
          <div class="feature-icon-circle">
            <i class="fas fa-percent"></i>
          </div>
          <h3>Direct Fuel Discounts</h3>
          <p>Access competitive, pre-negotiated wholesale pricing structures directly at high-volume highway truck stops.</p>
        </div>
        <!-- Feature 6 -->
        <div class="feature-card" id="featSupport">
          <div class="feature-icon-circle">
            <i class="fas fa-headset"></i>
          </div>
          <h3>24/7 Fleet Assistance</h3>
          <p>Reach dedicated logistics dispatchers who understand the pressures of long-haul deadlines anytime.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Client Testimonials Section -->
  <section class="section" id="testimonials">
    <div class="container">
      <div class="section-title-wrap">
        <h2>Trusted by Modern Carriers</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">See how transport owners are scaling their operations and reducing overhead using the KSG Fuel program.</p>
      </div>

      <div class="testimonials-grid">
        <!-- Testimonial 1 -->
        <div class="testimonial-card" id="testi1">
          <div class="quote-bubble">
            <div class="rating-stars">
              <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
            </div>
            <p>"Implementing the KSG Fuel Card completely resolved our card abuse issues. The geofencing tool blocked two out-of-bounds fills in our first month alone, saving us hundreds of dollars in leakage."</p>
          </div>
          <div class="testimonial-client">
            <div class="client-avatar">MH</div>
            <div class="client-info">
              <h4>Marcus Howell</h4>
              <span>Director of Logistics, Howell Transport</span>
            </div>
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div class="testimonial-card" id="testi2">
          <div class="quote-bubble">
            <div class="rating-stars">
              <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
            </div>
            <p>"We scaled our fleet from 5 to 25 trucks without adding a single administrative hire. The automated IFTA tax logs export seamlessly to our accounting platform. It's clean, rapid, and transparent."</p>
          </div>
          <div class="testimonial-client">
            <div class="client-avatar">SD</div>
            <div class="client-info">
              <h4>Sandeep Dhillon</h4>
              <span>Operations Manager, GTA Freightways</span>
            </div>
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div class="testimonial-card" id="testi3">
          <div class="quote-bubble">
            <div class="rating-stars">
              <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
            </div>
            <p>"Outstanding customer care. Whenever our drivers encounter weather route delays or require sudden limit extensions for truck maintenance, the phone dispatchers respond in under a minute."</p>
          </div>
          <div class="testimonial-client">
            <div class="client-avatar">TL</div>
            <div class="client-info">
              <h4>Terri Lafleur</h4>
              <span>Fleet Coordinator, Lafleur Transport Inc.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Inline Contact Form Section -->
  <section class="section section-light-teal" id="contact-form-section">
    <div class="container form-split-layout">
      <div class="form-intro">
        <h2>Power Your Fleet to the Next Level</h2>
        <p>Contact our onboarding team for a customized pricing proposal tailored to your unique lane schedules and truck volume.</p>
        <ul class="bullet-features">
          <li>
            <i class="fas fa-circle-check"></i>
            <span>No sign-up setup charges or long-term lock-in contracts</span>
          </li>
          <li>
            <i class="fas fa-circle-check"></i>
            <span>Approved credit checks within 24 business hours</span>
          </li>
          <li>
            <i class="fas fa-circle-check"></i>
            <span>Physical fuel cards shipped next-day via express delivery</span>
          </li>
        </ul>
      </div>

      <div class="form-card" id="contact-form">
        <% if (success) { %>
          <div class="alert alert-success" role="alert">
            <i class="fas fa-circle-check" style="margin-right: 0.5rem;"></i>
            <strong>Thank you!</strong> Your message has been submitted. One of our commercial representatives will contact you shortly.
          </div>
        <% } %>
        
        <form action="/submit-inquiry" method="POST" needs-validation novalidate>
          <div class="form-group">
            <label for="name">Full Name <span style="color: var(--color-error);">*</span></label>
            <input type="text" id="name" name="name" class="form-control" placeholder="Jane Doe" required minlength="2">
          </div>
          
          <div class="form-group">
            <label for="company">Company Name</label>
            <input type="text" id="company" name="company" class="form-control" placeholder="Logistics Express Inc.">
          </div>

          <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
              <label for="phone">Phone Number <span style="color: var(--color-error);">*</span></label>
              <input type="tel" id="phone" name="phone" class="form-control" placeholder="(905) 555-0199" required pattern="^\(?([0-9]{3})\)?[-. ]?([0-9]{3})[-. ]?([0-9]{4})$">
            </div>
            <div class="form-group">
              <label for="email">Email Address <span style="color: var(--color-error);">*</span></label>
              <input type="email" id="email" name="email" class="form-control" placeholder="jane@company.com" required>
            </div>
          </div>

          <div class="form-group">
            <label for="message">Message <span style="color: var(--color-error);">*</span></label>
            <textarea id="message" name="message" class="form-control" placeholder="Tell us about your fleet size and primary refueling routes..." required minlength="10"></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-full btn-large">Request Fleet Consultation</button>
        </form>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
