<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- SEO METADATA -->
  <title>Fuel Card Solutions & Fleet Fuel Management | Hire7 Fuel</title>
  <meta name="description" content="Hire7 Fuel provides premium fleet fuel cards and management tools. Empower your fleet with unmatched transaction security, 100% pricing transparency, and superior fuel efficiency.">
  
  <!-- Open Graph Protocol (OG) -->
  <meta property="og:title" content="Fuel Card Solutions & Fleet Fuel Management | Hire7 Fuel">
  <meta property="og:description" content="Empower your commercial fleet operations with Hire7 Fuel. Maximize efficiency, block fraud instantly, and access real-time online management.">
  <meta property="og:url" content="https://hire7fuel.com/">
  <meta property="og:type" content="website">
  <meta property="og:image" content="/assets/logo.png">

  <!-- Style links -->
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  
  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="hero-mesh">
    <!-- Animated background glow blobs -->
    <div class="glow-blob-container">
      <div class="glow-blob glow-blob-1"></div>
      <div class="glow-blob glow-blob-2"></div>
      <div class="glow-blob glow-blob-3"></div>
    </div>
    
    <div class="hero-glow"></div>
    <div class="container hero-layout">
      <div style="position: relative; z-index: 2;">
        <h1 class="hero-title" id="heroTitle">
          Drive Fleet Efficiency <br>
          <span class="text-accent">With Every Single Drop</span>
        </h1>
        <p class="hero-subtitle" id="heroSubtitle">
          Discover a commercial fuel program designed for ultimate transaction transparency, robust fraud safeguards, and comprehensive route optimization across North America.
        </p>
        <div class="button-group">
          <a href="/apply" class="btn btn-primary btn-large" id="heroApplyBtn">Apply Now</a>
          <a href="/fuelcard" class="btn btn-outline btn-large" id="heroLearnBtn">Learn More</a>
        </div>
      </div>
      <div class="hero-calculator-card glass-plate" id="hero-simulator">
        <div class="simulator-glow"></div>
        
        <!-- Premium Holographic Card -->
        <div class="hologram-card-container">
          <div class="hologram-card" id="hero-holo-card">
            <div class="hologram-card-reflection"></div>
            <div class="card-glow-pulse"></div>
            <div class="hologram-card-inner">
              <div class="card-top">
                <span class="card-brand">HIRE7 FUEL</span>
                <div class="card-chip-gold"></div>
              </div>
              <div class="card-number-glow">5412 8903 5678 1234</div>
              <!-- High-Fidelity Expiration & Card Meta Rows -->
              <div class="card-details-row" style="display: flex; gap: 1.25rem; margin: -0.25rem 0 0.75rem 0; font-size: 0.7rem; align-items: center;">
                <div style="display: flex; align-items: center; gap: 0.35rem;">
                  <span style="font-size: 0.45rem; line-height: 1; color: var(--color-muted); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">GOOD<br>THRU</span>
                  <strong style="font-size: 0.75rem; font-weight: 600; color: var(--color-white); letter-spacing: 0.05em; font-family: monospace;">12/29</strong>
                </div>
                <div style="display: flex; align-items: center; gap: 0.35rem;">
                  <span style="font-size: 0.45rem; line-height: 1; color: var(--color-muted); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">EXP</span>
                  <strong style="font-size: 0.75rem; font-weight: 600; color: var(--color-white); letter-spacing: 0.05em; font-family: monospace;">12/29</strong>
                </div>
              </div>
              <div class="card-bottom">
                <div class="card-holder">
                  <span>PREMIUM ACCOUNT</span>
                  <strong>Hire7 TRANSIT PLUS</strong>
                </div>
                <div class="card-network-badge">
                  <span class="neon-status-dot"></span>
                  <span class="neon-status-text">SHIELD ENABLED</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Dynamic Savings Readout -->
        <div class="sim-readout">
          <span class="sim-readout-label">ESTIMATED ANNUAL FLEET SAVINGS</span>
          <div class="sim-savings-counter" id="hero-savings-counter">$11,250</div>
        </div>
        
        <!-- Interactive Adjusters (Sliders) -->
        <div class="sim-adjusters">
          <div class="sim-slider-group">
            <div class="sim-slider-header">
              <span>Active Fleet Size</span>
              <strong id="hero-fleet-val">15 Trucks</strong>
            </div>
            <input type="range" id="hero-fleet-slider" class="range-slider sim-slider" min="1" max="150" value="15">
          </div>
          
          <div class="sim-slider-group">
            <div class="sim-slider-header">
              <span>Monthly Fuel / Truck</span>
              <strong id="hero-fuel-val">3,000 L</strong>
            </div>
            <input type="range" id="hero-fuel-slider" class="range-slider sim-slider" min="500" max="8000" step="100" value="3000">
          </div>
        </div>
        
        <!-- Mini Stats Grid -->
        <div class="sim-stats-grid">
          <div class="sim-stat-box">
            <span class="sim-stat-label">Net Fuel Rebate</span>
            <strong class="sim-stat-val text-accent" id="hero-rebate-val">$10,125</strong>
          </div>
          <div class="sim-stat-box">
            <span class="sim-stat-label">IFTA & Admin Saved</span>
            <strong class="sim-stat-val text-highlight" id="hero-hours-val">$1,125</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props Section -->
  <section class="section" id="value-props">
    <div class="container">
      <div class="section-title-wrap">
        <h2>Built on Core Fleet Pillars</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">Our customized fleet programs focus on delivering results that keep your business profitable, responsive, and secure.</p>
      </div>

      <div class="pillars-grid">
        <!-- Card 1: Efficiency -->
        <div class="pillar-card" id="propEfficiency">
          <div class="pillar-icon-wrapper">
            <i class="fas fa-gas-pump"></i>
          </div>
          <h3>Efficiency</h3>
          <p>Streamline your route logistics and refueling speed. Eliminate out-of-route mileage by utilizing our expansive network of premium stations across all main corridors.</p>
        </div>

        <!-- Card 2: Transparency -->
        <div class="pillar-card" id="propTransparency">
          <div class="pillar-icon-wrapper">
            <i class="fas fa-search-dollar"></i>
          </div>
          <h3>Transparency</h3>
          <p>Enjoy complete, unvarnished visibility into every transaction. Avoid hidden processing premiums or unexpected network fees with our clear pricing matrices.</p>
        </div>

        <!-- Card 3: Security -->
        <div class="pillar-card" id="propSecurity">
          <div class="pillar-icon-wrapper">
            <i class="fas fa-user-shield"></i>
          </div>
          <h3>Security</h3>
          <p>Lock down spending parameters immediately. Prevent employee card abuse by assigning distinct product classifications and daily transaction limits on every card.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Fleet Savings Calculator Section -->
  <section class="section section-dark-interactive" id="savings-calculator">
    <div class="glow-blob-container">
      <div class="glow-blob glow-blob-2" style="opacity: 0.12;"></div>
    </div>
    <div class="container">
      <div class="section-title-wrap">
        <h2 style="color: var(--color-white);">Project Your Annual Fleet Savings</h2>
        <p class="max-w-md text-center" style="color: rgba(255, 255, 255, 0.7); margin: 1rem auto 0 auto;">See how much overhead your carrier operations can eliminate by shifting from legacy, high-fee fuel card platforms to Hire7 Fuel.</p>
      </div>

      <div class="calculator-grid">
        <!-- Sliders Column -->
        <div class="calculator-inputs">
          <div class="input-card-glass">
            <div class="slider-header">
              <span class="slider-label">Fleet Size (Active Trucks)</span>
              <span class="slider-value" id="fleet-size-val">25</span>
            </div>
            <input type="range" id="fleet-size-slider" class="range-slider" min="1" max="250" value="25">
            <div class="slider-ticks">
              <span>1 Truck</span>
              <span>125 Trucks</span>
              <span>250+ Trucks</span>
            </div>
          </div>

          <div class="input-card-glass">
            <div class="slider-header">
              <span class="slider-label">Average Monthly Fuel per Truck (Liters)</span>
              <span class="slider-value" id="fuel-volume-val">3,500 L</span>
            </div>
            <input type="range" id="fuel-volume-slider" class="range-slider" min="500" max="8000" step="100" value="3500">
            <div class="slider-ticks">
              <span>500 L</span>
              <span>4,250 L</span>
              <span>8,000 L</span>
            </div>
          </div>
        </div>

        <!-- Savings Readout Column -->
        <div class="calculator-output-card">
          <div class="saving-card-inner">
            <span class="output-label">ESTIMATED TOTAL ANNUAL SAVINGS</span>
            <div class="huge-glowing-number" id="annual-savings-readout">$26,250</div>
            
            <div class="savings-breakdown">
              <div class="breakdown-row">
                <span class="breakdown-label"><i class="fas fa-gas-pump" style="color: var(--color-accent); margin-right: 0.5rem;"></i> Fuel Rebate Value (25¢ / L)</span>
                <strong class="breakdown-value" id="breakdown-fuel">$21,875</strong>
              </div>
              <div class="breakdown-row">
                <span class="breakdown-label"><i class="fas fa-clock" style="color: var(--color-accent); margin-right: 0.5rem;"></i> Admin & IFTA Hours Saved</span>
                <strong class="breakdown-value" id="breakdown-admin">$4,375</strong>
              </div>
            </div>

            <div style="margin-top: 2rem;">
              <a href="/apply" class="btn btn-primary btn-large btn-full">Start Saving Today</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Live Interactive Dashboard Emulator Section (Surpassing Nomad.io) -->
  <section class="section section-dark-interactive" id="live-portal-emulator" style="border-top: 1px solid rgba(255,255,255,0.06); padding-top: 4rem;">
    <div class="container">
      <div class="section-title-wrap">
        <h2 style="color: var(--color-white);">Experience Absolute Fleet Control Live</h2>
        <p class="max-w-md text-center" style="color: rgba(255, 255, 255, 0.7); margin: 1rem auto 0 auto;">Don't just take our word for it. Test drive the core controls of our administrative dashboard below and watch our AI defenses intercept threat variables in real-time.</p>
      </div>

      <div class="emulator-grid">
        <!-- Left Side: Interactive Dashboard Controls -->
        <div class="emulator-stage">
          <!-- Card Render -->
          <div class="emulator-card-container">
            <div class="highlight-glow"></div>
            <div class="emulator-card-render" id="emulator-card">
              <div class="card-top">
                <span class="card-brand"><%= config.brand.name %></span>
                <div class="card-chip"></div>
              </div>
              <div class="card-number">•••• •••• •••• 9981</div>
              <div class="card-bottom">
                <div class="card-holder">
                  <span>FLEET UNIT</span>
                  <strong>UNIT #285</strong>
                </div>
                <div class="card-status-pill active" id="card-status-pill">
                  <span class="status-dot"></span>
                  <span id="card-status-text">ACTIVE</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Interactive Switches and Settings -->
          <div class="emulator-controls">
            <!-- Card Lock switch -->
            <div class="control-card-glass">
              <div class="control-row">
                <div class="control-title-box">
                  <i class="fas fa-snowflake" style="color: var(--color-accent);"></i>
                  <span>Instant Security Freeze</span>
                </div>
                 <label class="switch-wrap">
                  <input type="checkbox" id="card-lock-toggle">
                  <span class="switch-slider"></span>
                </label>
              </div>
              <p style="font-size: 0.85rem; color: rgba(255,255,255,0.65); margin: 0;">Freeze card instantly to prevent transaction clearance (e.g. driver lost card, emergency lockout).</p>
            </div>

            <!-- Daily Spend limit slider -->
            <div class="control-card-glass">
              <div class="slider-header" style="margin-bottom: 0.5rem;">
                <div class="control-title-box">
                  <i class="fas fa-sliders" style="color: var(--color-accent);"></i>
                  <span>Daily Fuel Volume Limit</span>
                </div>
                <span class="slider-value" id="card-spend-val" style="font-size: 1.15rem;">150 Gal</span>
              </div>
              <input type="range" id="card-spend-slider" class="range-slider" min="50" max="300" step="10" value="150">
              <p style="font-size: 0.85rem; color: rgba(255,255,255,0.65); margin-top: 0.5rem; margin-bottom: 0;">Restricts gallons per day on the road. Updates are propagated immediately to the card.</p>
            </div>

            <!-- Geofence Grid checklist -->
            <div class="control-card-glass">
              <div class="control-title-box" style="margin-bottom: 0.25rem;">
                <i class="fas fa-map-location-dot" style="color: var(--color-accent);"></i>
                <span>Approved Corridor Geofences</span>
              </div>
              <p style="font-size: 0.85rem; color: rgba(255,255,255,0.65); margin-bottom: 0.75rem;">Limit refueling purchases exclusively to pre-checked highway lanes. Off-route fills block instantly.</p>
              <div class="geofence-list">
                <label class="geofence-checkbox">
                  <input type="checkbox" value="on" checked>
                  <span>Ontario ON</span>
                </label>
                <label class="geofence-checkbox">
                  <input type="checkbox" value="midwest" checked>
                  <span>US Mid-West</span>
                </label>
                <label class="geofence-checkbox">
                  <input type="checkbox" value="i95" checked>
                  <span>US I-95 Grid</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side: Scrolling Live Activity stream -->
        <div class="activity-feed-panel">
          <div class="feed-header">
            <div class="feed-title">
              <i class="fas fa-terminal"></i>
              <span>Real-Time Security Log Stream</span>
            </div>
            <div class="feed-badge-pulse">
              <span class="pulse-dot-red"></span>
              <span>LIVE TELEMETRY</span>
            </div>
          </div>
          
          <!-- Activity lists container -->
          <div class="activity-list" id="activity-list">
            <!-- Dynamically injected items go here -->
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Pricing Comparison Table -->
  <section class="section section-light-teal" id="pricing-matrix">
    <div class="container">
      <div class="section-title-wrap">
        <h2>Wholesale Pricing Without Hidden Surcharges</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">Compare side-by-side: Hire7 Fuel eliminates the predatory margins and hidden setup fees common to legacy programs, matching the sleekest tech upstarts while providing premium truck support.</p>
      </div>

      <div class="pricing-matrix-wrap">
        <table class="pricing-table">
          <thead>
            <tr>
              <th>Platform Parameters</th>
              <th class="highlight-col">Hire7 Fuel Card</th>
              <th>Legacy Cards (WEX/Comdata)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Monthly Card Fee</strong></td>
              <td class="highlight-col"><span class="check-icon"><i class="fas fa-circle-check"></i> $0.00 (Free)</span></td>
              <td><span class="cross-icon"><i class="fas fa-circle-xmark"></i> $5.00 – $10.00 / card</span></td>
            </tr>
            <tr>
              <td><strong>Standard Swipe / Network Charge</strong></td>
              <td class="highlight-col"><span class="check-icon"><i class="fas fa-circle-check"></i> $0.00 (Zero)</span></td>
              <td><span class="cross-icon"><i class="fas fa-circle-xmark"></i> $2.00 – $3.50 per swipe</span></td>
            </tr>
            <tr>
              <td><strong>Credit Setup & Deposits</strong></td>
              <td class="highlight-col"><span class="check-icon"><i class="fas fa-circle-check"></i> $0.00 (None Required)</span></td>
              <td><span class="cross-icon"><i class="fas fa-circle-xmark"></i> Upfront security deposits required</span></td>
            </tr>
            <tr>
              <td><strong>Fuel Pricing Basis</strong></td>
              <td class="highlight-col">Wholesale Cost-Plus (Rack Basis)</td>
              <td>Retail Price + hidden markups</td>
            </tr>
            <tr>
              <td><strong>Automated IFTA Tax Export</strong></td>
              <td class="highlight-col"><span class="check-icon"><i class="fas fa-circle-check"></i> Included (Free)</span></td>
              <td><span class="cross-icon"><i class="fas fa-circle-xmark"></i> $15/month extra addon</span></td>
            </tr>
            <tr>
              <td><strong>Support Dispatcher access</strong></td>
              <td class="highlight-col">24/7 dedicated dispatch support</td>
               <td>Long call queues, automated IVR</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Fraud Guarantee Alert Strip -->
  <section class="guarantee-banner" id="guarantee-banner">
    <div class="container">
      <div class="guarantee-layout">
        <i class="fas fa-shield-halved guarantee-icon"></i>
        <div class="guarantee-text">
          <h2>Zero-Liability Fraud Protection Guarantee</h2>
          <p>Sleep easy knowing your fleet transactions are locked down. Hire7 Fuel shields you from unauthorized activities through real-time notifications and instant online freeze controls.</p>
          <span class="guarantee-footnote">*Subject to immediate transaction review and prompt activation of card block settings. Terms apply.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Features Section -->
  <section class="section section-light-teal" id="features">
    <div class="container">
      <div class="section-title-wrap">
        <h2>Features Designed for Commercial Growth</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">Take back control of your operations. Our backend portal provides powerful utilities tailored to modern logistics.</p>
      </div>

      <div class="features-grid">
        <!-- Feature 1 -->
        <div class="feature-card" id="featRealTime">
          <div class="feature-icon-circle">
            <i class="fas fa-clock"></i>
          </div>
          <h3>Real-Time Alerts</h3>
          <p>Receive immediate updates on the exact location, quantity, and time of every fill-up right to your smartphone.</p>
        </div>
        <!-- Feature 2 -->
        <div class="feature-card" id="featGeofencing">
          <div class="feature-icon-circle">
            <i class="fas fa-map-location-dot"></i>
          </div>
          <h3>Station Geofencing</h3>
          <p>Restrict cards so they only operate within pre-approved zip codes or specific highway corridors.</p>
        </div>
        <!-- Feature 3 -->
        <div class="feature-card" id="featLimits">
          <div class="feature-icon-circle">
            <i class="fas fa-sliders"></i>
          </div>
          <h3>Flexible Limits</h3>
          <p>Adjust limits on diesel fuel, shop repair allowances, and driver lodging fees individually, instantly.</p>
        </div>
        <!-- Feature 4 -->
        <div class="feature-card" id="featReporting">
          <div class="feature-icon-circle">
            <i class="fas fa-file-invoice-dollar"></i>
          </div>
          <h3>IFTA Reporting</h3>
          <p>Export pre-formatted, tax-compliant fuel purchase logs, saving your back-office staff hours of manual math.</p>
        </div>
        <!-- Feature 5 -->
        <div class="feature-card" id="featPricing">
          <div class="feature-icon-circle">
            <i class="fas fa-percent"></i>
          </div>
          <h3>Direct Fuel Discounts</h3>
          <p>Access competitive, pre-negotiated wholesale pricing structures directly at high-volume highway truck stops.</p>
        </div>
        <!-- Feature 6 -->
        <div class="feature-card" id="featSupport">
          <div class="feature-icon-circle">
            <i class="fas fa-headset"></i>
          </div>
          <h3>24/7 Fleet Assistance</h3>
          <p>Reach dedicated logistics dispatchers who understand the pressures of long-haul deadlines anytime.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== NEW SECTION: HIRE7 MOBILE COMPANION APP ==================== -->
  <section class="section" id="mobile-app" style="border-top: 1px solid rgba(255,255,255,0.06); padding-top: 5rem;">
    <div class="container">
      <div class="section-title-wrap">
        <span style="font-size: 0.85rem; color: var(--color-accent); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 0.5rem;"><i class="fas fa-mobile-screen-button"></i> Mobile Companion App</span>
        <h2>High-Efficiency Telemetry & Real-Time Tracking</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">Empower your drivers on the highway while maintaining absolute control from dispatch. Our native mobile app is the ultimate copilot for efficiency.</p>
      </div>

      <div class="mobile-app-layout">
        
        <!-- Left Side: Sleek Interactive Phone Device Mockup -->
        <div class="mobile-device-mockup">
          <div class="mobile-device-screen">
            <!-- Simulated App Header -->
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 0.5rem; margin-bottom: 0.25rem;">
              <span style="font-weight: 800; font-size: 0.85rem; color: var(--color-white); display: flex; align-items: center; gap: 0.35rem;"><i class="fas fa-gas-pump" style="color: var(--color-accent);"></i> HIRE7 MOBILE</span>
              <span style="font-size: 0.65rem; background-color: rgba(34,201,138,0.1); border: 1px solid rgba(34,201,138,0.2); color: var(--color-accent); padding: 0.15rem 0.45rem; border-radius: 10px; font-weight: 700;"><i class="fas fa-satellite"></i> LIVE</span>
            </div>

            <!-- Gauge: Real-time Fuel Tracking Widget -->
            <div class="mobile-widget">
              <div class="mobile-widget-header">
                <span>Fuel Telemetry</span>
                <span style="color: var(--color-accent); font-weight: bold;"><i class="fas fa-chart-simple"></i> EFFICIENT</span>
              </div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem;">
                <div>
                  <span style="font-size: 0.65rem; color: #a3c2c2; display: block;">FUEL USAGE RATE</span>
                  <strong style="font-size: 1.1rem; color: var(--color-white);">6.8 Gal/Hr</strong>
                </div>
                <div style="text-align: right;">
                  <span style="font-size: 0.65rem; color: #a3c2c2; display: block;">CURRENT LEVEL</span>
                  <strong style="font-size: 1.1rem; color: var(--color-accent);">84% Full</strong>
                </div>
              </div>
            </div>

            <!-- GPS: Low Fuel Location Widget -->
            <div class="mobile-widget">
              <div class="mobile-widget-header">
                <span>Low Fuel GPS Locator</span>
                <span style="color: var(--color-highlight);"><i class="fas fa-location-arrow"></i> 2.4 MILES</span>
              </div>
              <div style="background-color: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 0.65rem; margin-top: 0.5rem; display: flex; align-items: center; gap: 0.75rem;">
                <div style="width: 32px; height: 32px; border-radius: 6px; background-color: rgba(245,166,35,0.1); border: 1px solid rgba(245,166,35,0.3); display: flex; align-items: center; justify-content: center; color: var(--color-highlight); font-size: 0.85rem;"><i class="fas fa-map-pin"></i></div>
                <div style="flex-grow: 1;">
                  <strong style="font-size: 0.75rem; color: var(--color-white); display: block;">Pilot Travel Center #240</strong>
                  <span style="font-size: 0.65rem; color: #a3c2c2; display: block;">Lowest wholesale cost: $3.42/Gal</span>
                </div>
              </div>
            </div>

            <!-- Behavior: Driver score widget -->
            <div class="mobile-widget" style="text-align: center;">
              <div class="mobile-widget-header">
                <span>Active Driver Score</span>
                <span style="color: var(--color-accent); font-weight: bold;"><i class="fas fa-award"></i> EXCELLENT</span>
              </div>
              <div class="mobile-score-circle">
                <span class="mobile-score-val">96</span>
              </div>
              <p style="font-size: 0.65rem; color: #a3c2c2; margin: 0.5rem 0 0 0; line-height: 1.4;">Zero harsh acceleration logs, 98% optimal speed corridor maintenance, 0 wasteful idle events.</p>
            </div>

            <!-- Security: Fraud Protection Alert -->
            <div class="mobile-widget" style="background-color: rgba(34, 201, 138, 0.03); border-color: rgba(34, 201, 138, 0.25);">
              <div style="display: flex; gap: 0.65rem; align-items: center;">
                <i class="fas fa-shield-halved" style="color: var(--color-accent); font-size: 0.95rem;"></i>
                <div style="text-align: left;">
                  <strong style="font-size: 0.75rem; color: var(--color-white); display: block;">Card Shield Enabled</strong>
                  <span style="font-size: 0.65rem; color: #a3c2c2;">Card geolocked to truck location.</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side: Beautiful App Feature Descriptions -->
        <div class="mobile-app-feature-list">
          
          <!-- Feature 1: Tracking Fuel Usage -->
          <div class="mobile-app-feature-card">
            <div class="mobile-app-feature-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <div class="mobile-app-feature-info">
              <h3>High-Efficiency Fuel Tracking</h3>
              <p>Eliminate black holes in your operating logs. Our mobile companion automatically measures and logs real-time fuel draw-downs, recording exact quantities, timestamps, and highway coordinates with millimeter accuracy.</p>
            </div>
          </div>

          <!-- Feature 2: Low Fuel Locations -->
          <div class="mobile-app-feature-card">
            <div class="mobile-app-feature-icon" style="color: var(--color-highlight); border-color: rgba(245,166,35,0.25); background-color: rgba(245,166,35,0.08);">
              <i class="fas fa-compass"></i>
            </div>
            <div class="mobile-app-feature-info">
              <h3>Low Fuel GPS Corridor Locators</h3>
              <p>Save dollars on every mile. When fuel reserves run low, the app cross-references your route to guide drivers to nearby, pre-negotiated wholesale cost-plus stations, completely bypassing overpriced retail highway pumps.</p>
            </div>
          </div>

          <!-- Feature 3: Driver Fuel Behaviour -->
          <div class="mobile-app-feature-card">
            <div class="mobile-app-feature-icon" style="color: var(--color-seafoam); border-color: rgba(58,191,160,0.25); background-color: rgba(58,191,160,0.08);">
              <i class="fas fa-gauge-high"></i>
            </div>
            <div class="mobile-app-feature-info">
              <h3>Driver Fuel Behavior Insights</h3>
              <p>Detect and optimize wasteful driving patterns. Monitor harsh braking, aggressive highway acceleration spikes, and excessive diesel idling logs in real-time, helping you reclaim thousands of wasted dollars annually.</p>
            </div>
          </div>

          <!-- Feature 4: Driver Score -->
          <div class="mobile-app-feature-card">
            <div class="mobile-app-feature-icon" style="color: #60a5fa; border-color: rgba(96,165,250,0.25); background-color: rgba(96,165,250,0.08);">
              <i class="fas fa-trophy"></i>
            </div>
            <div class="mobile-app-feature-info">
              <h3>Gamified Driver Performance Scores</h3>
              <p>Inspire safety and efficiency. Empower drivers with transparent daily scoring indexes (1 to 100). Gamify route operations and incentivize performance through customized driver-efficiency reward programs.</p>
            </div>
          </div>

          <!-- Feature 5: Fraud Protections -->
          <div class="mobile-app-feature-card">
            <div class="mobile-app-feature-icon">
              <i class="fas fa-user-shield"></i>
            </div>
            <div class="mobile-app-feature-info">
              <h3>Multi-Layered Mobile Fraud Protections</h3>
              <p>Keep your capital safe. Features zero-liability checkouts, instant geofencing, and double-factor driver identity verification. Cards are automatically locked to the truck's coordinates and frozen instantly on alert triggers.</p>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- ==================== NEW SECTION: TARGETED CARRIER TIERS ==================== -->
  <section class="section section-light-teal" id="targeted-carriers" style="border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="container">
      <div class="section-title-wrap">
        <span style="font-size: 0.85rem; color: var(--color-accent); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 0.5rem;"><i class="fas fa-truck-moving"></i> Targeted Carriers</span>
        <h2>Fueling Success for Fleets of Any Size</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">Whether you operate a single rig or coordinate national line-haul operations, our program scales seamlessly to eliminate manual admin overhead.</p>
      </div>

      <div class="targeted-carriers-grid">
        
        <!-- Profile 1: Owner Operators -->
        <div class="carrier-profile-card">
          <div class="carrier-badge-wrap">
            <div class="carrier-badge-icon"><i class="fas fa-user-gear"></i></div>
            <span class="carrier-size-tag">1-5 TRUCKS</span>
          </div>
          <h3>Owner Operators</h3>
          <p>For independent haulers looking to maximize take-home income. Skip credit gatekeepers, enjoy cash-flow stability, and get immediate wholesale pricing at the pump.</p>
          <ul class="carrier-features-list">
            <li><i class="fas fa-circle-check"></i> Zero Setup Fees</li>
            <li><i class="fas fa-circle-check"></i> Next-Day Fast Shipping</li>
            <li><i class="fas fa-circle-check"></i> Instant Mobile Card Freeze</li>
          </ul>
        </div>

        <!-- Profile 2: Regional Fleets -->
        <div class="carrier-profile-card">
          <div class="carrier-badge-wrap">
            <div class="carrier-badge-icon"><i class="fas fa-boxes-packing"></i></div>
            <span class="carrier-size-tag" style="color: #60a5fa; border-color: rgba(96,165,250,0.25); background-color: rgba(96,165,250,0.08);">5-50 TRUCKS</span>
          </div>
          <h3>Regional Fleets</h3>
          <p>For growing transport businesses requiring robust compliance and driver control tools. Gain full geofence boundary locking, driver scoring, and direct route control.</p>
          <ul class="carrier-features-list">
            <li><i class="fas fa-circle-check"></i> Station Geofence Locks</li>
            <li><i class="fas fa-circle-check"></i> Driver Efficiency Tracking</li>
            <li><i class="fas fa-circle-check"></i> Underwriting in 24 Hours</li>
          </ul>
        </div>

        <!-- Profile 3: Enterprise Logistics -->
        <div class="carrier-profile-card">
          <div class="carrier-badge-wrap">
            <div class="carrier-badge-icon"><i class="fas fa-network-wired"></i></div>
            <span class="carrier-size-tag" style="color: var(--color-accent); border-color: rgba(34,201,138,0.25); background-color: rgba(34,201,138,0.08);">50+ TRUCKS</span>
          </div>
          <h3>Enterprise Logistics</h3>
          <p>For large-scale freight networks requiring custom API integrations, real-time geofence tracking, automated tax logs, and 24/7 dispatcher channels.</p>
          <ul class="carrier-features-list">
            <li><i class="fas fa-circle-check"></i> Automated IFTA Tax Audits</li>
            <li><i class="fas fa-circle-check"></i> Dynamic API Webhooks</li>
            <li><i class="fas fa-circle-check"></i> 24/7 Dedicated Dispatchers</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- Client Testimonials Section -->
  <section class="section" id="testimonials">
    <div class="container">
      <div class="section-title-wrap">
        <h2>Trusted by Modern Carriers</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">See how transport owners are scaling their operations and reducing overhead using the Hire7 Fuel program.</p>
      </div>

      <div class="testimonials-grid">
        <% if (locals.testimonials && testimonials.length > 0) { %>
          <% testimonials.forEach((t) => { %>
            <% 
              // Compute initials from author name
              const initials = t.author.trim().split(/\s+/).map(n => n[0]).join('').substring(0, 2).toUpperCase();
            %>
            <div class="testimonial-card" id="testi-<%= t.id %>">
              <div class="quote-bubble">
                <div class="rating-stars">
                  <% for (let s = 0; s < t.stars; s++) { %>
                    <i class="fas fa-star"></i>
                  <% } %>
                </div>
                <p>"<%= t.quote %>"</p>
              </div>
              <div class="testimonial-client">
                <div class="client-avatar"><%= initials %></div>
                <div class="client-info">
                  <h4><%= t.author %></h4>
                  <span><%= t.role %></span>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--color-muted);">
            <i class="fas fa-quote-right" style="font-size: 2rem; opacity: 0.15; margin-bottom: 1rem; display: block;"></i>
            <p style="font-style: italic;">No verified fleet testimonials active at this time.</p>
          </div>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Inline Contact Form Section -->
  <section class="section section-light-teal" id="contact-form-section">
    <div class="container form-split-layout">
      <div class="form-intro">
        <h2>Power Your Fleet to the Next Level</h2>
        <p>Contact our onboarding team for a customized pricing proposal tailored to your unique lane schedules and truck volume.</p>
        <div class="onboarding-cards">
          <div class="onboarding-card">
            <div class="onboarding-icon">
              <i class="fas fa-file-contract"></i>
            </div>
            <div class="onboarding-content">
              <h3>Zero Lock-In Contracts</h3>
              <p>No sign-up setup charges or long-term commitments. Scale your fleet on your own terms.</p>
            </div>
          </div>
          <div class="onboarding-card">
            <div class="onboarding-icon">
              <i class="fas fa-bolt"></i>
            </div>
            <div class="onboarding-content">
              <h3>Rapid Underwriting</h3>
              <p>Approved credit checks within 24 business hours so your trucks can get moving immediately.</p>
            </div>
          </div>
          <div class="onboarding-card">
            <div class="onboarding-icon">
              <i class="fas fa-truck-fast"></i>
            </div>
            <div class="onboarding-content">
              <h3>Express Card Delivery</h3>
              <p>Physical fuel cards shipped next-day via express delivery directly to your dispatch office.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="form-card" id="contact-form">
        <% if (success) { %>
          <div class="alert alert-success" role="alert">
            <i class="fas fa-circle-check" style="margin-right: 0.5rem;"></i>
            <strong>Thank you!</strong> Your message has been submitted. One of our commercial representatives will contact you shortly.
          </div>
        <% } %>
        
        <form action="/submit-inquiry" method="POST" needs-validation novalidate>
          <div class="form-group">
            <label for="name">Full Name <span style="color: var(--color-error);">*</span></label>
            <input type="text" id="name" name="name" class="form-control" placeholder="Jane Doe" required minlength="2">
          </div>
          
          <div class="form-group">
            <label for="company">Company Name</label>
            <input type="text" id="company" name="company" class="form-control" placeholder="Logistics Express Inc.">
          </div>

          <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
              <label for="phone">Phone Number <span style="color: var(--color-error);">*</span></label>
              <input type="tel" id="phone" name="phone" class="form-control" placeholder="(905) 555-0199" required pattern="^\(?([0-9]{3})\)?[-. ]?([0-9]{3})[-. ]?([0-9]{4})$">
            </div>
            <div class="form-group">
              <label for="email">Email Address <span style="color: var(--color-error);">*</span></label>
              <input type="email" id="email" name="email" class="form-control" placeholder="jane@company.com" required>
            </div>
          </div>

          <div class="form-group">
            <label for="message">Message <span style="color: var(--color-error);">*</span></label>
            <textarea id="message" name="message" class="form-control" placeholder="Tell us about your fleet size and primary refueling routes..." required minlength="10"></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-full btn-large">Request Fleet Consultation</button>
        </form>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
