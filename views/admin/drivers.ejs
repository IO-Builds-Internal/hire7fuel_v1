<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Global Driver Roster | Admin Command Center</title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .admin-body { background-color: #f9fafb !important; color: #2d3748 !important; }
    .admin-card { background: #FFFFFF !important; border: 1px solid rgba(0,0,0,0.08) !important; border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
    .admin-card h2 { color: #0a2c2c !important; }
    .admin-table th { background-color: #f3f4f6 !important; color: #0a2c2c !important; font-weight: 600; padding: 0.75rem 1rem; border-bottom: 1px solid rgba(0,0,0,0.06); }
    .admin-table td { color: #2d3748 !important; border-bottom: 1px solid rgba(0,0,0,0.05); padding: 0.75rem 1rem; }
    .expiry-badge { display: inline-block; padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
    .badge-green { background-color: #DEF7EC; color: #03543F; }
    .badge-amber { background-color: #FEF3C7; color: #92400E; }
    .badge-red { background-color: #FDE8E8; color: #9B1C1C; }
  </style>
</head>
<body class="admin-body">

  <nav class="admin-nav">
    <div class="admin-nav-container">
      <a href="/admin" class="logo-link" style="font-size: 1.35rem; display: flex; align-items: center; gap: 0.75rem;">
        <img src="<%= config.brand.logo %>" alt="Logo" class="admin-nav-logo">
        <span><%= config.brand.name %> Admin</span>
      </a>

      <ul class="admin-nav-links">
        <li><a href="/admin" class="admin-nav-link">Dashboard Hub</a></li>
        <li><a href="/admin/compliance" class="admin-nav-link">Compliance Overview</a></li>
        <li><a href="/admin/drivers" class="admin-nav-link active">All Drivers</a></li>
        <li><a href="/admin/fleet" class="admin-nav-link">All Fleet</a></li>
        <li><a href="/admin/settings" class="admin-nav-link">Site Settings</a></li>
        <li><a href="/admin/jobs" class="admin-nav-link">Careers Admin</a></li>
        <li><a href="/admin/testimonials" class="admin-nav-link">Manage Testimonials</a></li>
      </ul>

      <a href="/admin/logout" class="admin-logout">
        <i class="fas fa-power-off"></i> Logout
      </a>
    </div>
  </nav>

  <main class="admin-container">
    
    <div class="admin-header-wrap">
      <div>
        <h1>Global Drivers Fleet List</h1>
        <p style="color: #4a5568; margin-top: 0.25rem;">Unified view of all drivers onboarded across carriers.</p>
      </div>
    </div>

    <div class="admin-card">
      <h2>Active Drivers</h2>
      
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Carrier</th>
              <th>Driver Name</th>
              <th>DL #</th>
              <th>Email Address</th>
              <th>Phone Number</th>
              <th>Driver Type</th>
              <th style="text-align: right;">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (drivers && drivers.length > 0) { %>
              <% drivers.forEach(function(d) { %>
                <tr>
                  <td style="font-weight: 600; color: #0a2c2c;"><%= d.carrier_name %></td>
                  <td style="font-weight: 600;"><%= d.last_name %>, <%= d.first_name %></td>
                  <td style="font-family: monospace;"><%= d.dl_number %> (<%= d.dl_state %>)</td>
                  <td><%= d.email || '—' %></td>
                  <td><%= d.can_phone || d.usa_phone || '—' %></td>
                  <td><%= d.driver_type %></td>
                  <td style="text-align: right;">
                    <a href="/portal/switch-carrier/<%= d.carrier_id %>" class="portal-btn portal-btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; color: var(--color-accent); border-color: var(--color-accent); text-decoration: none;">
                      Manage Carrier
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" style="text-align: center; color: #718096; padding: 3rem;">
                  No drivers found.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

</body>
</html>
