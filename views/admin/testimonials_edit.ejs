<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Carrier Testimonial | <%= config.brand.name %></title>
  <link class="styles" rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../partials/admin_nav') %>
    
    <div style="margin-top: 1.5rem; margin-bottom: 1.5rem;">
      <a href="/admin/testimonials" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-accent); font-weight: 600; text-decoration: none; font-size: 0.95rem;">
        <i class="fas fa-arrow-left"></i> Back to Testimonials Admin
      </a>
    </div>

    <!-- Alert notifications -->
    <% if (error) { %>
      <div class="alert alert-danger">
        <i class="fas fa-triangle-exclamation"></i> 
        <strong>Transaction Error:</strong> <%= error %>
      </div>
    <% } %>

    <div class="admin-card">
      <h3 style="color: var(--color-white); font-size: 1.15rem; border-bottom: 1px solid rgba(0, 0, 0, 0.06); padding-bottom: 0.5rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
        <i class="fas fa-pen-to-square text-accent"></i> Testimonial Parameters
      </h3>

      <form action="/admin/testimonials/edit/<%= testimonial.id %>" method="POST">
        
        <div class="form-group admin-form-group">
          <label for="author">Author Name <span style="color: var(--color-error);">*</span></label>
          <input type="text" id="author" name="author" class="form-control admin-input" value="<%= testimonial.author %>" required>
        </div>

        <div class="form-group admin-form-group">
          <label for="role">Client Role / Company Name <span style="color: var(--color-error);">*</span></label>
          <input type="text" id="role" name="role" class="form-control admin-input" value="<%= testimonial.role %>" required>
        </div>

        <div class="form-group admin-form-group">
          <label for="stars">Star Rating <span style="color: var(--color-error);">*</span></label>
          <select id="stars" name="stars" class="form-control admin-input" required>
            <option value="5" <%= testimonial.stars === 5 ? 'selected' : '' %>>5 Stars (Excellent)</option>
            <option value="4" <%= testimonial.stars === 4 ? 'selected' : '' %>>4 Stars (Good)</option>
            <option value="3" <%= testimonial.stars === 3 ? 'selected' : '' %>>3 Stars (Average)</option>
            <option value="2" <%= testimonial.stars === 2 ? 'selected' : '' %>>2 Stars (Poor)</option>
            <option value="1" <%= testimonial.stars === 1 ? 'selected' : '' %>>1 Star (Very Poor)</option>
          </select>
        </div>

        <div class="form-group admin-form-group" style="margin-bottom: 2rem;">
          <label for="quote">Carrier Review Quote <span style="color: var(--color-error);">*</span></label>
          <textarea id="quote" name="quote" class="form-control admin-input" required style="min-height: 120px;"><%= testimonial.quote %></textarea>
        </div>

        <div style="display: flex; gap: 1rem;">
          <button type="submit" class="btn btn-primary btn-large" style="min-width: 180px;">Save Updates</button>
          <a href="/admin/testimonials" class="btn btn-outline-dark btn-large" style="min-width: 120px; text-decoration: none;">Cancel</a>
        </div>
      </form>
    </div>
    </div>
  </div>

  <!-- FontAwesome for standard icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</body>
</html>
