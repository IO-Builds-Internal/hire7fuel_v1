<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Global Safety Compliance | Admin Command Center</title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    /* Styling extension for admin dashboard alignment */
    .admin-body {
      background-color: #f9fafb !important;
      color: #2d3748 !important;
    }
    .admin-card {
      background: #FFFFFF !important;
      border: 1px solid rgba(0, 0, 0, 0.08) !important;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04) !important;
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 2rem;
    }
    .admin-card h2 {
      color: #0a2c2c !important;
      margin-bottom: 1.5rem;
    }
    .admin-table th {
      background-color: #f3f4f6 !important;
      color: #0a2c2c !important;
      font-weight: 600;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .admin-table td {
      color: #2d3748 !important;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      padding: 0.75rem 1rem;
    }
    .admin-table tr:hover td {
      background-color: #f9fafb !important;
    }
    .expiry-badge {
      display: inline-block;
      padding: 0.25rem 0.5rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .badge-green { background-color: #DEF7EC; color: #03543F; }
    .badge-amber { background-color: #FEF3C7; color: #92400E; }
    .badge-red { background-color: #FDE8E8; color: #9B1C1C; }
  </style>
</head>
<body class="admin-body">

  <!-- Admin Navigation -->
  <nav class="admin-nav">
    <div class="admin-nav-container">
      <a href="/admin" class="logo-link" style="font-size: 1.35rem; display: flex; align-items: center; gap: 0.75rem;">
        <img src="<%= config.brand.logo %>" alt="Logo" class="admin-nav-logo">
        <span><%= config.brand.name %> Admin</span>
      </a>

      <ul class="admin-nav-links">
        <li><a href="/admin" class="admin-nav-link">Dashboard Hub</a></li>
        <li><a href="/admin/compliance" class="admin-nav-link active">Compliance Overview</a></li>
        <li><a href="/admin/drivers" class="admin-nav-link">All Drivers</a></li>
        <li><a href="/admin/fleet" class="admin-nav-link">All Fleet</a></li>
        <li><a href="/admin/settings" class="admin-nav-link">Site Settings</a></li>
        <li><a href="/admin/jobs" class="admin-nav-link">Careers Admin</a></li>
        <li><a href="/admin/testimonials" class="admin-nav-link">Manage Testimonials</a></li>
      </ul>

      <a href="/admin/logout" class="admin-logout">
        <i class="fas fa-power-off"></i> Logout
      </a>
    </div>
  </nav>

  <main class="admin-container">
    
    <div class="admin-header-wrap">
      <div>
        <h1>Safety Compliance Oversight</h1>
        <p style="color: #4a5568; margin-top: 0.25rem;">Monitor compliance documents, upcoming expiries, and filing status across all registered carriers.</p>
      </div>
      <div>
        <a href="/admin/compliance/expiry/csv" class="admin-action-btn admin-view-details" style="color: var(--color-accent); border-color: var(--color-accent); background: rgba(20,160,119,0.08); font-weight: 600; padding: 0.5rem 1rem; border-radius: var(--radius-sm); font-size: 0.9rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
          <i class="fas fa-file-csv"></i> Export Expiries (CSV)
        </a>
      </div>
    </div>

    <!-- Global Expiries Dashboard Card -->
    <div class="admin-card">
      <h2>Global Expiry Tracker (Next 60 Days)</h2>
      
      <div class="admin-table-wrap">
        <table class="admin-table" id="expiriesTable">
          <thead>
            <tr>
              <th onclick="sortTable(0)" style="cursor: pointer;">Carrier <i class="fas fa-sort"></i></th>
              <th onclick="sortTable(1)" style="cursor: pointer;">Entity <i class="fas fa-sort"></i></th>
              <th onclick="sortTable(2)" style="cursor: pointer;">Document / Field <i class="fas fa-sort"></i></th>
              <th onclick="sortTable(3)" style="cursor: pointer;">Expiry Date <i class="fas fa-sort"></i></th>
              <th onclick="sortTable(4)" style="cursor: pointer; text-align: right;">Days Left <i class="fas fa-sort"></i></th>
              <th style="text-align: right;">Alert Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (expiries && expiries.length > 0) { %>
              <% expiries.forEach(function(e) { %>
                <tr>
                  <td style="font-weight: 600; color: #0a2c2c;"><%= e.carrier %></td>
                  <td><%= e.entity %></td>
                  <td><%= e.field %></td>
                  <td style="font-family: monospace;"><%= e.date %></td>
                  <td style="text-align: right; font-family: monospace; font-weight: 600;"><%= e.daysLeft %> days</td>
                  <td style="text-align: right;">
                    <span class="expiry-badge <%= e.daysLeft <= 7 ? 'badge-red' : (e.daysLeft <= 30 ? 'badge-amber' : 'badge-green') %>">
                      <%= e.daysLeft <= 0 ? 'EXPIRED' : (e.daysLeft <= 7 ? 'URGENT' : (e.daysLeft <= 30 ? 'WARNING' : 'PENDING')) %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" style="text-align: center; color: #718096; padding: 3rem;">
                  <i class="fas fa-check-circle" style="font-size: 2.5rem; color: #10B981; margin-bottom: 1rem; display: block;"></i>
                  <strong>No upcoming expiries</strong>
                  <p style="margin: 0; font-size: 0.85rem; color: #718096; margin-top: 0.25rem;">All safety documents and registration plate expiries across all carriers are fully compliant for the next 60 days.</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

  <script>
    // Client-side table sorting
    function sortTable(n) {
      const table = document.getElementById("expiriesTable");
      let switching = true;
      let dir = "asc";
      let switchcount = 0;
      
      while (switching) {
        switching = false;
        const rows = table.rows;
        
        for (let i = 1; i < (rows.length - 1); i++) {
          let shouldSwitch = false;
          const x = rows[i].getElementsByTagName("TD")[n];
          const y = rows[i + 1].getElementsByTagName("TD")[n];
          
          let valX = x.innerHTML.toLowerCase().trim();
          let valY = y.innerHTML.toLowerCase().trim();
          
          // Number sorting
          if (n === 4) {
            valX = parseInt(valX) || 0;
            valY = parseInt(valY) || 0;
          }
          
          if (dir === "asc") {
            if (valX > valY) {
              shouldSwitch = true;
              break;
            }
          } else if (dir === "desc") {
            if (valX < valY) {
              shouldSwitch = true;
              break;
            }
          }
        }
        
        if (shouldSwitch) {
          rows[switchcount + 1].parentNode.insertBefore(rows[switchcount + 2], rows[switchcount + 1]);
          switching = true;
          switchcount++;
        } else {
          if (switchcount === 0 && dir === "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }
  </script>

</body>
</html>
