<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/admin_nav') %>
    
    <div style="margin-top: 1.5rem;"></div>

    <% if (error) { %>
      <div style="background-color: #FEF2F2; border: 1px solid rgba(239,68,68,0.2); color: #9B1C1C; padding: 1rem; border-radius: var(--radius-sm); margin-bottom: 1.5rem; font-weight: 600;">
        <i class="fas fa-exclamation-circle" style="margin-right: 0.5rem;"></i> <%= error %>
      </div>
    <% } %>

    <div class="admin-card">
      <div style="border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 1rem; margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between;">
        <h2 style="margin: 0; display: flex; align-items: center; gap: 0.5rem;">
          <i class="fas fa-building text-accent"></i> Company Onboarding Parameters
        </h2>
        <a href="/admin/carriers" class="portal-btn portal-btn-secondary" style="padding: 0.45rem 0.85rem; font-size: 0.85rem;"><i class="fas fa-arrow-left"></i> Back to List</a>
      </div>

      <form action="/admin/carriers/new" method="POST">
        <div class="portal-form-grid" style="grid-template-columns: repeat(2, 1fr);">
          <div class="portal-form-group">
            <label class="portal-label">Legal Company Name *</label>
            <input type="text" name="company_name" class="portal-input" placeholder="e.g. Acme Transport Inc." required>
          </div>
          
          <div class="portal-form-group">
            <label class="portal-label">DBA Name</label>
            <input type="text" name="dba_name" class="portal-input" placeholder="Doing Business As (if applicable)">
          </div>

          <div class="portal-form-group">
            <label class="portal-label">USDOT Number</label>
            <input type="text" name="usdot" class="portal-input" placeholder="e.g. DOT1234567">
          </div>

          <div class="portal-form-group">
            <label class="portal-label">MC Number</label>
            <input type="text" name="mc_number" class="portal-input" placeholder="e.g. MC123456">
          </div>

          <div class="portal-form-group">
            <label class="portal-label">Primary Email</label>
            <input type="email" name="email" class="portal-input" placeholder="operations@company.com">
          </div>

          <div class="portal-form-group">
            <label class="portal-label">Primary Phone</label>
            <input type="text" name="phone" class="portal-input" placeholder="+1 (555) 019-9234">
          </div>

          <div class="portal-form-group full-width">
            <label class="portal-label">Main Registered Head Office Address</label>
            <input type="text" name="main_address" class="portal-input" placeholder="123 Highway Blvd, Mississauga, ON, L5T 1A1">
          </div>
        </div>

        <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); padding: 1.25rem; border-radius: var(--radius-md); margin-top: 2rem; margin-bottom: 2rem;">
          <h4 style="margin: 0 0 0.5rem 0; color: var(--color-white); display: flex; align-items: center; gap: 0.5rem;">
            <i class="fas fa-info-circle text-accent"></i> Onboarding Automation Notice
          </h4>
          <p style="margin: 0; font-size: 0.85rem; color: var(--color-muted); line-height: 1.5;">
            By submitting this form, the system will automatically:
            <br>• Provision a dedicated <strong>Carrier Profile</strong> directory.
            <br>• Schedule default <strong>IFTA, KYU, and NY-HUT filing trackers</strong> for the current calendar year quarters.
            <br>• Enable access for active drivers and equipment assignments to be linked under this carrier context.
          </p>
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 1rem;">
          <a href="/admin/carriers" class="portal-btn portal-btn-secondary">Cancel</a>
          <button type="submit" class="portal-btn portal-btn-primary"><i class="fas fa-check-circle"></i> Onboard Carrier</button>
        </div>
      </form>
    </div>

  </div>
</body>
</html>
