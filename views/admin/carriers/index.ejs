<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    /* Premium Hover & Animation Effects */
    .admin-action-btn:hover {
      transform: translateY(-1px);
    }
    .admin-view-btn:hover {
      background: rgba(58, 191, 160, 0.15) !important;
      border-color: var(--color-seafoam) !important;
    }
    .admin-edit-btn:hover {
      background: rgba(34, 201, 138, 0.15) !important;
      border-color: var(--color-accent) !important;
    }
    .admin-delete-btn:hover {
      background: rgba(239, 68, 68, 0.18) !important;
      border-color: #ef4444 !important;
    }
    .search-wrapper {
      position: relative;
      max-width: 400px;
      margin-bottom: 1.5rem;
    }
    .search-input {
      width: 100%;
      padding: 0.65rem 1rem 0.65rem 2.5rem;
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: var(--radius-md);
      color: var(--color-white);
      font-size: 0.9rem;
      outline: none;
      transition: all 0.2s ease;
    }
    .search-input:focus {
      border-color: var(--color-accent);
      box-shadow: 0 0 0 2px rgba(34, 201, 138, 0.15);
    }
    .search-icon {
      position: absolute;
      left: 0.9rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--color-muted);
      font-size: 0.9rem;
    }
  </style>
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/admin_nav') %>
    
    <div style="margin-top: 1.5rem;"></div>

    <% if (success) { %>
      <div style="background-color: #E6FDF4; border: 1px solid rgba(34,201,138,0.2); color: #03543F; padding: 1rem; border-radius: var(--radius-sm); margin-bottom: 1.5rem; font-weight: 600;">
        <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i> Carrier registry updated successfully.
      </div>
    <% } %>
    
    <% if (error) { %>
      <div style="background-color: #FEF2F2; border: 1px solid rgba(239,68,68,0.2); color: #9B1C1C; padding: 1rem; border-radius: var(--radius-sm); margin-bottom: 1.5rem; font-weight: 600;">
        <i class="fas fa-exclamation-circle" style="margin-right: 0.5rem;"></i> <%= error %>
      </div>
    <% } %>

    <!-- Directory Controls -->
    <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem;">
      <div class="search-wrapper">
        <i class="fas fa-search search-icon"></i>
        <input type="text" id="carrierSearch" class="search-input" placeholder="Search carriers by name, email, or USDOT...">
      </div>
      
      <a href="/admin/carriers/new" class="portal-btn portal-btn-primary" style="display: inline-flex; align-items: center; gap: 0.5rem;">
        <i class="fas fa-plus-circle"></i> Onboard New Carrier
      </a>
    </div>

    <!-- Carriers List Card -->
    <div class="admin-card">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem;">
        <h2 style="margin: 0;">Registered Commercial Carriers</h2>
        <span style="font-size: 0.85rem; color: var(--color-muted);" id="carrierCount"><%= carriers.length %> Carriers total</span>
      </div>
      
      <% if (carriers && carriers.length > 0) { %>
        <div class="admin-table-wrap">
          <table class="admin-table" id="carriersTable">
            <thead>
              <tr>
                <th>Company Name</th>
                <th>USDOT Number</th>
                <th>MC Number</th>
                <th>Contact Details</th>
                <th>Status</th>
                <th style="text-align: right;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% carriers.forEach((c) => { %>
                <tr class="carrier-row">
                  <td style="font-weight: 600; color: var(--color-white);"><%= c.company_name %></td>
                  <td><code style="background: rgba(255,255,255,0.05); padding: 0.2rem 0.4rem; border-radius: 4px; color: var(--color-white); font-family: monospace;"><%= c.usdot || 'N/A' %></code></td>
                  <td><code style="background: rgba(255,255,255,0.05); padding: 0.2rem 0.4rem; border-radius: 4px; color: var(--color-white); font-family: monospace;"><%= c.mc_number || 'N/A' %></code></td>
                  <td>
                    <div style="font-size: 0.9rem;"><%= c.email || 'N/A' %></div>
                    <div style="font-size: 0.8rem; color: var(--color-muted);"><%= c.phone || 'N/A' %></div>
                  </td>
                  <td>
                    <% if (c.status === 'active') { %>
                      <span class="badge-pill badge-fuelcard" style="background: rgba(34, 201, 138, 0.1); color: var(--color-accent); border: 1px solid rgba(34, 201, 138, 0.2);">Active</span>
                    <% } else { %>
                      <span class="badge-pill" style="background: rgba(239, 68, 68, 0.1); color: #f85149; border: 1px solid rgba(239, 68, 68, 0.2);"><%= c.status %></span>
                    <% } %>
                  </td>
                  <td style="text-align: right; white-space: nowrap;">
                    <div style="display: inline-flex; align-items: center; gap: 0.5rem; justify-content: flex-end;">
                      <a href="/admin/carriers/<%= c.id %>" class="admin-action-btn admin-view-btn" style="color: var(--color-seafoam); text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.35rem; background: rgba(58, 191, 160, 0.08); border: 1px solid rgba(58, 191, 160, 0.2); padding: 0.45rem 0.75rem; border-radius: var(--radius-sm); transition: all 0.2s ease;">
                        <i class="fas fa-eye"></i> View Profile
                      </a>
                      <a href="/admin/carriers/<%= c.id %>/edit" class="admin-action-btn admin-edit-btn" style="color: var(--color-accent); text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.35rem; background: rgba(34, 201, 138, 0.08); border: 1px solid rgba(34, 201, 138, 0.2); padding: 0.45rem 0.75rem; border-radius: var(--radius-sm); transition: all 0.2s ease;">
                        <i class="fas fa-edit"></i> Edit
                      </a>
                      
                      <form action="/admin/carriers/<%= c.id %>/delete" method="POST" onsubmit="return confirm('WARNING: Deleting this carrier will permanently purge their profile, compliance filings, drivers, fleet assets, transponders, and invoicing history. This action CANNOT be undone. Are you sure you want to proceed?');" style="display: inline;">
                        <button type="submit" class="admin-delete-btn" style="background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2); color: #fca5a5; font-weight: 600; padding: 0.45rem 0.75rem; border-radius: var(--radius-sm); cursor: pointer; transition: all 0.2s ease; display: inline-flex; align-items: center; gap: 0.35rem;">
                          <i class="fas fa-trash-can" style="color: #ef4444;"></i> Delete
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div style="text-align: center; padding: 4rem 2rem; color: var(--color-muted);">
          <i class="fas fa-building" style="font-size: 3rem; color: rgba(255,255,255,0.03); margin-bottom: 1.5rem;"></i>
          <h3>No Carriers Registered</h3>
          <p style="color: #6B7280; font-size: 0.95rem; max-width: 400px; margin: 0.5rem auto 1.5rem auto;">Onboard a new transport carrier to begin tracking their compliance documents and fleet expiries.</p>
          <a href="/admin/carriers/new" class="portal-btn portal-btn-primary"><i class="fas fa-plus-circle"></i> Onboard New Carrier</a>
        </div>
      <% } %>
    </div>

  </div>

  <script>
    // Client-side quick search/filtering
    const searchInput = document.getElementById('carrierSearch');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        const query = this.value.toLowerCase().trim();
        const rows = document.querySelectorAll('.carrier-row');
        let visibleCount = 0;
        
        rows.forEach(row => {
          const text = row.textContent.toLowerCase();
          if (text.includes(query)) {
            row.style.display = '';
            visibleCount++;
          } else {
            row.style.display = 'none';
          }
        });
        
        const countSpan = document.getElementById('carrierCount');
        if (countSpan) {
          countSpan.textContent = `${visibleCount} of <%= carriers.length %> Carriers displayed`;
        }
      });
    }
  </script>
</body>
</html>
