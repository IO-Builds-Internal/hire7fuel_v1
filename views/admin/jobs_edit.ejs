<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Job Opening | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
</head>
<body class="admin-body">

  <!-- Admin Navigation -->
  <nav class="admin-nav">
    <div class="admin-nav-container">
      <a href="/admin" class="logo-link" style="font-size: 1.35rem;">
        <i class="fas fa-screwdriver-wrench text-accent"></i>
        <span><%= config.brand.name %> Admin</span>
      </a>

      <ul class="admin-nav-links">
        <li><a href="/admin" class="admin-nav-link">Dashboard Hub</a></li>
        <li><a href="/admin/settings" class="admin-nav-link">Site Settings</a></li>
        <li><a href="/admin/jobs" class="admin-nav-link active">Careers Admin</a></li>
        <li><a href="/" class="admin-nav-link" target="_blank">View Site <i class="fas fa-up-right-from-square" style="font-size: 0.75rem; margin-left: 0.25rem;"></i></a></li>
      </ul>

      <a href="/admin/logout" class="admin-logout">
        <i class="fas fa-power-off"></i> Logout
      </a>
    </div>
  </nav>

  <!-- Edit job layout -->
  <main class="admin-container" style="max-width: 800px;">
    
    <div class="admin-header-wrap">
      <div>
        <h1 style="display: flex; align-items: center; gap: 0.75rem;">
          <a href="/admin/jobs" style="color: #a3c2c2; font-size: 1.75rem; text-decoration: none;"><i class="fas fa-arrow-left"></i></a>
          Edit Job Opening
        </h1>
        <p style="color: #a3c2c2; margin-top: 0.25rem; margin-left: 2.5rem;">Modify listing details for "<%= job.title %>". Changes propagate instantly.</p>
      </div>
    </div>

    <!-- Alert notifications -->
    <% if (error) { %>
      <div class="alert" style="background-color: rgba(239, 68, 68, 0.15); border: 1px solid var(--color-error); color: #fca5a5; margin-bottom: 2rem;">
        <i class="fas fa-triangle-exclamation" style="margin-right: 0.5rem; color: var(--color-error);"></i> 
        <strong>Transaction Error:</strong> <%= error %>
      </div>
    <% } %>

    <div class="admin-card">
      <h3 style="color: var(--color-white); font-size: 1.15rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
        <i class="fas fa-pen-to-square text-accent"></i> Job Parameters
      </h3>

      <form action="/admin/jobs/edit/<%= job.id %>" method="POST">
        
        <div class="form-group admin-form-group">
          <label for="title">Job Title <span style="color: var(--color-error);">*</span></label>
          <input type="text" id="title" name="title" class="form-control admin-input" value="<%= job.title %>" required>
        </div>

        <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1rem;">
          <div class="form-group admin-form-group">
            <label for="department">Department <span style="color: var(--color-error);">*</span></label>
            <input type="text" id="department" name="department" class="form-control admin-input" value="<%= job.department %>" required>
          </div>
          <div class="form-group admin-form-group">
            <label for="location">Location <span style="color: var(--color-error);">*</span></label>
            <input type="text" id="location" name="location" class="form-control admin-input" value="<%= job.location %>" required>
          </div>
        </div>

        <div class="form-group admin-form-group">
          <label for="type">Job Type <span style="color: var(--color-error);">*</span></label>
          <select id="type" name="type" class="form-control admin-input" required>
            <option value="Full-time" <%= job.type === 'Full-time' ? 'selected' : '' %>>Full-time</option>
            <option value="Part-time" <%= job.type === 'Part-time' ? 'selected' : '' %>>Part-time</option>
            <option value="Contract" <%= job.type === 'Contract' ? 'selected' : '' %>>Contract</option>
            <option value="Internship" <%= job.type === 'Internship' ? 'selected' : '' %>>Internship</option>
          </select>
        </div>

        <div class="form-group admin-form-group">
          <label for="description">Job Summary / Description <span style="color: var(--color-error);">*</span></label>
          <textarea id="description" name="description" class="form-control admin-input" required style="min-height: 120px;"><%= job.description %></textarea>
        </div>

        <div class="form-group admin-form-group" style="margin-bottom: 2rem;">
          <label for="requirements">Core Job Requirements <span style="color: var(--color-error);">*</span></label>
          <textarea id="requirements" name="requirements" class="form-control admin-input" required style="min-height: 150px;"><%= job.requirements %></textarea>
          <span style="font-size: 0.75rem; color: #6B7280; display: block; margin-top: 0.25rem;">Enter each requirement bullet-point on a separate line. The template translates them automatically.</span>
        </div>

        <div style="display: flex; gap: 1rem;">
          <button type="submit" class="btn btn-primary btn-large" style="min-width: 180px;">Save Updates</button>
          <a href="/admin/jobs" class="btn btn-outline-dark btn-large" style="min-width: 120px; text-decoration: none;">Cancel</a>
        </div>
      </form>
    </div>
  </main>

  <!-- FontAwesome for standard icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</body>
</html>
