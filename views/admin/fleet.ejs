<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Global Fleet Assets | Admin Command Center</title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .admin-body { background-color: #f9fafb !important; color: #2d3748 !important; }
    .admin-card { background: #FFFFFF !important; border: 1px solid rgba(0,0,0,0.08) !important; border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
    .admin-card h2 { color: #0a2c2c !important; margin-bottom: 1.5rem; }
    .admin-table th { background-color: #f3f4f6 !important; color: #0a2c2c !important; font-weight: 600; padding: 0.75rem 1rem; border-bottom: 1px solid rgba(0,0,0,0.06); }
    .admin-table td { color: #2d3748 !important; border-bottom: 1px solid rgba(0,0,0,0.05); padding: 0.75rem 1rem; }
  </style>
</head>
<body class="admin-body">

  <nav class="admin-nav">
    <div class="admin-nav-container">
      <a href="/admin" class="logo-link" style="font-size: 1.35rem; display: flex; align-items: center; gap: 0.75rem;">
        <img src="<%= config.brand.logo %>" alt="Logo" class="admin-nav-logo">
        <span><%= config.brand.name %> Admin</span>
      </a>

      <ul class="admin-nav-links">
        <li><a href="/admin" class="admin-nav-link">Dashboard Hub</a></li>
        <li><a href="/admin/compliance" class="admin-nav-link">Compliance Overview</a></li>
        <li><a href="/admin/drivers" class="admin-nav-link">All Drivers</a></li>
        <li><a href="/admin/fleet" class="admin-nav-link active">All Fleet</a></li>
        <li><a href="/admin/settings" class="admin-nav-link">Site Settings</a></li>
        <li><a href="/admin/jobs" class="admin-nav-link">Careers Admin</a></li>
        <li><a href="/admin/testimonials" class="admin-nav-link">Manage Testimonials</a></li>
      </ul>

      <a href="/admin/logout" class="admin-logout">
        <i class="fas fa-power-off"></i> Logout
      </a>
    </div>
  </nav>

  <main class="admin-container">
    
    <div class="admin-header-wrap">
      <div>
        <h1>Global Fleet Assets Oversight</h1>
        <p style="color: #4a5568; margin-top: 0.25rem;">Unified view of all trucks and trailers active across carriers.</p>
      </div>
    </div>

    <div class="admin-card">
      <h2>Registered Trucks</h2>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Carrier</th>
              <th>Unit #</th>
              <th>Make / Model / Year</th>
              <th>VIN</th>
              <th>GPS Tracker</th>
              <th>Status</th>
              <th style="text-align: right;">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (trucks && trucks.length > 0) { %>
              <% trucks.forEach(function(t) { %>
                <tr>
                  <td style="font-weight: 600; color: #0a2c2c;"><%= t.carrier_name %></td>
                  <td style="font-weight: 700;">#<%= t.unit_number %></td>
                  <td><%= t.make %> <%= t.model %> (<%= t.year %>)</td>
                  <td style="font-family: monospace;"><%= t.vin %></td>
                  <td><%= t.gps_tracker || '—' %></td>
                  <td><span class="expiry-badge badge-green"><%= t.status %></span></td>
                  <td style="text-align: right;">
                    <a href="/portal/switch-carrier/<%= t.carrier_id %>" class="portal-btn portal-btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; color: var(--color-accent); border-color: var(--color-accent); text-decoration: none;">
                      Manage Carrier
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" style="text-align: center; color: #718096; padding: 2rem;">No trucks found.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="admin-card">
      <h2>Registered Trailers</h2>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Carrier</th>
              <th>Unit #</th>
              <th>Make / Model / Year</th>
              <th>VIN</th>
              <th>Registration State</th>
              <th>Status</th>
              <th style="text-align: right;">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (trailers && trailers.length > 0) { %>
              <% trailers.forEach(function(tr) { %>
                <tr>
                  <td style="font-weight: 600; color: #0a2c2c;"><%= tr.carrier_name %></td>
                  <td style="font-weight: 700;">#<%= tr.unit_number %></td>
                  <td><%= tr.make %> <%= tr.model %> (<%= tr.year %>)</td>
                  <td style="font-family: monospace;"><%= tr.vin %></td>
                  <td><%= tr.registration_state || '—' %></td>
                  <td><span class="expiry-badge badge-green"><%= tr.status %></span></td>
                  <td style="text-align: right;">
                    <a href="/portal/switch-carrier/<%= tr.carrier_id %>" class="portal-btn portal-btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; color: var(--color-accent); border-color: var(--color-accent); text-decoration: none;">
                      Manage Carrier
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" style="text-align: center; color: #718096; padding: 2rem;">No trailers found.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

</body>
</html>
