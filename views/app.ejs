              8903
            </div>
            <span style="font-size: 0.55rem; color: #6B7280; display: block; margin-top: 0.35rem; text-align: center;">Re-generates in <span id="livePinCountdown" style="font-weight:bold;color:var(--color-accent);">45</span> seconds for checkout protection.</span>
          </div>
        </div>
      `
    };

    // Sequential Auto-cycling Carousel Logic
    const tabKeys = ['telemetry', 'gps', 'behaviour', 'score', 'fraud'];
    let currentTabIndex = 0;
    let autoCycleTimer = null;

    function startAutoCycle() {
      autoCycleTimer = setInterval(() => {
        currentTabIndex = (currentTabIndex + 1) % tabKeys.length;
        const nextKey = tabKeys[currentTabIndex];
        const nextBtn = document.querySelectorAll('.app-tab-btn')[currentTabIndex];
        if (nextBtn) {
          switchAppEmulatorTab(nextKey, nextBtn, true);
        }
      }, 8000); // cycle every 8 seconds
    }

    // Main Tab Switching Function
    function switchAppEmulatorTab(tabKey, buttonEl, isAuto = false) {
      // 1. Remove active class from all buttons
      document.querySelectorAll('.app-tab-btn').forEach(btn => {
        btn.classList.remove('active');
      });

      // 2. Add active class to clicked button
      buttonEl.classList.add('active');

      // 3. Inject new EJS widget markup into emulator screen
      const screenEl = document.getElementById('emulatorScreen');
      if (screenEl && emulatorScreens[tabKey]) {
        screenEl.innerHTML = emulatorScreens[tabKey];
      }

      // 4. If manual click, sync tab index and reset cycle timer
      if (!isAuto) {
        currentTabIndex = tabKeys.indexOf(tabKey);
        clearInterval(autoCycleTimer);
        startAutoCycle();
      }
    }

    // Initialize auto-cycling on window load
    window.addEventListener('DOMContentLoaded', () => {
      startAutoCycle();
    });

    // High-fidelity Live Emulator Simulation State
    const simState = {
      fuelDraw: 6.8,
      reserveLevel: 84,
      savings: 432.80,
      fuelSwipes: 12,
      gpsDistance: 2.4,
      driverScore: 96,
      otpPin: 8903,
      otpSeconds: 45
    };

    // Auto-looping Telemetry Simulator Ticker
    setInterval(() => {
      // 1. Live satellite beacon blinker
      const beacon = document.getElementById('liveBeacon');
      if (beacon) {
        // Toggle neon glow pulse
        const isDim = beacon.style.opacity === '0.6';
        beacon.style.opacity = isDim ? '1' : '0.6';
        beacon.style.transform = isDim ? 'scale(1)' : 'scale(0.97)';
        beacon.style.transition = 'all 0.4s ease';
      }

      // 2. Telemetry panel auto-updates
      const drawEl = document.getElementById('liveFuelDraw');
      if (drawEl) {
        // Fluctuate diesel draw slightly (e.g. between 6.4 and 7.3 Gal/Hr)
        simState.fuelDraw = (6.4 + Math.random() * 0.9).toFixed(1);
        drawEl.innerText = `${simState.fuelDraw} Gal/Hr`;
        
        // Sparkline dynamic columns shifts
        const chartContainer = document.getElementById('liveTelemetryChart');
        if (chartContainer) {
          const bars = chartContainer.children;
          for (let i = 0; i < bars.length - 1; i++) {
            bars[i].style.height = bars[i+1].style.height;
          }
          const newHeight = Math.floor(40 + Math.random() * 55) + '%';
          bars[bars.length - 1].style.height = newHeight;
        }

        // Slow draw-down on reserve levels
        if (Math.random() > 0.85) {
          simState.reserveLevel = Math.max(10, simState.reserveLevel - 1);
        }
        
        const reserveBar = document.getElementById('liveFuelLevelProgress');
        const reserveText = document.getElementById('liveReservePercentageText');
        if (reserveBar) reserveBar.style.width = `${simState.reserveLevel}%`;
        if (reserveText) reserveText.innerText = `${simState.reserveLevel}% Full`;

        // Increment trip savings slightly to simulate active lane optimization
        if (Math.random() > 0.7) {
          simState.savings = parseFloat((simState.savings + (0.05 + Math.random() * 0.15)).toFixed(2));
          const savingsEl = document.getElementById('liveTripSavings');
          if (savingsEl) savingsEl.innerText = `+$${simState.savings.toFixed(2)}`;
        }
      }

      // 3. GPS panel auto-updates
      const gpsDistanceEl = document.getElementById('liveGpsDistance');
      if (gpsDistanceEl) {
        // Fluctuate distance slightly (e.g. Rig closing in: 2.4 -> 2.3 -> 2.2)
        if (Math.random() > 0.8) {
          simState.gpsDistance = parseFloat((simState.gpsDistance - 0.1).toFixed(1));
          if (simState.gpsDistance <= 0.2) simState.gpsDistance = 2.8; // reset loop
          gpsDistanceEl.innerHTML = `<i class="fas fa-location-crosshairs"></i> ${simState.gpsDistance} MI`;
        }
      }

      // 4. Driver Score active ring pulsing
      const scoreEl = document.getElementById('liveDriverScore');
      const scoreStroke = document.getElementById('liveScoreCircleStroke');
      if (scoreEl) {
        // Micro fluctuations (e.g. 96 <-> 97) to show live scoring calibration
        if (Math.random() > 0.9) {
          simState.driverScore = 95 + Math.floor(Math.random() * 3);
          scoreEl.innerText = simState.driverScore;
          if (scoreStroke) {
            scoreStroke.setAttribute('stroke-dasharray', `${simState.driverScore}, 100`);
          }
        }
      }

      // 5. Compliance speed limit bar updates
      const complianceText = document.getElementById('liveComplianceText');
      const complianceBar = document.getElementById('liveComplianceProgress');
      if (complianceText && complianceBar) {
        if (Math.random() > 0.9) {
          const complianceVal = 96 + Math.floor(Math.random() * 5); // 96-100%
          complianceText.innerText = `${complianceVal}%`;
          complianceBar.style.width = `${complianceVal}%`;
        }
      }

      // 6. Fraud Protection One-Time Passcode (OTP) Ticker
      const otpSecondsEl = document.getElementById('livePinCountdown');
      const otpPinEl = document.getElementById('liveVerificationPin');
      const mockupEl = document.getElementById('emulatorDeviceMockup');
      if (otpSecondsEl && otpPinEl) {
        simState.otpSeconds--;
        if (simState.otpSeconds <= 0) {
          // Generate new 4-digit code and reset countdown
          simState.otpSeconds = 45;
          simState.otpPin = Math.floor(1000 + Math.random() * 9000);
          
          // Flash dynamic lock gate visual feedback
          otpPinEl.style.color = 'var(--color-accent)';
          otpPinEl.innerText = simState.otpPin;
          setTimeout(() => { otpPinEl.style.color = '#ffffff'; }, 800);

          // EXPERIMENTAL: Green glow flash on physical outer mobile frame during PIN regeneration
          if (mockupEl) {
            mockupEl.style.boxShadow = '0 0 45px rgba(34, 201, 138, 0.75), 0 25px 60px rgba(0, 0, 0, 0.6)';
            mockupEl.style.outlineColor = 'var(--color-accent)';
            mockupEl.style.transform = 'scale(1.02)';
            setTimeout(() => {
              mockupEl.style.boxShadow = '';
              mockupEl.style.outlineColor = '';
              mockupEl.style.transform = '';
            }, 600);
          }
        } else {
          otpSecondsEl.innerText = simState.otpSeconds;

          // EXPERIMENTAL: Warning orange glow pulse in final 5 seconds before PIN rollover
          if (simState.otpSeconds <= 5 && mockupEl) {
            mockupEl.style.boxShadow = '0 0 30px rgba(245, 166, 35, 0.45), 0 25px 60px rgba(0, 0, 0, 0.6)';
            mockupEl.style.outlineColor = 'var(--color-highlight)';
            setTimeout(() => {
              mockupEl.style.boxShadow = '';
              mockupEl.style.outlineColor = '';
            }, 400);
          }
        }
      }
    }, 1000);
  </script>

