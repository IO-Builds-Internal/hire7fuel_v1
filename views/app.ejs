<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- SEO METADATA -->
  <title>Hire7 Fuel Mobile App | High-Efficiency Telemetry & Real-Time Tracking</title>
  <meta name="description" content="Manage your fleet on the highway. Discover the Hire7 Fuel mobile companion app featuring real-time fuel tracking, low-fuel corridor locator maps, driver scores, and advanced geofencing fraud shields.">
  
  <!-- Style links -->
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  
  <style>
    /* Premium Interactive Page Custom Styles */
    .app-hero-mesh {
      position: relative;
      background: radial-gradient(circle at 80% 20%, rgba(20, 160, 119, 0.03) 0%, transparent 50%),
                  radial-gradient(circle at 10% 80%, rgba(20, 160, 119, 0.02) 0%, transparent 60%);
      padding: 6rem 0;
      overflow: hidden;
      border-bottom: 1px solid rgba(20, 160, 119, 0.1);
    }

    .app-hero-glow {
      position: absolute;
      top: -30%;
      left: 20%;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(34, 201, 138, 0.035) 0%, rgba(13, 79, 79, 0.01) 70%);
      filter: blur(100px);
      z-index: 0;
      pointer-events: none;
    }

    .app-showcase-grid {
      display: grid;
      grid-template-columns: 360px 1fr;
      gap: 4rem;
      align-items: center;
      margin-top: 3.5rem;
    }

    @media (max-width: 992px) {
      .app-showcase-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
        text-align: center;
      }
    }

    /* Interactive Menu Tabs */
    .app-interactive-menu {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .app-tab-btn {
      background: #ffffff;
      border: 1px solid rgba(20, 160, 119, 0.08);
      box-shadow: 0 4px 15px rgba(0,0,0,0.01);
      border-radius: var(--radius-md);
      padding: 1.5rem;
      text-align: left;
      cursor: pointer;
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @media (max-width: 992px) {
      .app-tab-btn {
        text-align: left;
      }
    }

    .app-tab-btn:hover {
      border-color: rgba(20, 160, 119, 0.25);
      background: rgba(20, 160, 119, 0.02);
      transform: translateX(4px);
    }

    .app-tab-btn.active {
      background: rgba(20, 160, 119, 0.04);
      border-color: rgba(20, 160, 119, 0.35);
      box-shadow: 0 10px 30px rgba(20, 160, 119, 0.06);
    }

    .app-tab-btn.active .app-tab-icon {
      background-color: rgba(34, 201, 138, 0.08);
      border-color: var(--color-accent);
      color: var(--color-accent);
      box-shadow: 0 0 10px rgba(34, 201, 138, 0.15);
      transform: scale(1.05);
    }

    .app-tab-icon {
      background-color: rgba(0, 0, 0, 0.02);
      border: 1px solid rgba(0, 0, 0, 0.06);
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-text-off);
      font-size: 1.15rem;
      flex-shrink: 0;
      transition: all 0.3s ease;
    }

    .app-tab-info h3 {
      font-size: 1.1rem;
      color: var(--color-white);
      margin: 0 0 0.35rem 0;
      font-weight: 700;
    }

    .app-tab-info p {
      color: var(--color-text-off);
      font-size: 0.9rem;
      margin: 0;
      line-height: 1.5;
    }

    /* Screen Transition Animation */
    .screen-widget-fade {
      animation: screenFadeIn 0.4s ease-out forwards;
    }

    @keyframes screenFadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Mini Simulated Phone Map Node styling */
    .sim-map-marker {
      position: relative;
      animation: mapPinBounce 1.5s infinite ease-in-out;
    }

    @keyframes mapPinBounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-4px); }
    }

    /* Download Banner Cards */
    .app-download-banner {
      background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 100%);
      border: 1px solid rgba(20, 160, 119, 0.15);
      border-radius: var(--radius-lg);
      padding: 4rem 3rem;
      margin-top: 4rem;
      margin-bottom: 6rem;
      backdrop-filter: blur(20px);
      box-shadow: 0 10px 30px rgba(20, 160, 119, 0.04);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3rem;
    }

    @media (max-width: 992px) {
      .app-download-banner {
        flex-direction: column;
        text-align: center;
        padding: 3rem 2rem;
        gap: 2rem;
      }
    }

    .app-badge-btn {
      background-color: #0a2c2c;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      padding: 0.65rem 1.25rem;
      color: var(--color-white);
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.25s ease;
      cursor: pointer;
    }

    .app-badge-btn:hover {
      border-color: var(--color-accent);
      background-color: var(--color-accent);
      color: #ffffff;
      transform: translateY(-1px);
    }
  </style>
  
  <%- include('partials/header') %>

  <!-- Premium Header & App Hero section -->
  <section class="app-hero-mesh">
    <div class="app-glow-overlay"></div>
    <div class="app-hero-glow"></div>
    
    <div class="container" style="position: relative; z-index: 2;">
      <div class="section-title-wrap" style="margin-bottom: 2rem;">
        <span style="font-size: 0.85rem; color: var(--color-accent); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 0.5rem;">
          <i class="fas fa-mobile-screen-button" style="margin-right: 0.25rem;"></i> Dynamic Mobile Operations
        </span>
        <h1 style="font-size: 2.75rem; font-weight: 800; color: var(--color-white); margin-top: 0; line-height: 1.25;">
          High-Efficiency Telemetry <br>
          <span class="text-accent">Right In Your Driver's Pocket</span>
        </h1>
        <p class="max-w-md text-center" style="color: var(--color-muted); font-size: 1.05rem;">
          Empower drivers on the long-haul corridor while maintaining complete, state-of-the-art security, geofence logs, and dispatch authorization in real-time.
        </p>
      </div>

      <!-- Master Interactive Showcase Grid -->
      <div class="app-showcase-grid">
        
        <!-- Left Side: Interactive Glass Phone Emulator -->
        <div class="mobile-device-mockup" id="emulatorDeviceMockup" style="margin-top: 0; transition: all 0.4s ease;">
          <div class="mobile-device-screen" id="emulatorScreen">
            <!-- Initial Widget Load (Fuel Usage telemetry) -->
            <div class="screen-widget-fade" style="display: flex; flex-direction: column; gap: 1.25rem; height: 100%;">
              <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 0.5rem;">
                <span style="font-weight: 800; font-size: 0.85rem; color: #ffffff; display: flex; align-items: center; gap: 0.35rem;"><i class="fas fa-gas-pump" style="color: var(--color-accent);"></i> HIRE7 MOBILE</span>
                <span style="font-size: 0.65rem; background-color: rgba(34,201,138,0.1); border: 1px solid rgba(20, 160, 119, 0.15); color: var(--color-accent); padding: 0.15rem 0.45rem; border-radius: 10px; font-weight: 700;" id="liveBeacon"><i class="fas fa-satellite"></i> LIVE</span>
              </div>

              <!-- Main telemetry screen stats -->
              <div class="mobile-widget">
                <div class="mobile-widget-header">
                  <span>Fuel Telemetry</span>
                  <span style="color: var(--color-accent); font-weight: bold;"><i class="fas fa-chart-simple"></i> EFFICIENT</span>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem;">
                  <div>
                    <span style="font-size: 0.65rem; color: #a3c2c2; display: block;">FUEL DRAW-DOWN</span>
                    <strong style="font-size: 1.15rem; color: #ffffff;" id="liveFuelDraw">6.8 Gal/Hr</strong>
                  </div>
                  
                  <!-- Dynamic sparkline bar chart -->
                  <div style="display: flex; gap: 4px; align-items: flex-end; height: 28px; justify-content: center;" id="liveTelemetryChart">
                    <div style="width: 5px; height: 60%; background: rgba(34, 201, 138, 0.3); border-radius: 3px; transition: height 0.4s ease;"></div>
                    <div style="width: 5px; height: 75%; background: rgba(34, 201, 138, 0.4); border-radius: 3px; transition: height 0.4s ease;"></div>
                    <div style="width: 5px; height: 68%; background: rgba(34, 201, 138, 0.5); border-radius: 3px; transition: height 0.4s ease;"></div>
                    <div style="width: 5px; height: 82%; background: rgba(34, 201, 138, 0.7); border-radius: 3px; transition: height 0.4s ease;"></div>
                    <div style="width: 5px; height: 70%; background: var(--color-accent); border-radius: 3px; transition: height 0.4s ease; box-shadow: 0 0 6px var(--color-accent);"></div>
                  </div>
                </div>
                
                <!-- Dynamic reserve level progress bar -->
                <div style="margin-top: 0.85rem;">
                  <div style="display: flex; justify-content: space-between; font-size: 0.6rem; color: #a3c2c2; margin-bottom: 0.25rem;">
                    <span>RESERVE LEVEL</span>
                    <span id="liveReservePercentageText">84% Full</span>
                  </div>
                  <div style="width: 100%; height: 5px; background: rgba(255,255,255,0.06); border-radius: 10px; overflow: hidden; border: 1px solid rgba(255,255,255,0.03);">
                    <div id="liveFuelLevelProgress" style="width: 84%; height: 100%; background: linear-gradient(90deg, #1a6b6b 0%, var(--color-accent) 100%); box-shadow: 0 0 6px var(--color-accent); border-radius: 10px; transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);"></div>
                  </div>
                </div>
              </div>

              <div class="mobile-widget">
                <div class="mobile-widget-header">
                  <span>Trip Statistics</span>
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.75rem; margin-top: 0.25rem;">
                  <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.25rem;">
                    <span style="color: #a3c2c2;">Active Fuel Swipes</span>
                    <strong style="color: #ffffff;" id="liveFuelSwipes">12 Fills</strong>
                  </div>
                  <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.25rem;">
                    <span style="color: #a3c2c2;">Average Swipe Cost</span>
                    <strong style="color: #ffffff; font-weight: 700;">$385.20</strong>
                  </div>
                  <div style="display: flex; justify-content: space-between;">
                    <span style="color: #a3c2c2;">Total Trip Savings</span>
                    <strong style="color: var(--color-accent); font-weight: 700;" id="liveTripSavings">+$432.80</strong>
                  </div>
                </div>
              </div>

              <div class="mobile-widget" style="background-color: rgba(34, 201, 138, 0.03); border-color: rgba(34, 201, 138, 0.25);">
                <div style="display: flex; gap: 0.65rem; align-items: center;">
                  <i class="fas fa-circle-check" style="color: var(--color-accent); font-size: 0.95rem;"></i>
                  <div style="text-align: left;">
                    <strong style="font-size: 0.75rem; color: #ffffff; display: block;">Flow Auto-Sync Connected</strong>
                    <span style="font-size: 0.65rem; color: #a3c2c2;">Vehicle CAN-bus syncing perfectly.</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side: Beautiful Interactive Menu Tabs -->
        <div class="app-interactive-menu">
          
          <!-- Tab 1: Fuel Usage Telemetry -->
          <div class="app-tab-btn active" onclick="switchAppEmulatorTab('telemetry', this)">
            <div class="app-tab-icon"><i class="fas fa-gauge-high"></i></div>
            <div class="app-tab-info">
              <h3>High-Efficiency Fuel Tracking</h3>
              <p>Eliminate manual operational logs. Connect directly to vehicle CAN-bus links to dynamically record fuel usage rate, tank draw-downs, filling coordinates, and exact gallons purchased automatically.</p>
            </div>
          </div>

          <!-- Tab 2: Low Fuel GPS Locator -->
          <div class="app-tab-btn" onclick="switchAppEmulatorTab('gps', this)">
            <div class="app-tab-icon" style="color: var(--color-highlight); border-color: rgba(245,166,35,0.25);"><i class="fas fa-compass"></i></div>
            <div class="app-tab-info">
              <h3>Low Fuel GPS Corridor Locator</h3>
              <p>Maximize margins on every gallon. Cross-references reserves to automatically guide drivers to adjacent pre-negotiated wholesale Pilot, Flying J, and Cost-Plus network stop stations, entirely dodging high retail pump markups.</p>
            </div>
          </div>

          <!-- Tab 3: Driver Fuel Behaviour -->
          <div class="app-tab-btn" onclick="switchAppEmulatorTab('behaviour', this)">
            <div class="app-tab-icon" style="color: var(--color-seafoam); border-color: rgba(58,191,160,0.25);"><i class="fas fa-road"></i></div>
            <div class="app-tab-info">
              <h3>Driver Fuel Behavior Insights</h3>
              <p>Monitor harsh braking, aggressive speed spikes, and excess diesel idling logs dynamically. Provide drivers real-time dashboard notifications on wasteful habits to optimize average lane mileage immediately.</p>
            </div>
          </div>

          <!-- Tab 4: Driver Score -->
          <div class="app-tab-btn" onclick="switchAppEmulatorTab('score', this)">
            <div class="app-tab-icon" style="color: #60a5fa; border-color: rgba(96,165,250,0.25);"><i class="fas fa-trophy"></i></div>
            <div class="app-tab-info">
              <h3>Gamified Driver Performance Scores</h3>
              <p>Incentivize efficiency across your logistics network. Give drivers clean daily performance scores (1-100) and gamify operations to reward high-scoring drivers through customized performance bonuses.</p>
            </div>
          </div>

          <!-- Tab 5: Fraud Protections -->
          <div class="app-tab-btn" onclick="switchAppEmulatorTab('fraud', this)">
            <div class="app-tab-icon"><i class="fas fa-user-shield"></i></div>
            <div class="app-tab-info">
              <h3>Multi-Layered Mobile Fraud Protection</h3>
              <p>Lock down cash lines instantly. Features double-factor card unlock codes, immediate driver coordinates mapping checks, and instant dynamic geofence shields. If anomalies are caught, cards freeze instantly.</p>
            </div>
          </div>

        </div>

      </div>

      <!-- App Download Call to Action Frosted Box -->
      <div class="app-download-banner">
        <div style="max-width: 600px; text-align: left;">
          <h2 style="font-size: 1.8rem; font-weight: 700; color: var(--color-white); margin-top: 0; margin-bottom: 0.5rem;">
            Ready to Connect Your Logistics Fleet?
          </h2>
          <p style="color: var(--color-text-off); margin: 0; line-height: 1.5; font-size: 0.95rem;">
            Empower your drivers, slash manual bookkeeping math, and lock down secure pump expenditures. Download the companion app on driver smartphones to initialize wholesale cost-plus pricing links dynamically.
          </p>
        </div>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
          <a href="<%= config.app.appstore || '#' %>" target="_blank" class="app-badge-btn" id="appAppleDownloadBtn">
            <i class="fab fa-apple" style="font-size: 1.4rem; color: var(--color-accent);"></i>
            <div style="text-align: left;">
              <span style="font-size: 0.65rem; color: var(--color-text-off); display: block; font-weight: 500; text-transform: uppercase;">Download on the</span>
              <strong style="font-size: 0.9rem; font-weight: 700;">App Store</strong>
            </div>
          </a>
          
          <a href="<%= config.app.playstore || '#' %>" target="_blank" class="app-badge-btn" id="appGoogleDownloadBtn">
            <i class="fab fa-google-play" style="font-size: 1.25rem; color: var(--color-highlight);"></i>
            <div style="text-align: left;">
              <span style="font-size: 0.65rem; color: var(--color-text-off); display: block; font-weight: 500; text-transform: uppercase;">Get it on</span>
              <strong style="font-size: 0.9rem; font-weight: 700;">Google Play</strong>
            </div>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Dynamic Footer Bar Include -->
  <%- include('partials/footer') %>

  <!-- Interactive JavaScript Tab Switcher Logic -->
  <script>
    // Dictionary storing high-fidelity HTML screens to dynamically inject
    const emulatorScreens = {
