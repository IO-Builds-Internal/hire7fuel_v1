<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- SEO METADATA -->
  <title>Commercial Fuel Card Programs & Fleet Savings | Hire7 Fuel</title>
  <meta name="description" content="Discover what the Hire7 Fuel Card can do for your business. Choose between Diesel, Cash, and Maintenance programs. Access 24/7 web management, geofencing, and massive truck stop savings.">
  
  <!-- Open Graph Protocol (OG) -->
  <meta property="og:title" content="Commercial Fuel Card Programs & Fleet Savings | Hire7 Fuel">
  <meta property="og:description" content="Gain full control of your fleet expenses. Select from custom fuel and repair cards. View 3-step onboarding flow and FAQs.">
  <meta property="og:url" content="https://hire7fuel.com/fuelcard">
  <meta property="og:type" content="website">
  <meta property="og:image" content="/assets/logo.png">

  <!-- Style links -->
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  
  <style>
    /* ============================================================================
       HIRE7 FUEL - FUEL CARD PAGE REDESIGN MASTER STYLES
       ============================================================================ */
    
    /* 1. Interactive Hero Grid */
    .fc-hero-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4rem;
      align-items: center;
      text-align: left;
    }

    /* 3D Interactive Card Stack */
    .card-stack-viewport {
      height: 380px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      perspective: 1200px;
    }

    .card-stack-wrapper {
      width: 340px;
      height: 215px;
      position: relative;
      transform-style: preserve-3d;
    }

    .stacked-card {
      width: 100%;
      height: 100%;
      position: absolute;
      border-radius: 14px;
      padding: 1.5rem;
      color: var(--color-white);
      box-shadow: 0 15px 35px rgba(0,0,0,0.5);
      transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
      transform-style: preserve-3d;
      backface-visibility: hidden;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      border: 1px solid rgba(255,255,255,0.1);
    }

    /* Diesel Card Styling */
    .sc-diesel {
      background: linear-gradient(135deg, #0d3b3b 0%, #061515 100%);
      box-shadow: 0 10px 30px rgba(34, 201, 138, 0.15), 0 15px 40px rgba(0,0,0,0.4);
      border-color: rgba(34, 201, 138, 0.25);
      transform: translate3d(0, 0, 0) rotateX(5deg) rotateY(-10deg);
      z-index: 3;
    }

    /* Cash Card Styling */
    .sc-cash {
      background: linear-gradient(135deg, #093c2b 0%, #03140e 100%);
      box-shadow: 0 10px 30px rgba(16, 185, 129, 0.15), 0 15px 40px rgba(0,0,0,0.4);
      border-color: rgba(16, 185, 129, 0.25);
      transform: translate3d(30px, 20px, -40px) rotateX(5deg) rotateY(-10deg);
      z-index: 2;
      opacity: 0.85;
    }

    /* Maintenance Card Styling */
    .sc-maintenance {
      background: linear-gradient(135deg, #442a0b 0%, #170d02 100%);
      box-shadow: 0 10px 30px rgba(245, 166, 35, 0.15), 0 15px 40px rgba(0,0,0,0.4);
      border-color: rgba(245, 166, 35, 0.25);
      transform: translate3d(60px, 40px, -80px) rotateX(5deg) rotateY(-10deg);
      z-index: 1;
      opacity: 0.7;
    }

    /* Stack Hover Effects */
    .card-stack-wrapper:hover .sc-diesel {
      transform: translate3d(-10px, -20px, 20px) rotateX(0deg) rotateY(0deg) scale(1.02);
    }
    .card-stack-wrapper:hover .sc-cash {
      transform: translate3d(15px, 0px, 0px) rotateX(0deg) rotateY(0deg) scale(0.98);
      opacity: 0.95;
    }
    .card-stack-wrapper:hover .sc-maintenance {
      transform: translate3d(40px, 20px, -20px) rotateX(0deg) rotateY(0deg) scale(0.94);
      opacity: 0.85;
    }

    /* Single Card Interactive focus state */
    .stacked-card:hover {
      z-index: 10 !important;
      opacity: 1 !important;
      transform: translate3d(15px, -15px, 50px) rotateX(0deg) rotateY(0deg) scale(1.08) !important;
      box-shadow: 0 25px 55px rgba(0,0,0,0.6), 0 0 30px rgba(255,255,255,0.15) !important;
      border-color: rgba(255,255,255,0.4) !important;
    }

    /* Inner card visuals */
    .stacked-card-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .stacked-card-brand {
      font-weight: 800;
      font-size: 1.1rem;
      letter-spacing: 1px;
    }
    .sc-diesel .stacked-card-brand { color: var(--color-accent); }
    .sc-cash .stacked-card-brand { color: #10b981; }
    .sc-maintenance .stacked-card-brand { color: #f5a623; }

    .stacked-card-chip {
      width: 38px;
      height: 28px;
      background: linear-gradient(135deg, #ffd700 0%, #b8860b 100%);
      border-radius: 4px;
      box-shadow: inset 0 1px 3px rgba(255,255,255,0.4);
    }
    .stacked-card-num {
      font-family: monospace;
      font-size: 1.1rem;
      letter-spacing: 0.06em;
      margin: 1rem 0 0.5rem 0;
      text-shadow: 0 2px 4px rgba(0,0,0,0.5);
      white-space: nowrap;
    }
    .stacked-card-bottom {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      font-size: 0.75rem;
    }
    .stacked-card-name {
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 0.5px;
    }
    .stacked-card-badge {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.15rem 0.5rem;
      border-radius: 20px;
      font-weight: 800;
      font-size: 0.65rem;
    }
    .sc-diesel .stacked-card-badge { background-color: rgba(34, 201, 138, 0.15); color: var(--color-accent); }
    .sc-cash .stacked-card-badge { background-color: rgba(16, 185, 129, 0.15); color: #10b981; }
    .sc-maintenance .stacked-card-badge { background-color: rgba(245, 166, 35, 0.15); color: #f5a623; }

    /* 2. Side-by-side Program Grid */
    .programs-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2.25rem;
      margin-top: 3.5rem;
    }

    .program-card {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0.005) 100%);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: var(--radius-md);
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
      position: relative;
      overflow: hidden;
      height: 100%;
    }

    .program-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: transparent;
      transition: all 0.4s ease;
    }

    /* Program specific themes */
    .pc-diesel::before { background: var(--color-accent); }
    .pc-diesel:hover {
      border-color: rgba(34, 201, 138, 0.25);
      box-shadow: 0 20px 40px rgba(34, 201, 138, 0.08), 0 10px 25px rgba(0,0,0,0.3);
      transform: translateY(-8px);
    }
    
    .pc-cash::before { background: #10b981; }
    .pc-cash:hover {
      border-color: rgba(16, 185, 129, 0.25);
      box-shadow: 0 20px 40px rgba(16, 185, 129, 0.08), 0 10px 25px rgba(0,0,0,0.3);
      transform: translateY(-8px);
    }

    .pc-maintenance::before { background: #f5a623; }
    .pc-maintenance:hover {
      border-color: rgba(245, 166, 35, 0.25);
      box-shadow: 0 20px 40px rgba(245, 166, 35, 0.08), 0 10px 25px rgba(0,0,0,0.3);
      transform: translateY(-8px);
    }

    .program-card-header {
      margin-bottom: 2rem;
    }
    .program-icon-badge {
      width: 54px;
      height: 54px;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.35rem;
      margin-bottom: 1.5rem;
    }
    .pc-diesel .program-icon-badge { background-color: rgba(34, 201, 138, 0.08); color: var(--color-accent); border: 1px solid rgba(34, 201, 138, 0.15); }
    .pc-cash .program-icon-badge { background-color: rgba(16, 185, 129, 0.08); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.15); }
    .pc-maintenance .program-icon-badge { background-color: rgba(245, 166, 35, 0.08); color: #f5a623; border: 1px solid rgba(245, 166, 35, 0.15); }

    .program-title {
      font-size: 1.45rem;
      font-weight: 700;
      color: var(--color-white);
      margin-bottom: 0.5rem;
    }
    .program-subtitle {
      font-size: 0.9rem;
      color: #a3c2c2;
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 0.5px;
      margin-bottom: 1rem;
      display: block;
    }
    .program-desc {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.75);
      line-height: 1.5;
    }

    .program-features-list {
      list-style: none;
      margin: 2rem 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      border-top: 1px solid rgba(255,255,255,0.05);
      padding-top: 2rem;
    }
    .program-features-list li {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      font-size: 0.95rem;
      color: rgba(255,255,255,0.85);
    }
    .program-features-list li i {
      margin-top: 0.2rem;
      font-size: 0.95rem;
    }
    .pc-diesel .program-features-list li i { color: var(--color-accent); }
    .pc-cash .program-features-list li i { color: #10b981; }
    .pc-maintenance .program-features-list li i { color: #f5a623; }

    /* 3. Browser Mockup Frame styling */
    .browser-mockup {
      border: 1px solid rgba(34, 201, 138, 0.2);
      border-radius: var(--radius-md);
      overflow: hidden;
      box-shadow: var(--shadow-premium), 0 0 35px rgba(34, 201, 138, 0.05);
      background-color: #060f0f;
    }

    .browser-header {
      background-color: #0a1717;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      padding: 0.75rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .browser-dots {
      display: flex;
      gap: 6px;
    }
    .browser-dot {
      width: 11px;
      height: 11px;
      border-radius: 50%;
    }
    .bd-red { background-color: #ff5f56; }
    .bd-yellow { background-color: #ffbd2e; }
    .bd-green { background-color: #27c93f; }

    .browser-address {
      flex-grow: 1;
      max-width: 500px;
      background-color: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: var(--radius-sm);
      padding: 0.25rem 1rem;
      font-family: monospace;
      font-size: 0.8rem;
      color: #a3c2c2;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      margin: 0 auto;
    }

    /* 3.5 Card Presentation Side-by-Side & Premium Interactive Feature Cards */
    .card-presentation {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 5rem;
      align-items: center;
      margin-top: 3.5rem;
    }
    @media (max-width: 1024px) {
      .card-presentation {
        grid-template-columns: 1fr;
        gap: 3.5rem;
      }
    }

    .feature-cards-stack {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-top: 2rem;
    }

    .feature-glass-card {
      background: rgba(255, 255, 255, 0.015);
      border: 1px solid rgba(255, 255, 255, 0.03);
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      display: flex;
      gap: 1.25rem;
      align-items: center;
      transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
      position: relative;
      overflow: hidden;
      box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.01);
    }

    .feature-glass-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: transparent;
      transition: all 0.4s ease;
    }

    .feature-card-icon {
      width: 48px;
      height: 48px;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.15rem;
      flex-shrink: 0;
      transition: all 0.4s ease;
    }

    /* Interactive state mappings by features */
    .fg-lock .feature-card-icon {
      background-color: rgba(34, 201, 138, 0.06);
      color: var(--color-accent);
      border: 1px solid rgba(34, 201, 138, 0.15);
      box-shadow: 0 0 15px rgba(34, 201, 138, 0.05);
    }
    .fg-lock::before { background: var(--color-accent); }
    .fg-lock:hover {
      background: rgba(34, 201, 138, 0.03);
      border-color: rgba(34, 201, 138, 0.25);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3), 0 0 20px rgba(34, 201, 138, 0.05);
      transform: translateX(8px);
    }

    .fg-gears .feature-card-icon {
      background-color: rgba(16, 185, 129, 0.06);
      color: #10b981;
      border: 1px solid rgba(16, 185, 129, 0.15);
      box-shadow: 0 0 15px rgba(16, 185, 129, 0.05);
    }
    .fg-gears::before { background: #10b981; }
    .fg-gears:hover {
      background: rgba(16, 185, 129, 0.03);
      border-color: rgba(16, 185, 129, 0.25);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3), 0 0 20px rgba(16, 185, 129, 0.05);
      transform: translateX(8px);
    }

    .fg-receipt .feature-card-icon {
      background-color: rgba(245, 166, 35, 0.06);
      color: #f5a623;
      border: 1px solid rgba(245, 166, 35, 0.15);
      box-shadow: 0 0 15px rgba(245, 166, 35, 0.05);
    }
    .fg-receipt::before { background: #f5a623; }
    .fg-receipt:hover {
      background: rgba(245, 166, 35, 0.03);
      border-color: rgba(245, 166, 35, 0.25);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3), 0 0 20px rgba(245, 166, 35, 0.05);
      transform: translateX(8px);
    }

    .fg-chart .feature-card-icon {
      background-color: rgba(59, 130, 246, 0.06);
      color: #3b82f6;
      border: 1px solid rgba(59, 130, 246, 0.15);
      box-shadow: 0 0 15px rgba(59, 130, 246, 0.05);
    }
    .fg-chart::before { background: #3b82f6; }
    .fg-chart:hover {
      background: rgba(59, 130, 246, 0.03);
      border-color: rgba(59, 130, 246, 0.25);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3), 0 0 20px rgba(59, 130, 246, 0.05);
      transform: translateX(8px);
    }

    .feature-card-content h4 {
      font-size: 1.1rem;
      color: var(--color-white);
      margin-bottom: 0.25rem;
      font-weight: 700;
    }
    .feature-card-content p {
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.45;
    }

    /* 4. Responsive media queries */
    @media (max-width: 992px) {
      .fc-hero-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
        text-align: center;
      }
      .card-stack-viewport {
        height: 320px;
      }
      .programs-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    /* 5. Custom Redesigned IFTA Compliance Splits Section */
    .form-split-layout {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4.5rem;
      align-items: center;
    }
    @media (max-width: 992px) {
      .form-split-layout {
        grid-template-columns: 1fr;
        gap: 3rem;
      }
    }

    /* Badge audit shield status indicator */
    .badge-audit-shield {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(34, 201, 138, 0.08);
      border: 1px solid rgba(34, 201, 138, 0.2);
      color: var(--color-accent);
      padding: 0.35rem 0.75rem;
      border-radius: var(--radius-sm);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      box-shadow: 0 0 15px rgba(34, 201, 138, 0.05);
      animation: floatIndicator 2s infinite ease-in-out;
    }

    /* Redesigned Floating State Cards */
    .ifta-state-card {
      background: rgba(255, 255, 255, 0.015) !important;
      border: 1px solid rgba(255, 255, 255, 0.03) !important;
      border-radius: 12px !important;
      padding: 1.25rem !important;
      margin-bottom: 1.25rem;
      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
      box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.02) !important;
    }

    .ifta-state-card:hover {
      background: rgba(34, 201, 138, 0.03) !important;
      border-color: rgba(34, 201, 138, 0.25) !important;
      transform: translateY(-3px) scale(1.01);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3), inset 0 1px 1px rgba(255, 255, 255, 0.05) !important;
    }

    /* High-tech state badges */
    .state-code-badge {
      display: inline-block;
      font-weight: 800;
      font-size: 0.75rem;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      letter-spacing: 0.05em;
    }

    .badge-on { background: rgba(34, 201, 138, 0.1); color: var(--color-accent); border: 1px solid rgba(34, 201, 138, 0.2); }
    .badge-mi { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
    .badge-ny { background: rgba(245, 166, 35, 0.1); color: #f5a623; border: 1px solid rgba(245, 166, 35, 0.2); }
    .badge-pa { background: rgba(59, 130, 246, 0.1); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.2); }

    /* Custom high-contrast layout header */
    .state-name-text {
      font-weight: 600;
      color: #e2f0f0;
      font-size: 0.95rem;
      margin-left: 0.5rem;
    }

    /* Deep track channels for progress elements */
    .state-bar-track {
      height: 8px !important;
      background: rgba(0, 0, 0, 0.3) !important;
      border-radius: 10px !important;
      border: 1px solid rgba(255, 255, 255, 0.03) !important;
      overflow: hidden;
      margin-top: 0.5rem;
    }

    /* Luxurious custom state-specific gradients and glowing fills */
    #ifta-on-bar {
      background: linear-gradient(90deg, rgba(34, 201, 138, 0.3) 0%, var(--color-accent) 100%) !important;
      box-shadow: 0 0 12px rgba(34, 201, 138, 0.5) !important;
    }
    #ifta-mi-bar {
      background: linear-gradient(90deg, rgba(16, 185, 129, 0.3) 0%, #10b981 100%) !important;
      box-shadow: 0 0 12px rgba(16, 185, 129, 0.5) !important;
    }
    #ifta-ny-bar {
      background: linear-gradient(90deg, rgba(245, 166, 35, 0.3) 0%, #f5a623 100%) !important;
      box-shadow: 0 0 12px rgba(245, 166, 35, 0.5) !important;
    }
    #ifta-pa-bar {
      background: linear-gradient(90deg, rgba(59, 130, 246, 0.3) 0%, #3b82f6 100%) !important;
      box-shadow: 0 0 12px rgba(59, 130, 246, 0.5) !important;
    }

    /* Stylized bullet pill tags */
    .bullet-pills-list {
      list-style: none;
      padding: 0;
      margin: 1.5rem 0 2rem 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .bullet-pill-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: rgba(255, 255, 255, 0.015);
      border: 1px solid rgba(255, 255, 255, 0.03);
      padding: 0.75rem 1rem;
      border-radius: 8px;
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.85);
      transition: all 0.3s ease;
    }
    .bullet-pill-item:hover {
      background: rgba(34, 201, 138, 0.02);
      border-color: rgba(34, 201, 138, 0.15);
      transform: translateX(5px);
    }
    .bullet-pill-item i {
      color: var(--color-accent);
      font-size: 1rem;
    }

    /* ============================================================================
       HIRE7 FUEL - PREMIUM INTERACTIVE FAQ ACCORDION STYLES
       ============================================================================ */
    .faq-container {
      max-width: 850px;
      margin: 3rem auto 0 auto;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .faq-item {
      background: rgba(16, 46, 46, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: var(--radius-md);
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
      position: relative;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    /* Left colorful gradient accent bar visible on active */
    .faq-item::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: linear-gradient(180deg, var(--color-accent) 0%, var(--color-seafoam) 100%);
      transform: scaleY(0);
      transform-origin: center;
      transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
      border-radius: 4px 0 0 4px;
      z-index: 3;
    }

    .faq-item.active::before {
      transform: scaleY(1);
    }

    /* Ultimate Button Styling Reset to clear Mac/Safari system borders */
    .faq-trigger {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      text-align: left;
      padding: 1.5rem 2rem;
      background: transparent !important;
      border: none !important;
      outline: none !important;
      box-shadow: none !important;
      color: var(--color-white);
      font-size: 1.15rem;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
