                  <span class="state-code-badge badge-pa">PA</span>
                  <span class="state-name-text">Pennsylvania</span>
                </div>
                <span class="state-gallons" style="font-family: monospace; font-size: 1.1rem; font-weight: 700; color: var(--color-white); letter-spacing: 0.5px;">
                  <span id="ifta-pa-val">1,290</span> <span style="font-size: 0.75rem; color: var(--color-muted); font-weight: 600;">Gal</span>
                </span>
              </div>
              <div class="state-bar-track">
                <div class="state-bar-fill" id="ifta-pa-bar" data-pct="35" style="width: 35%;"></div>
              </div>
            </div>
          </div>

          <div style="margin-top: 1.5rem; display: flex; justify-content: flex-end; align-items: center; gap: 0.5rem; color: var(--color-muted); font-size: 0.75rem;">
            <i class="fas fa-circle-info" style="color: var(--color-accent);"></i>
            <span>Auto-sync with QuickBooks & TMS enabled</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Accordion Section -->
  <section class="section section-light-teal" id="faqs">
    <div class="container">
      <div class="section-title-wrap">
        <h2>Frequently Asked Questions</h2>
        <p class="max-w-md text-center" style="color: var(--color-muted);">Find answers to common onboarding, limit control, and network compatibility questions.</p>
      </div>

      <div class="faq-container">
        <!-- FAQ 1 -->
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span>Where is the Hire7 Fuel Card accepted?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-content">
            <p>Our fleet cards are accepted at over 15,000 truck terminals, commercial travel plazas, and service facilities across Canada and the United States, including all major networks like Shell, TA, Love's, Petro, and Flying J.</p>
          </div>
        </div>

        <!-- FAQ 2 -->
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span>How fast can I obtain credit approval?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-content">
            <p>We pride ourselves on offering rapid onboarding. Once you submit our online application with basic company details, our specialized credit team performs underwriters' checks within 24 business hours to establish credit limits.</p>
          </div>
        </div>

        <!-- FAQ 3 -->
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span>Can I lock cards down to diesel fuel purchases only?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-content">
            <p>Yes. You possess complete granular control. Through the management dashboard, you can restrict cards to allow only "Diesel Fuel Only" or "Fuel + DEF," blocking any driver shop or snack-store transactions instantly.</p>
          </div>
        </div>

        <!-- FAQ 4 -->
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span>Are there any hidden monthly administration fees?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-content">
            <p>Absolutely not. We believe in 100% price transparency. There are no annual contract charges, dynamic account upkeep fees, or surprise data reporting levies. Our custom program cost details are laid out beforehand.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Apply CTA Banner Section -->
  <section class="section" id="apply-banner" style="padding: 4rem 0;">
    <div class="container">
      <div class="gradient-banner">
        <h2>Start Maximizing Your Fleet Revenue Today</h2>
        <p>Join thousands of trucking owners who rely on Hire7 Fuel to reduce fuel costs, prevent driver card abuse, and automate administrative bookkeeping.</p>
        <a href="/apply" class="btn btn-primary btn-large">Apply for Fuel Card</a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <!-- Page specific smooth scroll navigation helper -->
  <script>
    function scrollToProgram(elementId) {
      const element = document.getElementById(elementId);
      if (element) {
        element.scrollIntoView({ behavior: 'smooth', block: 'center' });
        
        // Highlight active card border dynamically as flash reminder
        element.style.borderColor = 'rgba(255,255,255,0.4)';
        setTimeout(() => {
          element.style.borderColor = '';
        }, 1500);
      }
    }
  </script>
</body>
</html>
