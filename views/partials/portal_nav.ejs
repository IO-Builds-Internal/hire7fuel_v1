<div class="portal-sidebar">
  <div class="portal-sidebar-header">
    <a href="/portal/compliance" class="logo-link" style="font-size: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: var(--color-white);">
      <img src="<%= config.brand.logo %>" alt="Logo" class="admin-nav-logo" style="height: 35px; width: auto;">
      <span style="font-weight: 700;"><%= config.brand.name %></span>
    </a>
    <div style="font-size: 0.75rem; color: var(--color-accent); font-weight: 600; text-transform: uppercase; margin-top: 0.25rem; letter-spacing: 0.05em;">Carrier Portal</div>
  </div>

  <ul class="portal-sidebar-menu">
    <li>
      <a href="/portal/compliance" class="portal-menu-link <%= page === 'portal-compliance' ? 'active' : '' %>">
        <i class="fas fa-chart-line"></i>
        <span>Compliance Overview</span>
      </a>
    </li>
    <li>
      <a href="/portal/profile" class="portal-menu-link <%= page === 'portal-profile' ? 'active' : '' %>">
        <i class="fas fa-building"></i>
        <span>My Profile</span>
      </a>
    </li>
    <li>
      <a href="/portal/compliance/ifta" class="portal-menu-link <%= page === 'portal-ifta' ? 'active' : '' %>">
        <i class="fas fa-gas-pump"></i>
        <span>IFTA Filing</span>
      </a>
    </li>
    <li>
      <a href="/portal/compliance/kyu" class="portal-menu-link <%= page === 'portal-kyu' ? 'active' : '' %>">
        <i class="fas fa-road"></i>
        <span>KYU Filing</span>
      </a>
    </li>
    <li>
      <a href="/portal/compliance/nyhut" class="portal-menu-link <%= page === 'portal-nyhut' ? 'active' : '' %>">
        <i class="fas fa-truck-moving"></i>
        <span>NY-HUT Filing</span>
      </a>
    </li>
    <li>
      <a href="/portal/drivers" class="portal-menu-link <%= page === 'portal-drivers' ? 'active' : '' %>">
        <i class="fas fa-users"></i>
        <span>Drivers Fleet</span>
      </a>
    </li>
    <li>
      <a href="/portal/trucks" class="portal-menu-link <%= page === 'portal-trucks' ? 'active' : '' %>">
        <i class="fas fa-truck"></i>
        <span>Trucks</span>
      </a>
    </li>
    <li>
      <a href="/portal/trailers" class="portal-menu-link <%= page === 'portal-trailers' ? 'active' : '' %>">
        <i class="fas fa-trailer"></i>
        <span>Trailers</span>
      </a>
    </li>
    <li>
      <a href="/portal/transponders" class="portal-menu-link <%= page === 'portal-transponders' ? 'active' : '' %>">
        <i class="fas fa-microchip"></i>
        <span>Transponders</span>
      </a>
    </li>
    <li>
      <a href="/portal/tasks" class="portal-menu-link <%= page === 'portal-tasks' ? 'active' : '' %>">
        <i class="fas fa-tasks"></i>
        <span>Compliance Tasks</span>
      </a>
    </li>
    <li>
      <a href="/portal/billing" class="portal-menu-link <%= page === 'portal-billing' ? 'active' : '' %>">
        <i class="fas fa-file-invoice-dollar"></i>
        <span>Billing & Invoices</span>
      </a>
    </li>
    <li>
      <a href="/portal/documents" class="portal-menu-link <%= page === 'portal-documents' ? 'active' : '' %>">
        <i class="fas fa-folder-open"></i>
        <span>Document Library</span>
      </a>
    </li>
    
    <% if (session && session.isAdmin) { %>
    <li style="margin-top: auto; border-top: 1px solid rgba(0, 0, 0, 0.05); padding-top: 1rem;">
      <a href="/admin" class="portal-menu-link" style="color: var(--color-muted);">
        <i class="fas fa-cogs"></i>
        <span>Admin Dashboard</span>
      </a>
    </li>
    <% } %>
  </ul>
</div>

<!-- Main Body Wrapper Start -->
<div class="portal-main">
  <!-- Top Portal Header with Switcher -->
  <div class="portal-header">
    <div>
      <h1 id="portalPageTitle"><%= pageTitle %></h1>
      <p style="color: var(--color-muted); font-size: 0.9rem; margin-top: 0.25rem;">
        Active Carrier: <strong style="color: var(--color-white);"><%= activeCarrier ? activeCarrier.company_name : 'No Active Carrier' %></strong>
        <% if (activeCarrier && activeCarrier.usdot) { %> | USDOT: <%= activeCarrier.usdot %><% } %>
      </p>
    </div>
    
    <div style="display: flex; align-items: center; gap: 1rem;">
      <!-- Admin Switcher Dropdown -->
      <% if (session && session.isAdmin && typeof allCarriers !== 'undefined' && allCarriers.length > 0) { %>
        <div class="carrier-switcher-wrapper">
          <i class="fas fa-exchange-alt" style="color: var(--color-accent); font-size: 0.85rem;"></i>
          <select class="carrier-switcher-select" onchange="window.location.href='/portal/switch-carrier/' + this.value">
            <% allCarriers.forEach(function(c) { %>
              <option value="<%= c.id %>" <%= activeCarrier && activeCarrier.id === c.id ? 'selected' : '' %>>
                <%= c.company_name %>
              </option>
            <% }) %>
          </select>
        </div>
      <% } %>
      
      <a href="/admin/logout" class="portal-btn portal-btn-secondary" style="padding: 0.45rem 0.85rem; font-size: 0.85rem;">
        <i class="fas fa-sign-out-alt"></i> Logout
      </a>
    </div>
  </div>
