  <!-- KSG Fuel Premium Footer Section -->
  <footer class="footer-wrapper">
    <div class="container footer-grid">
      
      <!-- Column 1: Brand Info -->
      <div class="footer-brand">
        <div class="footer-logo">
          <a href="/" class="logo-link" title="KSG Fuel Homepage">
            <img src="<%= config.brand.logo %>" alt="<%= config.brand.name %> Logo" class="logo-image">
            <span><%= config.brand.name %></span>
          </a>
        </div>
        <p><%= config.brand.tagline %></p>
        
        <!-- Conditional Social Media Links (Zero Broken Icons Rule) -->
        <div class="footer-social-row">
          <% if (config.social.linkedin) { %>
            <a href="<%= config.social.linkedin %>" class="social-circle" target="_blank" rel="noopener noreferrer" title="LinkedIn" aria-label="Follow us on LinkedIn">
              <i class="fab fa-linkedin-in"></i>
            </a>
          <% } %>
          <% if (config.social.facebook) { %>
            <a href="<%= config.social.facebook %>" class="social-circle" target="_blank" rel="noopener noreferrer" title="Facebook" aria-label="Follow us on Facebook">
              <i class="fab fa-facebook-f"></i>
            </a>
          <% } %>
          <% if (config.social.instagram) { %>
            <a href="<%= config.social.instagram %>" class="social-circle" target="_blank" rel="noopener noreferrer" title="Instagram" aria-label="Follow us on Instagram">
              <i class="fab fa-instagram"></i>
            </a>
          <% } %>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="footer-links">
        <h3>Quick Navigation</h3>
        <ul class="footer-nav">
          <li><a href="/">Home</a></li>
          <li><a href="/fuelcard">Fuel Card Program</a></li>
          <li><a href="/careers">Careers Board</a></li>
          <li><a href="/contact">Contact Coordinates</a></li>
          <li><a href="/apply">Apply for Card</a></li>
        </ul>
      </div>

      <!-- Column 3: Contact Coordinates -->
      <div class="footer-contact">
        <h3>Contact Us</h3>
        <ul class="footer-contact-list">
          <li>
            <i class="fas fa-map-marker-alt"></i>
            <span><%= config.contact.address %></span>
          </li>
          <li>
            <i class="fas fa-phone-alt"></i>
            <a href="tel:<%= config.contact.phone.replace(/[^0-9]/g, '') %>" style="color: inherit;"><%= config.contact.phone %></a>
          </li>
          <li>
            <i class="fas fa-envelope"></i>
            <a href="mailto:<%= config.contact.email %>" style="color: inherit;"><%= config.contact.email %></a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom copyrights row -->
    <div class="container footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> <%= config.brand.name %>. All Rights Reserved.</p>
      <p>
        <a href="/admin/login" style="color: rgba(255, 255, 255, 0.4); text-decoration: underline;" id="adminLink">Staff Admin Login</a>
      </p>
    </div>
  </footer>

  <!-- FontAwesome for standard icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  
  <!-- Interactive components javascript -->
  <script src="/js/main.js"></script>
</body>
</html>
