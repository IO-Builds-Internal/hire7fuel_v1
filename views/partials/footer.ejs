  <!-- Hire7 Fuel Premium Glassmorphic Footer -->
  <footer class="footer-wrapper">
    <div class="footer-glow-overlay"></div>
    <div class="container footer-grid">
      
      <!-- Column 1: High-Tech Brand Profile -->
      <div class="footer-brand-column">
        <div class="footer-logo-wrap">
          <a href="/" class="footer-logo-link" title="Hire7 Fuel Homepage">
            <div class="footer-logo-img-wrapper">
              <div class="logo-glow-ring"></div>
              <img src="<%= config.brand.logo %>" alt="<%= config.brand.name %> Logo" class="footer-logo-img">
            </div>
            <span class="footer-brand-title"><%= config.brand.name %></span>
          </a>
        </div>
        <p class="footer-tagline"><%= config.brand.tagline %></p>
        
        <!-- Premium Neon Social Touchpoints -->
        <div class="footer-social-row">
          <% if (config.social.linkedin) { %>
            <a href="<%= config.social.linkedin %>" class="social-glass-btn" target="_blank" rel="noopener noreferrer" title="LinkedIn" aria-label="Follow us on LinkedIn">
              <i class="fab fa-linkedin-in"></i>
            </a>
          <% } %>
          <% if (config.social.facebook) { %>
            <a href="<%= config.social.facebook %>" class="social-glass-btn" target="_blank" rel="noopener noreferrer" title="Facebook" aria-label="Follow us on Facebook">
              <i class="fab fa-facebook-f"></i>
            </a>
          <% } %>
          <% if (config.social.instagram) { %>
            <a href="<%= config.social.instagram %>" class="social-glass-btn" target="_blank" rel="noopener noreferrer" title="Instagram" aria-label="Follow us on Instagram">
              <i class="fab fa-instagram"></i>
            </a>
          <% } %>
        </div>
      </div>

      <!-- Column 2: Quick Links with Interactive Indicators -->
      <div class="footer-links-column">
        <h3 class="footer-widget-title">Quick Navigation</h3>
        <ul class="footer-nav-list">
          <li>
            <a href="/">
              <i class="fas fa-chevron-right nav-arrow-icon"></i>
              <span>Home</span>
            </a>
          </li>
          <li>
            <a href="/fuelcard">
              <i class="fas fa-chevron-right nav-arrow-icon"></i>
              <span>Fuel Card Program</span>
            </a>
          </li>
          <li>
            <a href="/careers">
              <i class="fas fa-chevron-right nav-arrow-icon"></i>
              <span>Careers Board</span>
            </a>
          </li>
          <li>
            <a href="/contact">
              <i class="fas fa-chevron-right nav-arrow-icon"></i>
              <span>Contact Coordinates</span>
            </a>
          </li>
          <li>
            <a href="/apply">
              <i class="fas fa-chevron-right nav-arrow-icon"></i>
              <span>Apply for Card</span>
            </a>
          </li>
          <li>
            <a href="/portal/login">
              <i class="fas fa-chevron-right nav-arrow-icon"></i>
              <span>Carrier Sign-In</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: High-Fidelity Contact Badges -->
      <div class="footer-contact-column">
        <h3 class="footer-widget-title">Contact Us</h3>
        <div class="footer-contact-badges">
          <!-- Address Badge -->
          <div class="contact-glass-badge">
            <div class="badge-icon-glowing"><i class="fas fa-map-location-dot"></i></div>
            <div class="badge-info-text">
              <span>OPERATIONAL HEADQUARTERS</span>
              <strong><%= config.contact.address %></strong>
            </div>
          </div>
          
          <!-- Phone Badge -->
          <a href="tel:<%= config.contact.phone.replace(/[^0-9]/g, '') %>" class="contact-glass-badge interactive-badge">
            <div class="badge-icon-glowing"><i class="fas fa-phone-alt"></i></div>
            <div class="badge-info-text">
              <span>TOLL-FREE CARRIER LINE</span>
              <strong><%= config.contact.phone %></strong>
            </div>
          </a>
          
          <!-- Email Badge -->
          <a href="mailto:<%= config.contact.email %>" class="contact-glass-badge interactive-badge">
            <div class="badge-icon-glowing"><i class="fas fa-envelope"></i></div>
            <div class="badge-info-text">
              <span>SUPPORT NETWORK INBOX</span>
              <strong><%= config.contact.email %></strong>
            </div>
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom Copyright & Utility Command Access -->
    <div class="container footer-bottom-wrap" style="justify-content: center; text-align: center;">
      <div class="footer-copyright-box">
        <p>&copy; <%= new Date().getFullYear() %> <%= config.brand.name %>. Powering Fleet Operations Worldwide.</p>
      </div>
    </div>
  </footer>

  <!-- Get Started Options Modal -->
  <div class="apply-modal" id="applyOptionModal" role="dialog" aria-modal="true" aria-labelledby="applyOptionTitle">
    <div class="apply-modal-backdrop" id="applyModalBackdrop"></div>
    <div class="apply-modal-content">
      <button class="apply-modal-close" id="applyModalClose" aria-label="Close modal">&times;</button>
      <div class="apply-modal-header">
        <h2 id="applyOptionTitle">Get Started with Hire7 Fuel</h2>
        <p>Select the option that best fits your current operational needs. Or, <a href="/portal/login" style="color: var(--color-accent); font-weight: 700; text-decoration: underline;">Sign In to your Carrier Portal</a>.</p>
      </div>
      <div class="apply-modal-options">
        <!-- Option 1: Fleet Owner / Carrier Onboarding -->
        <a href="/portal/register" class="apply-modal-card option-carrier">
          <div class="option-icon-glowing">
            <i class="fas fa-truck-moving"></i>
          </div>
          <div class="option-info">
            <h3>Fleet / Carrier Onboard</h3>
            <p>Onboard your commercial fleet, manage vehicle assets, driver compliance rosters, and IFTA/KYU/NY-HUT tax filings in our secure carrier control room.</p>
            <span class="option-btn">Onboard Fleet <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
        
        <!-- Option 2: Commercial Driver Application -->
        <a href="/apply" class="apply-modal-card option-driver">
          <div class="option-icon-glowing">
            <i class="fas fa-id-card"></i>
          </div>
          <div class="option-info">
            <h3>Commercial Driver Apply</h3>
            <p>Submit your driver coordinates, commercial licensing, passport/border credentials, and experience history to join our active driver network.</p>
            <span class="option-btn">Apply to Drive <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
      </div>
    </div>
  </div>

  <!-- FontAwesome for standard icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  
  <!-- Interactive components javascript -->
  <script src="/js/main.js"></script>
</body>
</html>
