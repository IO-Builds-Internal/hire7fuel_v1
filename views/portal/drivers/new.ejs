<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/portal_nav') %>

    <div class="portal-dashboard">
      
      <% if (error) { %>
        <div style="background-color: #FEF2F2; border: 1px solid rgba(239,68,68,0.2); color: #9B1C1C; padding: 1rem; border-radius: var(--radius-sm); margin-bottom: 1.5rem; font-weight: 600;">
          <i class="fas fa-exclamation-circle" style="margin-right: 0.5rem;"></i> <%= error %>
        </div>
      <% } %>

      <div class="portal-card">
        <h2>Onboard New Driver Profile</h2>
        <p style="color: var(--color-muted); margin-bottom: 2rem; font-size: 0.95rem;">
          Provide the required driver credentials, contacts, emergency contacts, tax classification, and API keys.
        </p>

        <form action="/portal/drivers/new" method="POST">
          
          <!-- Section 1: Personal Coordinates -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-bottom: 1.25rem; color: var(--color-accent);">Personal Details & Licensing</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">First Name</label>
              <input type="text" name="first_name" class="portal-input" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Middle Name</label>
              <input type="text" name="middle_name" class="portal-input">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Last Name</label>
              <input type="text" name="last_name" class="portal-input" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Email Address</label>
              <input type="email" name="email" class="portal-input">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Canada Phone</label>
              <input type="text" name="can_phone" class="portal-input">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">USA Phone</label>
              <input type="text" name="usa_phone" class="portal-input">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Primary Phone Contact</label>
              <div style="display: flex; gap: 1.5rem; align-items: center; padding: 0.5rem 0;">
                <label style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.9rem; cursor: pointer; color: var(--color-white);">
                  <input type="radio" name="primary_phone" value="CAN" checked> Canada
                </label>
                <label style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.9rem; cursor: pointer; color: var(--color-white);">
                  <input type="radio" name="primary_phone" value="USA"> USA
                </label>
              </div>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Emergency Contact Phone #</label>
              <input type="text" name="emergency_contact_phone" class="portal-input" placeholder="e.g. (555) 019-9283">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Driver License #</label>
              <input type="text" name="dl_number" class="portal-input" required placeholder="e.g. D1234-56789-01234">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">DL Issuing State / Province</label>
              <input type="text" name="dl_state" class="portal-input" required placeholder="e.g. ON, MI">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">DL Expiration Date</label>
              <input type="date" name="dl_expiry" class="portal-input" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Status</label>
              <select name="status" class="portal-select">
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="hold">Hold</option>
              </select>
            </div>
            <div class="portal-form-group" style="grid-column: span 3; margin-top: 0.5rem;">
              <label style="display: flex; align-items: center; gap: 0.5rem; color: var(--color-white); font-size: 0.95rem; cursor: pointer;">
                <input type="checkbox" name="hazmat_tdg" value="1"> Has Hazmat Certificate (TDG)
              </label>
            </div>
          </div>

          <!-- Section 2: Driver Classification & Truck Assignment -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">Employment & Logistics</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">Driver Type</label>
              <div style="display: flex; gap: 1.5rem; align-items: center; padding: 0.5rem 0;">
                <label style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.9rem; cursor: pointer; color: var(--color-white);">
                  <input type="radio" name="driver_type" value="Company Driver" checked onchange="toggleDriverTypeFields(this)"> Company Driver
                </label>
                <label style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.9rem; cursor: pointer; color: var(--color-white);">
                  <input type="radio" name="driver_type" value="Owner Operator" onchange="toggleDriverTypeFields(this)"> Owner Operator
                </label>
              </div>
            </div>

            <!-- Assigned Truck Dropdown -->
            <div class="portal-form-group" id="truckAssignmentField">
              <label class="portal-label">Assign Fleet Truck</label>
              <select name="assigned_truck_id" class="portal-select">
                <option value="">-- No Assigned Truck --</option>
                <% if (trucks && trucks.length > 0) { %>
                  <% trucks.forEach(function(t) { %>
                    <option value="<%= t.id %>">Unit #<%= t.unit_number %> — <%= t.make %> <%= t.model %> (<%= t.vin %>)</option>
                  <% }) %>
                <% } %>
              </select>
            </div>
          </div>

          <!-- Section 3: Citizenship, Tax Classification -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">Citizenship, Taxes & Incorporation</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">Citizenship</label>
              <select name="citizenship" id="citizenshipSelect" class="portal-select" onchange="toggleCitizenshipFields(this)">
                <option value="Canada">Canada</option>
                <option value="United States">United States</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="portal-form-group">
              <label class="portal-label">Payment Method</label>
              <select name="payment_type" id="paymentTypeSelect" class="portal-select" onchange="togglePaymentTypeFields(this)">
                <option value="Payroll">Payroll (W2 / T4)</option>
                <option value="Independent Contractor">Independent Contractor (1099)</option>
              </select>
            </div>

            <div class="portal-form-group" id="contractorCompanyGroup" style="display: none;">
              <label class="portal-label">Contractor Company Name</label>
              <input type="text" name="contractor_company_name" class="portal-input" placeholder="Incorporated Name">
            </div>
            
            <div class="portal-form-group" id="contractorHstGroup" style="display: none;">
              <label class="portal-label">Contractor HST / Business Number</label>
              <input type="text" name="contractor_hst" class="portal-input" placeholder="HST #">
            </div>

            <div class="portal-form-group">
              <label class="portal-label">Payment Classification</label>
              <select name="payment_classification" id="paymentClassification" class="portal-select" onchange="handlePaymentClassChange(this.value)">
                <option value="Payroll">Payroll</option>
                <option value="In-Corporation">In-Corporation</option>
              </select>
            </div>

            <div class="portal-form-group">
              <label class="portal-label">SIN Number <span style="font-size: 0.75rem; color: var(--color-muted);">(Masked in displays)</span></label>
              <input type="text" name="sin_number" class="portal-input" placeholder="e.g. 123-456-789">
            </div>

            <div class="portal-form-group">
              <label class="portal-label">WCB / WSIB Account #</label>
              <input type="text" name="wcb_number" class="portal-input" placeholder="e.g. WCB-9820-1">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">WCB / WSIB Expiration</label>
              <input type="date" name="wcb_expiry" class="portal-input">
            </div>

            <div class="portal-form-group">
              <label class="portal-label">Passport Number</label>
              <input type="text" name="passport_number" class="portal-input">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Passport Expiration</label>
              <input type="date" name="passport_expiry" class="portal-input">
            </div>
          </div>

          <!-- Incorporation Details (Conditional on payment_classification === 'In-Corporation') -->
          <div id="incorporationSection" style="display: none; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; margin-top: 1.5rem;">
            <h3 style="font-size: 1rem; color: var(--color-accent); margin-bottom: 1rem;">Incorporation Details</h3>
            <div class="portal-form-grid">
              <div class="portal-form-group">
                <label class="portal-label">Corporate Name</label>
                <input type="text" name="inc_name" class="portal-input" placeholder="e.g. Acme Trucking Inc.">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">DBA (Doing Business As)</label>
                <input type="text" name="inc_dba" class="portal-input" placeholder="e.g. Acme Logistics">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Corporate Address</label>
                <input type="text" name="inc_address" class="portal-input" placeholder="Street, City, Province, Postal Code">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Corporate Phone #</label>
                <input type="text" name="inc_phone" class="portal-input" placeholder="(555) 000-0000">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Corporate E-Mail</label>
                <input type="email" name="inc_email" class="portal-input" placeholder="corporate@email.com">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">GST/HST Number</label>
                <input type="text" name="inc_gst_hst" class="portal-input" placeholder="e.g. 123456789 RT 0001">
              </div>
            </div>
          </div>

          <!-- Section 4: Border Crossing Credentials (Conditional based on Citizenship) -->
          <div id="borderDocsSection" style="margin-top: 1.5rem;">
            <!-- FAST Card Option -->
            <div id="fastCardWrapper" style="display: block; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; margin-bottom: 1.5rem;">
              <div class="toggle-switch-wrapper" style="margin-bottom: 1rem;">
                <label class="toggle-switch">
                  <input type="checkbox" id="hasFastCard" onchange="toggleSubDocFields(this, 'fastCardInputs')">
                  <span class="toggle-slider"></span>
                </label>
                <span class="portal-label">Has FAST Card Credentials</span>
              </div>
              <div class="portal-form-grid" id="fastCardInputs" style="display: none;">
                <div class="portal-form-group">
                  <label class="portal-label">FAST Card Number</label>
                  <input type="text" name="fast_card_number" class="portal-input">
                </div>
                <div class="portal-form-group">
                  <label class="portal-label">FAST Card Expiry</label>
                  <input type="date" name="fast_card_expiry" class="portal-input">
                </div>
              </div>
            </div>

            <!-- CDRP Card Option -->
            <div id="cdrpCardWrapper" style="display: block; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; margin-bottom: 1.5rem;">
              <div class="toggle-switch-wrapper" style="margin-bottom: 1rem;">
                <label class="toggle-switch">
                  <input type="checkbox" id="hasCdrpCard" onchange="toggleSubDocFields(this, 'cdrpCardInputs')">
                  <span class="toggle-slider"></span>
                </label>
                <span class="portal-label">Has CDRP Card Credentials</span>
              </div>
              <div class="portal-form-grid" id="cdrpCardInputs" style="display: none;">
                <div class="portal-form-group">
                  <label class="portal-label">CDRP Card Number</label>
                  <input type="text" name="cdrp_number" class="portal-input">
                </div>
                <div class="portal-form-group">
                  <label class="portal-label">CDRP Card Expiry</label>
                  <input type="date" name="cdrp_expiry" class="portal-input">
                </div>
              </div>
            </div>

            <!-- Visa Option -->
            <div id="visaWrapper" style="display: none; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; margin-bottom: 1.5rem;">
              <div class="portal-form-grid">
                <div class="portal-form-group">
                  <label class="portal-label">Work / Travel Visa Number</label>
                  <input type="text" name="visa_number" class="portal-input">
                </div>
                <div class="portal-form-group">
                  <label class="portal-label">Visa Expiration Date</label>
                  <input type="date" name="visa_expiry" class="portal-input">
                </div>
              </div>
            </div>
          </div>

          <!-- Section 5: Medical Milestones -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">Medical Reviews</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">Medical Examiners Certificate Review Due Date</label>
              <input type="date" name="medical_due_date" class="portal-input">
            </div>
          </div>

          <!-- Section 6: API Keys & Integrations -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">ELD & Fuel API Integrations</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">ELD Provider Company</label>
              <input type="text" name="eld_company_name" class="portal-input" placeholder="e.g. Samsara, KeepTruckin">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">ELD API Key / Token</label>
              <input type="password" name="eld_api_key" class="portal-input" placeholder="Paste ELD API credentials">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Fuel Integration Provider</label>
              <input type="text" name="fuel_company_name" class="portal-input" placeholder="e.g. Comdata, Fleetcor">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Fuel API Key / Account ID</label>
              <input type="password" name="fuel_api_key" class="portal-input" placeholder="Paste Fuel Card API credentials">
            </div>
          </div>

          <!-- Form Buttons -->
          <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; margin-top: 2rem; display: flex; justify-content: flex-end; gap: 1rem;">
            <a href="/portal/drivers" class="portal-btn portal-btn-secondary">Cancel</a>
            <button type="submit" class="portal-btn portal-btn-primary"><i class="fas fa-user-plus"></i> Complete Onboarding</button>
          </div>

        </form>
      </div>

    </div>
  </div>

  <script>
    function toggleDriverTypeFields(radio) {
      const assignField = document.getElementById('truckAssignmentField');
      assignField.style.display = 'block';
    }

    function togglePaymentTypeFields(select) {
      const isContractor = select.value === 'Independent Contractor';
      document.getElementById('contractorCompanyGroup').style.display = isContractor ? 'block' : 'none';
      document.getElementById('contractorHstGroup').style.display = isContractor ? 'block' : 'none';
    }

    function handlePaymentClassChange(val) {
      const incSec = document.getElementById('incorporationSection');
      if (val === 'In-Corporation') {
        incSec.style.display = 'block';
      } else {
        incSec.style.display = 'none';
      }
    }

    function toggleCitizenshipFields(select) {
      const citizenship = select.value;
      const visaWrapper = document.getElementById('visaWrapper');
      const cdrpWrapper = document.getElementById('cdrpCardWrapper');
      const fastWrapper = document.getElementById('fastCardWrapper');
      
      if (citizenship === 'Canada') {
        cdrpWrapper.style.display = 'block';
        fastWrapper.style.display = 'block';
        visaWrapper.style.display = 'none';
      } else if (citizenship === 'United States') {
        cdrpWrapper.style.display = 'none';
        fastWrapper.style.display = 'block';
        visaWrapper.style.display = 'none';
      } else {
        cdrpWrapper.style.display = 'none';
        fastWrapper.style.display = 'none';
        visaWrapper.style.display = 'block';
      }
    }

    function toggleSubDocFields(checkbox, containerId) {
      const container = document.getElementById(containerId);
      container.style.display = checkbox.checked ? 'grid' : 'none';
    }

    // Initialize fields
    window.onload = function() {
      toggleCitizenshipFields(document.getElementById('citizenshipSelect'));
      togglePaymentTypeFields(document.getElementById('paymentTypeSelect'));
      handlePaymentClassChange(document.getElementById('paymentClassification').value);
    };
  </script>
</body>
</html>
