<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/portal_nav') %>

    <div class="portal-dashboard">
      
      <div style="display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2rem;">
        <a href="/portal/drivers" class="portal-btn portal-btn-secondary" style="padding: 0.5rem 1rem;">
          <i class="fas fa-arrow-left"></i> Back to Roster
        </a>
        <a href="/portal/drivers/<%= driver.id %>/edit" class="portal-btn portal-btn-primary" style="padding: 0.5rem 1rem;">
          <i class="fas fa-edit"></i> Edit Driver Profile
        </a>
      </div>

      <div class="portal-card">
        <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.05);">
          <div style="width: 70px; height: 70px; border-radius: 50%; background: rgba(20, 160, 119, 0.1); color: var(--color-accent); display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 700;">
            <%= driver.first_name.charAt(0) %><%= driver.last_name.charAt(0) %>
          </div>
          <div>
            <h2 style="margin: 0; font-size: 1.75rem;"><%= driver.first_name %> <%= driver.middle_name || '' %> <%= driver.last_name %></h2>
            <p style="margin: 0; color: var(--color-muted); font-size: 0.95rem;">
              Classification: <strong style="color: var(--color-white);"><%= driver.driver_type %></strong> | Status: <strong style="color: var(--color-accent);"><%= driver.status %></strong>
            </p>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;">
          <!-- Left Column: Core Info & Contacts -->
          <div>
            <h3 style="font-size: 1.1rem; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 0.5rem; margin-bottom: 1rem;">Core Details & Contacts</h3>
            
            <table class="portal-table" style="border: none;">
              <tbody>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none; width: 180px;">Email Address:</td>
                  <td style="padding: 0.5rem 0; border: none;"><%= driver.email || '—' %></td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Canada Phone:</td>
                  <td style="padding: 0.5rem 0; border: none;">
                    <%= driver.can_phone || '—' %>
                    <%= driver.primary_phone === 'CAN' ? '(Primary)' : '' %>
                  </td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">USA Phone:</td>
                  <td style="padding: 0.5rem 0; border: none;">
                    <%= driver.usa_phone || '—' %>
                    <%= driver.primary_phone === 'USA' ? '(Primary)' : '' %>
                  </td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Emergency Contact:</td>
                  <td style="padding: 0.5rem 0; border: none;"><%= driver.emergency_contact_phone || '—' %></td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Assigned Truck:</td>
                  <td style="padding: 0.5rem 0; border: none;">
                    <% if (truck) { %>
                      <a href="/portal/trucks/<%= truck.id %>" style="color: var(--color-accent); font-weight: 600;">Unit #<%= truck.unit_number %> (<%= truck.make %> <%= truck.model %>)</a>
                    <% } else { %>
                      <span style="color: var(--color-muted);">No assigned truck unit</span>
                    <% } %>
                  </td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Payment Type:</td>
                  <td style="padding: 0.5rem 0; border: none;"><%= driver.payment_type %></td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Payment Class:</td>
                  <td style="padding: 0.5rem 0; border: none;"><%= driver.payment_classification || 'Payroll' %></td>
                </tr>
                <% if (driver.payment_type === 'Independent Contractor') { %>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Contractor Entity:</td>
                    <td style="padding: 0.5rem 0; border: none;">
                      <%= driver.contractor_company_name || '—' %>
                      <% 
                        try {
                          const info = JSON.parse(driver.contractor_info);
                          if (info && info.hst_number) {
                            %><br><small style="color: var(--color-muted);">HST: <%= info.hst_number %></small><%
                          }
                        } catch(e) {}
                      %>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>

          <!-- Right Column: Compliance Credentials & Dates -->
          <div>
            <h3 style="font-size: 1.1rem; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 0.5rem; margin-bottom: 1rem;">Compliance Milestones</h3>
            
            <table class="portal-table" style="border: none;">
              <tbody>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none; width: 180px;">DL Issuing Info:</td>
                  <td style="padding: 0.5rem 0; border: none; font-family: monospace;"><%= driver.dl_number %> (<%= driver.dl_state %>)</td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">DL Expiry:</td>
                  <td style="padding: 0.5rem 0; border: none;">
                    <%- include('../../partials/expiry_badge', { expiry: driver.dl_expiry }) %>
                  </td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Hazmat (TDG) Status:</td>
                  <td style="padding: 0.5rem 0; border: none;">
                    <% if (driver.hazmat_tdg === 1) { %>
                      <span class="expiry-badge badge-green" style="background: rgba(34, 201, 138, 0.1); color: var(--color-accent); padding: 0.25rem 0.5rem; border-radius: 4px; font-weight: 600; font-size: 0.85rem;">Certified</span>
                    <% } else { %>
                      <span style="background: rgba(255,255,255,0.05); color: var(--color-muted); padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.85rem;">Not Certified</span>
                    <% } %>
                  </td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Medical Certificate:</td>
                  <td style="padding: 0.5rem 0; border: none;">
                    <%- include('../../partials/expiry_badge', { expiry: driver.medical_due_date }) %>
                  </td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">SIN Number:</td>
                  <td style="padding: 0.5rem 0; border: none; font-family: monospace;"><%= maskNumber(driver.sin_number) %></td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">WCB / WSIB Account:</td>
                  <td style="padding: 0.5rem 0; border: none;">
                    <%= driver.wcb_number || '—' %><br>
                    <% if (driver.wcb_expiry) { %>
                      <%- include('../../partials/expiry_badge', { expiry: driver.wcb_expiry }) %>
                    <% } %>
                  </td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Citizenship:</td>
                  <td style="padding: 0.5rem 0; border: none;"><%= driver.citizenship %></td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Passport Details:</td>
                  <td style="padding: 0.5rem 0; border: none;">
                    <%= driver.passport_number || '—' %><br>
                    <% if (driver.passport_expiry) { %>
                      <%- include('../../partials/expiry_badge', { expiry: driver.passport_expiry }) %>
                    <% } %>
                  </td>
                </tr>
                <% if (driver.fast_card_number) { %>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none;">FAST Card:</td>
                    <td style="padding: 0.5rem 0; border: none;">
                      <%= driver.fast_card_number %><br>
                      <%- include('../../partials/expiry_badge', { expiry: driver.fast_card_expiry }) %>
                    </td>
                  </tr>
                <% } %>
                <% if (driver.cdrp_number) { %>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none;">CDRP Card:</td>
                    <td style="padding: 0.5rem 0; border: none;">
                      <%= driver.cdrp_number %><br>
                      <%- include('../../partials/expiry_badge', { expiry: driver.cdrp_expiry }) %>
                    </td>
                  </tr>
                <% } %>
                <% if (driver.visa_number) { %>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none;">US Visa:</td>
                    <td style="padding: 0.5rem 0; border: none;">
                      <%= driver.visa_number %><br>
                      <%- include('../../partials/expiry_badge', { expiry: driver.visa_expiry }) %>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <!-- Incorporation Details Card (Conditional) -->
      <% if (driver.payment_classification === 'In-Corporation') { %>
        <div class="portal-card" style="margin-top: 2rem;">
          <h2 style="font-size: 1.25rem; color: var(--color-accent); border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-bottom: 1rem;">
            <i class="fas fa-building" style="margin-right: 0.5rem;"></i> Incorporation Details
          </h2>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;">
            <div>
              <table class="portal-table" style="border: none;">
                <tbody>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none; width: 180px;">Corporate Name:</td>
                    <td style="padding: 0.5rem 0; border: none;"><%= driver.inc_name || '—' %></td>
                  </tr>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none;">DBA Name:</td>
                    <td style="padding: 0.5rem 0; border: none;"><%= driver.inc_dba || '—' %></td>
                  </tr>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none;">GST/HST Number:</td>
                    <td style="padding: 0.5rem 0; border: none;"><%= driver.inc_gst_hst || '—' %></td>
                  </tr>
                </tbody>
              </table>
            </div>
            <div>
              <table class="portal-table" style="border: none;">
                <tbody>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none; width: 180px;">Corporate Phone:</td>
                    <td style="padding: 0.5rem 0; border: none;"><%= driver.inc_phone || '—' %></td>
                  </tr>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Corporate Email:</td>
                    <td style="padding: 0.5rem 0; border: none;"><%= driver.inc_email || '—' %></td>
                  </tr>
                  <tr>
                    <td style="font-weight: 600; padding: 0.5rem 0; border: none;">Corporate Address:</td>
                    <td style="padding: 0.5rem 0; border: none;"><%= driver.inc_address || '—' %></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ELD & Fuel API Integrations Card -->
      <div class="portal-card" style="margin-top: 2rem;">
        <h2 style="font-size: 1.25rem; color: var(--color-accent); border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-bottom: 1rem;">
          <i class="fas fa-network-wired" style="margin-right: 0.5rem;"></i> ELD & Fuel API Integrations
        </h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;">
          <div>
            <h3 style="font-size: 1rem; color: var(--color-white); margin-bottom: 0.5rem;">ELD Provider Integration</h3>
            <table class="portal-table" style="border: none;">
              <tbody>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none; width: 180px;">Company Name:</td>
                  <td style="padding: 0.5rem 0; border: none;"><%= driver.eld_company_name || 'Not Configured' %></td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">API Access Token:</td>
                  <td style="padding: 0.5rem 0; border: none; font-family: monospace;">
                    <%= driver.eld_api_key ? '••••••••••••••••' : 'Not Configured' %>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <div>
            <h3 style="font-size: 1rem; color: var(--color-white); margin-bottom: 0.5rem;">Fuel API Integration</h3>
            <table class="portal-table" style="border: none;">
              <tbody>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none; width: 180px;">Company Name:</td>
                  <td style="padding: 0.5rem 0; border: none;"><%= driver.fuel_company_name || 'Not Configured' %></td>
                </tr>
                <tr>
                  <td style="font-weight: 600; padding: 0.5rem 0; border: none;">API Key / Secret:</td>
                  <td style="padding: 0.5rem 0; border: none; font-family: monospace;">
                    <%= driver.fuel_api_key ? '••••••••••••••••' : 'Not Configured' %>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Reference Verification Panel -->
      <div class="portal-card" style="margin-top: 2rem; margin-bottom: 3rem;">
        <h2 style="font-size: 1.25rem; color: var(--color-accent); border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-bottom: 1.5rem;">
          <i class="fas fa-user-check" style="margin-right: 0.5rem;"></i> Employment Reference Verification Check
        </h2>

        <%
          let recipient = null;
          try {
            if (driver.ref_check_recipient_info) {
              recipient = JSON.parse(driver.ref_check_recipient_info);
            }
          } catch (e) {}

          let refDriverInfo = null;
          try {
            if (driver.ref_check_driver_info) {
              refDriverInfo = JSON.parse(driver.ref_check_driver_info);
            }
          } catch (e) {}
        %>

        <% if (recipient) { %>
          <div style="background: rgba(0,0,0,0.15); border: 1px solid rgba(255,255,255,0.05); padding: 1.25rem; border-radius: 6px; margin-bottom: 2rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.75rem; margin-bottom: 1rem;">
              <h3 style="font-size: 1.05rem; margin: 0; color: var(--color-white);">Active Reference Check Details</h3>
              <span class="expiry-badge <%= driver.ref_check_status === 'Completed' ? 'badge-green' : 'badge-amber' %>" style="font-size: 0.85rem; font-weight: 600; padding: 0.3rem 0.6rem; border-radius: 4px;">
                <%= driver.ref_check_status === 'Completed' ? 'Completed' : 'Pending Response' %>
              </span>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; font-size: 0.95rem; margin-bottom: 1rem;">
              <div>
                <div><strong>Reference Name:</strong> <%= recipient.name %></div>
                <div><strong>Reference Email:</strong> <%= recipient.email %></div>
                <div><strong>Reference Phone:</strong> <%= recipient.phone || '—' %></div>
              </div>
              <div>
                <% if (refDriverInfo) { %>
                  <div><strong>Position Applied:</strong> <%= refDriverInfo.position %></div>
                <% } %>
                <div><strong>Follow-up Reminders Sent:</strong> <%= driver.ref_check_followup_count %> / 3</div>
                <% if (driver.ref_check_status !== 'Completed') { %>
                  <div style="margin-top: 0.25rem;">
                    <strong>Verification URL:</strong> 
                    <a href="/public/ref-check/<%= driver.id %>" target="_blank" style="color: var(--color-accent); font-weight: 600;">View Live Form</a>
                  </div>
                <% } %>
              </div>
            </div>

            <% if (driver.ref_check_status === 'Completed' && recipient.responses) { %>
              <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem; margin-top: 1rem;">
                <h4 style="color: var(--color-accent); font-size: 0.95rem; margin-top: 0; margin-bottom: 0.75rem;">Verification Response Summary</h4>
                <div style="display: grid; grid-template-columns: 1fr; gap: 0.75rem; font-size: 0.9rem; background: rgba(0,0,0,0.1); padding: 1rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.02);">
                  <div><strong>1. Relationship / Professional Role:</strong> <%= recipient.responses.relationship %></div>
                  <div><strong>2. Performance Rating:</strong> <%= recipient.responses.performance_rating %> / 5 Stars</div>
                  <div><strong>3. Recommend for Rehire?</strong> <%= recipient.responses.eligible_for_rehire %></div>
                  <div><strong>4. Comments / Feedback:</strong> <%= recipient.responses.comments || 'No comment provided' %></div>
                  <div style="font-size: 0.8rem; color: var(--color-muted); text-align: right; margin-top: 0.5rem;">
                    Submitted: <%= new Date(recipient.responses.submitted_at).toLocaleString() %>
                  </div>
                </div>
              </div>
            <% } %>

            <div style="margin-top: 1.25rem; display: flex; gap: 1rem; flex-wrap: wrap;">
              <% if (driver.ref_check_status === 'Completed' && driver.ref_check_pdf_path) { %>
                <a href="<%= driver.ref_check_pdf_path %>" target="_blank" class="portal-btn portal-btn-primary" style="padding: 0.5rem 1rem;">
                  <i class="fas fa-file-pdf"></i> View & Download PDF Report
                </a>
              <% } else if (driver.ref_check_status !== 'Completed') { %>
                <form action="/portal/drivers/<%= driver.id %>/ref-check/followup" method="POST" style="display: inline;">
                  <button type="submit" class="portal-btn portal-btn-primary" style="padding: 0.5rem 1rem;" <%= driver.ref_check_followup_count >= 3 ? 'disabled' : '' %>>
                    <i class="fas fa-envelope"></i> Send Follow-Up Reminder (<%= driver.ref_check_followup_count %>/3)
                  </button>
                </form>
                <button onclick="navigator.clipboard.writeText('http://localhost:3000/public/ref-check/<%= driver.id %>'); alert('Access Link copied to clipboard!');" class="portal-btn portal-btn-secondary" style="padding: 0.5rem 1rem;">
                  <i class="fas fa-copy"></i> Copy Public Form Link
                </button>
              <% } %>
              <button onclick="document.getElementById('reinitiateSection').style.display='block'; this.style.display='none';" class="portal-btn portal-btn-secondary" style="padding: 0.5rem 1rem;">
                <i class="fas fa-redo"></i> Start New Reference Check
              </button>
            </div>
          </div>
        <% } %>

        <div id="reinitiateSection" style="display: <%= recipient ? 'none' : 'block' %>;">
          <h3 style="font-size: 1rem; color: var(--color-white); margin-bottom: 1.25rem;">
            <%= recipient ? 'Initiate a New Reference Check' : 'No reference check initiated yet. Start a reference verification:' %>
          </h3>
          <form action="/portal/drivers/<%= driver.id %>/ref-check" method="POST">
            <div class="portal-form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
              <div class="portal-form-group">
                <label class="portal-label">Reference Contact Name</label>
                <input type="text" name="ref_name" class="portal-input" placeholder="e.g. John Smith" required>
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Reference Contact Email</label>
                <input type="email" name="ref_email" class="portal-input" placeholder="john.smith@company.com" required>
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Reference Contact Phone</label>
                <input type="text" name="ref_phone" class="portal-input" placeholder="e.g. (555) 019-2831">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Position Applied</label>
                <input type="text" name="position_applied" class="portal-input" value="<%= driver.driver_type || 'Commercial Driver' %>" required>
              </div>
            </div>
            <button type="submit" class="portal-btn portal-btn-primary" style="margin-top: 1.25rem; padding: 0.6rem 1.25rem;">
              <i class="fas fa-play"></i> Send Reference Request
            </button>
          </form>
        </div>
      </div>


    </div>
  </div>

</body>
</html>
