<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/portal_nav') %>

    <div class="portal-dashboard">
      
      <div class="portal-card">
        <div class="portal-card-header">
          <h2>Trailer Fleet Manager</h2>
          <a href="/portal/trailers/new" class="portal-btn portal-btn-primary">
            <i class="fas fa-plus"></i> Register Trailer
          </a>
        </div>

        <p style="color: var(--color-muted); margin-bottom: 1.5rem; font-size: 0.95rem;">
          Monitor trailer unit logs, license plate registrations, and annual safety/PMVI maintenance schedules.
        </p>

        <!-- Status Filter Tabs -->
        <div style="display: flex; gap: 0.75rem; margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding-bottom: 0.75rem;">
          <a href="/portal/trailers?status=active" class="portal-btn <%= currentStatus === 'active' ? 'portal-btn-primary' : 'portal-btn-secondary' %>" style="padding: 0.4rem 1rem; font-size: 0.85rem; border-radius: var(--radius-sm);">Active</a>
          <a href="/portal/trailers?status=inactive" class="portal-btn <%= currentStatus === 'inactive' ? 'portal-btn-primary' : 'portal-btn-secondary' %>" style="padding: 0.4rem 1rem; font-size: 0.85rem; border-radius: var(--radius-sm);">Inactive</a>
          <a href="/portal/trailers?status=hold" class="portal-btn <%= currentStatus === 'hold' ? 'portal-btn-primary' : 'portal-btn-secondary' %>" style="padding: 0.4rem 1rem; font-size: 0.85rem; border-radius: var(--radius-sm);">Hold</a>
        </div>

        <div class="portal-table-wrap">
          <table class="portal-table">
            <thead>
              <tr>
                <th>Unit #</th>
                <th>Make / Model / Year</th>
                <th>Registration State</th>
                <th>Active Plate</th>
                <th>Annual Safety</th>
                <th>PMVI Due Date</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (trailers && trailers.length > 0) { %>
                <% trailers.forEach(function(tr) { %>
                  <tr>
                    <td style="font-weight: 700; color: var(--color-white);"><a href="/portal/trailers/<%= tr.id %>" style="color: var(--color-white); text-decoration: underline;">#<%= tr.unit_number %></a></td>
                    <td><%= tr.make %> <%= tr.model %> (<%= tr.year || '—' %>)</td>
                    <td><%= tr.registration_state || '—' %></td>
                    <td style="font-family: monospace; font-weight: 600;"><%= tr.activePlateNumber %></td>
                    <td>
                      <%- include('../../partials/expiry_badge', { expiry: tr.annual_safety_expiry }) %>
                    </td>
                    <td>
                      <%- include('../../partials/expiry_badge', { expiry: tr.pmvi_next_date }) %>
                    </td>
                    <td>
                      <span class="expiry-badge <%= tr.status === 'active' ? 'badge-green' : (tr.status === 'hold' ? 'badge-amber' : 'badge-red') %>"><%= tr.status %></span>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" style="text-align: center; color: var(--color-muted); padding: 4rem 2rem;">
                    <i class="fas fa-trailer" style="font-size: 2.5rem; color: rgba(20,160,119,0.1); margin-bottom: 1rem; display: block;"></i>
                    <p style="margin: 0; font-weight: 600; color: var(--color-white);">No trailers found</p>
                    <p style="margin: 0; font-size: 0.85rem; margin-bottom: 1rem;">No trailer records match this status.</p>
                    <a href="/portal/trailers/new" class="portal-btn portal-btn-primary">Register First Trailer</a>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

</body>
</html>
