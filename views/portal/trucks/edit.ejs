<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .finance-subform, .border-transponder-form-group {
      transition: all 0.3s ease;
    }
  </style>
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/portal_nav') %>

    <div class="portal-dashboard">
      
      <% if (error) { %>
        <div style="background-color: #FEF2F2; border: 1px solid rgba(239,68,68,0.2); color: #9B1C1C; padding: 1rem; border-radius: var(--radius-sm); margin-bottom: 1.5rem; font-weight: 600;">
          <i class="fas fa-exclamation-circle" style="margin-right: 0.5rem;"></i> <%= error %>
        </div>
      <% } %>

      <div class="portal-card">
        <h2>Edit Fleet Truck Details</h2>
        <p style="color: var(--color-muted); margin-bottom: 2rem; font-size: 0.95rem;">
          Update unit details, active plate registrations, operating region parameters, and asset financing.
        </p>

        <form action="/portal/trucks/<%= truck.id %>/edit" method="POST" id="truckForm">
          
          <!-- Section 1: Basic Specifications -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-bottom: 1.25rem; color: var(--color-accent);">Basic Specifications</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">Unit Number</label>
              <input type="text" name="unit_number" class="portal-input" value="<%= truck.unit_number || '' %>" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">VIN (Vehicle Identification Number)</label>
              <input type="text" name="vin" class="portal-input" value="<%= truck.vin || '' %>" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Make</label>
              <input type="text" name="make" class="portal-input" value="<%= truck.make || '' %>" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Model</label>
              <input type="text" name="model" class="portal-input" value="<%= truck.model || '' %>" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Year</label>
              <input type="number" name="year" class="portal-input" value="<%= truck.year || '' %>" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Ownership Classification</label>
              <select name="ownership_type" class="portal-select">
                <option value="Company Truck" <%= truck.ownership_type === 'Company Truck' ? 'selected' : '' %>>Company Truck</option>
                <option value="Owner Operator" <%= truck.ownership_type === 'Owner Operator' ? 'selected' : '' %>>Owner Operator</option>
              </select>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">GPS Tracker Device ID</label>
              <input type="text" name="gps_tracker" class="portal-input" value="<%= truck.gps_tracker || '' %>">
            </div>
          </div>

          <!-- Section 2: Operating & Specs Categorization -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">Operating Parameters</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">Operating Region</label>
              <select name="operating_region" id="operatingRegion" class="portal-select" onchange="handleRegionChange(this.value)">
                <option value="Provincial" <%= truck.operating_region === 'Provincial' ? 'selected' : '' %>>Provincial (Canada Only - Basic)</option>
                <option value="Canada Wide" <%= truck.operating_region === 'Canada Wide' ? 'selected' : '' %>>Canada Wide (IFTA & Canada Tolls)</option>
                <option value="Cross-Border" <%= truck.operating_region === 'Cross-Border' ? 'selected' : '' %>>Cross-Border (Canada–USA)</option>
              </select>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Status</label>
              <select name="status" class="portal-select">
                <option value="active" <%= truck.status === 'active' ? 'selected' : '' %>>Active</option>
                <option value="inactive" <%= truck.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                <option value="hold" <%= truck.status === 'hold' ? 'selected' : '' %>>Hold</option>
              </select>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Equipment Type</label>
              <select name="equipment_type" class="portal-select">
                <option value="Cargo Van" <%= truck.equipment_type === 'Cargo Van' ? 'selected' : '' %>>Cargo Van</option>
                <option value="Sprinter Van" <%= truck.equipment_type === 'Sprinter Van' ? 'selected' : '' %>>Sprinter Van</option>
                <option value="Cube Van" <%= truck.equipment_type === 'Cube Van' ? 'selected' : '' %>>Cube Van</option>
                <option value="Straight Truck" <%= truck.equipment_type === 'Straight Truck' ? 'selected' : '' %>>Straight Truck</option>
                <option value="Tractor – Day Cab" <%= truck.equipment_type === 'Tractor – Day Cab' ? 'selected' : '' %>>Tractor – Day Cab</option>
                <option value="Tractor – Sleeper Cab" <%= truck.equipment_type === 'Tractor – Sleeper Cab' ? 'selected' : '' %>>Tractor – Sleeper Cab</option>
              </select>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Axle Configuration</label>
              <select name="axle_config" class="portal-select">
                <option value="Single Axle" <%= truck.axle_config === 'Single Axle' ? 'selected' : '' %>>Single Axle</option>
                <option value="Tandem" <%= truck.axle_config === 'Tandem' ? 'selected' : '' %>>Tandem</option>
                <option value="Tr-Axle" <%= truck.axle_config === 'Tr-Axle' ? 'selected' : '' %>>Tr-Axle</option>
                <option value="Quad-Axle" <%= truck.axle_config === 'Quad-Axle' ? 'selected' : '' %>>Quad-Axle</option>
              </select>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Est KMS per Litre</label>
              <input type="number" step="0.01" name="est_kms_per_litre" class="portal-input" value="<%= truck.est_kms_per_litre || '' %>">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Calculated KMs/Litre</label>
              <input type="number" step="0.01" name="calculated_kms_per_litre" class="portal-input" value="<%= truck.calculated_kms_per_litre || '' %>" readonly>
            </div>
          </div>

          <!-- Section 3: Dual Currency Fuel Cards -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">Fuel Cards Setup</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">CAD Currency Fuel Card</label>
              <input type="text" name="fuel_card_cad" class="portal-input" value="<%= truck.fuel_card_cad || '' %>">
            </div>
            <div class="portal-form-group" id="usdFuelCardGroup">
              <label class="portal-label">USD Currency Fuel Card</label>
              <input type="text" name="fuel_card_usd" class="portal-input" value="<%= truck.fuel_card_usd || '' %>">
            </div>
          </div>

          <!-- Section 4: License Plate -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">License Plate & Weight Details</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">Plate Number</label>
              <input type="text" name="plate_number" class="portal-input" value="<%= activePlate.plate_number || '' %>" placeholder="e.g. 982-7XP">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Fleet # (Plate Group)</label>
              <input type="text" name="plate_group" class="portal-input" value="<%= activePlate.plate_group || '' %>" placeholder="e.g. Fleet 1">
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Registered Weight Group</label>
              <input type="text" name="weight_group" class="portal-input" value="<%= activePlate.weight_group || '' %>" placeholder="e.g. Weight Group 1">
            </div>
            <div class="portal-form-group" id="plateExpiryGroup">
              <label class="portal-label">Plate Expiration Date</label>
              <input type="date" name="plate_expiry" class="portal-input" value="<%= activePlate.expiry || '' %>">
            </div>
          </div>

          <!-- Section 5: Tolls Configurations & Master Transponders -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">Tolls & Transponders</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group" id="dtopsGroup">
              <label class="portal-label">D-TOPS Transponder Allocation</label>
              <select name="dtops_transponder_id" class="portal-select">
                <option value="">-- Assign Master D-TOPS --</option>
                <% availableDtops.forEach(function(d) { %>
                  <option value="<%= d.id %>" <%= currentDtops && currentDtops.id === d.id ? 'selected' : '' %>><%= d.transponder_number %></option>
                <% }) %>
              </select>
            </div>
            <div class="portal-form-group" id="bluewaterGroup">
              <label class="portal-label">Blue Water Bridge Allocation</label>
              <select name="bluewater_transponder_id" class="portal-select">
                <option value="">-- Assign Master Blue Water --</option>
                <% availableBorder.forEach(function(b) { %>
                  <option value="<%= b.id %>" <%= currentBorder && currentBorder.id === b.id ? 'selected' : '' %>><%= b.transponder_number %> (<%= b.bridge_name %>)</option>
                <% }) %>
              </select>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">HWY 407 Transponder #</label>
              <input type="text" name="tolls_hwy407" class="portal-input" value="<%= truck.tolls_hwy407 || '' %>">
            </div>
            <div class="portal-form-group" id="iftaDecalGroup">
              <label class="portal-label">IFTA Decal Number</label>
              <input type="text" name="ifta_decal" class="portal-input" value="<%= truck.ifta_decal || '' %>" placeholder="e.g. IFTA-2026-892">
            </div>
            <div class="portal-form-group" id="nyhutDecalGroup">
              <label class="portal-label">NYHUT Decal Number</label>
              <input type="text" name="nyhut_decal" class="portal-input" value="<%= truck.nyhut_decal || '' %>" placeholder="e.g. NYHUT-8890A">
            </div>
          </div>

          <!-- Section 6: Inspections -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">Preventive Maintenance Inspections</h3>
          <div class="portal-form-grid">
            <div class="portal-form-group">
              <label class="portal-label">PMVI: Last Inspection Date</label>
              <input type="date" name="pmvi_last_date" class="portal-input" value="<%= truck.pmvi_last_date || '' %>" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">PMVI Servicing Frequency</label>
              <select name="pmvi_frequency" class="portal-select">
                <option value="monthly" <%= truck.pmvi_frequency === 'monthly' ? 'selected' : '' %>>Monthly</option>
                <option value="quarterly" <%= truck.pmvi_frequency === 'quarterly' ? 'selected' : '' %>>Quarterly</option>
                <option value="annually" <%= truck.pmvi_frequency === 'annually' ? 'selected' : '' %>>Annually</option>
              </select>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Annual Safety Inspection Expiry Date</label>
              <input type="date" name="annual_safety_expiry" class="portal-input" value="<%= truck.annual_safety_expiry || '' %>" required>
            </div>
            <div class="portal-form-group">
              <label class="portal-label">Oil Change: Last Serviced Date</label>
              <input type="date" name="oil_change_last" class="portal-input" value="<%= truck.oil_change_last || '' %>" required>
            </div>
          </div>

          <!-- Section 7: Asset Finance -->
          <h3 style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.25rem; color: var(--color-accent);">Asset Financing Details</h3>
          <div style="margin-bottom: 1.5rem;">
            <label class="portal-label" style="margin-bottom: 0.75rem; display: block;">Finance Model</label>
            <select name="finance_type" id="financeType" class="portal-select" style="width: 250px;" onchange="handleFinanceChange(this.value)">
              <option value="Owned" <%= truck.finance_type === 'Owned' ? 'selected' : '' %>>Owned Asset</option>
              <option value="Leased" <%= truck.finance_type === 'Leased' ? 'selected' : '' %>>Leased Asset</option>
              <option value="Rented" <%= truck.finance_type === 'Rented' ? 'selected' : '' %>>Rented Asset</option>
            </select>
          </div>

          <!-- Sub-forms for financing options -->
          <!-- Owned Asset Details -->
          <div id="ownedFinanceForm" class="finance-subform">
            <div class="portal-form-grid">
              <div class="portal-form-group">
                <label class="portal-label">Purchase Date</label>
                <input type="date" name="purchase_date" class="portal-input" value="<%= truck.purchase_date || '' %>">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Purchase Price ($)</label>
                <input type="number" step="0.01" name="purchase_price" class="portal-input" value="<%= truck.purchase_price || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Asset Valuation ($)</label>
                <input type="number" step="0.01" name="valuation" class="portal-input" value="<%= truck.valuation || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">HST Tax Amount ($)</label>
                <input type="number" step="0.01" name="hst_amount" class="portal-input" value="<%= truck.hst_amount || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Total Amount Paid ($)</label>
                <input type="number" step="0.01" name="total_amount" class="portal-input" value="<%= truck.total_amount || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">ACH Settled Value ($)</label>
                <input type="number" step="0.01" name="ach_value" class="portal-input" value="<%= truck.ach_value || '' %>" placeholder="0.00">
              </div>
            </div>
          </div>

          <!-- Leased Asset Details -->
          <div id="leasedFinanceForm" class="finance-subform" style="display: none;">
            <div class="portal-form-grid">
              <div class="portal-form-group">
                <label class="portal-label">Lease Purchase Date</label>
                <input type="date" name="purchase_date" class="portal-input" value="<%= truck.purchase_date || '' %>">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Lease Value ($)</label>
                <input type="number" step="0.01" name="valuation" class="portal-input" value="<%= truck.valuation || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">HST Tax Amount ($)</label>
                <input type="number" step="0.01" name="hst_amount" class="portal-input" value="<%= truck.hst_amount || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Total Capital cost ($)</label>
                <input type="number" step="0.01" name="total_amount" class="portal-input" value="<%= truck.total_amount || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Lease Term (e.g., 36 Months)</label>
                <input type="text" name="lease_term" class="portal-input" value="<%= truck.lease_term || '' %>" placeholder="e.g. 48 Months">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Lease Payment Rate ($)</label>
                <input type="number" step="0.01" name="lease_payment" class="portal-input" value="<%= truck.lease_payment || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Lease Payment Interval</label>
                <select name="lease_frequency" class="portal-select">
                  <option value="Weekly" <%= truck.lease_frequency === 'Weekly' ? 'selected' : '' %>>Weekly payments</option>
                  <option value="Bi-Monthly" <%= truck.lease_frequency === 'Bi-Monthly' ? 'selected' : '' %>>Bi-Monthly payments</option>
                  <option value="Monthly" <%= truck.lease_frequency === 'Monthly' ? 'selected' : '' %>>Monthly payments</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Rented Asset Details -->
          <div id="rentedFinanceForm" class="finance-subform" style="display: none;">
            <div class="portal-form-grid">
              <div class="portal-form-group">
                <label class="portal-label">Rental Payment Rate ($)</label>
                <input type="number" step="0.01" name="rent_payment" class="portal-input" value="<%= truck.rent_payment || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Rent Base Amount (Excl. HST) ($)</label>
                <input type="number" step="0.01" name="rent_amount_exc_hst" class="portal-input" value="<%= truck.rent_amount_exc_hst || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Rent HST Tax Amount ($)</label>
                <input type="number" step="0.01" name="rent_hst" class="portal-input" value="<%= truck.rent_hst || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Total Rent Invoice ($)</label>
                <input type="number" step="0.01" name="rent_total" class="portal-input" value="<%= truck.rent_total || '' %>" placeholder="0.00">
              </div>
              <div class="portal-form-group">
                <label class="portal-label">Rent Invoice Interval</label>
                <select name="rent_frequency" class="portal-select">
                  <option value="Weekly" <%= truck.rent_frequency === 'Weekly' ? 'selected' : '' %>>Weekly</option>
                  <option value="Bi-Monthly" <%= truck.rent_frequency === 'Bi-Monthly' ? 'selected' : '' %>>Bi-Monthly</option>
                  <option value="Monthly" <%= truck.rent_frequency === 'Monthly' ? 'selected' : '' %>>Monthly</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Submit Panel -->
          <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; margin-top: 2.5rem; display: flex; justify-content: flex-end; gap: 1rem;">
            <a href="/portal/trucks/<%= truck.id %>" class="portal-btn portal-btn-secondary">Cancel</a>
            <button type="submit" class="portal-btn portal-btn-primary"><i class="fas fa-save"></i> Save Truck Changes</button>
          </div>

        </form>
      </div>

    </div>
  </div>

  <script>
    function handleFinanceChange(val) {
      document.querySelectorAll('.finance-subform').forEach(form => {
        form.style.display = 'none';
        form.querySelectorAll('input').forEach(i => i.disabled = true);
      });

      let activeFormId = 'ownedFinanceForm';
      if (val === 'Leased') activeFormId = 'leasedFinanceForm';
      else if (val === 'Rented') activeFormId = 'rentedFinanceForm';

      const activeForm = document.getElementById(activeFormId);
      activeForm.style.display = 'block';
      activeForm.querySelectorAll('input').forEach(i => i.disabled = false);
    }

    function handleRegionChange(val) {
      const usdFuelCard = document.getElementById('usdFuelCardGroup');
      const dtopsGroup = document.getElementById('dtopsGroup');
      const bluewaterGroup = document.getElementById('bluewaterGroup');
      const iftaDecal = document.getElementById('iftaDecalGroup');
      const nyhutDecal = document.getElementById('nyhutDecalGroup');

      if (val === 'Provincial') {
        usdFuelCard.style.display = 'none';
        dtopsGroup.style.display = 'none';
        bluewaterGroup.style.display = 'none';
        iftaDecal.style.display = 'none';
        nyhutDecal.style.display = 'none';
      } else if (val === 'Canada Wide') {
        usdFuelCard.style.display = 'none';
        dtopsGroup.style.display = 'none';
        bluewaterGroup.style.display = 'none';
        iftaDecal.style.display = 'block';
        nyhutDecal.style.display = 'none';
      } else {
        usdFuelCard.style.display = 'block';
        dtopsGroup.style.display = 'block';
        bluewaterGroup.style.display = 'block';
        iftaDecal.style.display = 'block';
        nyhutDecal.style.display = 'block';
      }
    }

    // Initialize initial values
    handleFinanceChange('<%= truck.finance_type || "Owned" %>');
    handleRegionChange('<%= truck.operating_region || "Cross-Border" %>');
  </script>
</body>
</html>
