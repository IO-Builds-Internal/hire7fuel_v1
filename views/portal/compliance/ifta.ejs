<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/portal_nav') %>

    <div class="portal-dashboard">
      
      <div class="portal-card">
        <div class="portal-card-header">
          <h2>IFTA Filing Records</h2>
          <div style="font-weight: 600; color: var(--color-accent);">
            License Number: <%= profile.ifta_number || 'N/A' %>
          </div>
        </div>
        
        <p style="color: var(--color-muted); margin-bottom: 1.5rem; font-size: 0.95rem;">
          Under the International Fuel Tax Agreement (IFTA), quarterly tax returns must be filed to report fuel purchase logs and distance traveled.
        </p>

        <div class="portal-table-wrap">
          <table class="portal-table">
            <thead>
              <tr>
                <th>Filing Year</th>
                <th>Quarter</th>
                <th>Due Date</th>
                <th>Filing Status</th>
                <th>Date Filed</th>
                <th>Internal Notes</th>
                <th style="text-align: right;">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (filings && filings.length > 0) { %>
                <% filings.forEach(function(f) { %>
                  <tr>
                    <td style="font-weight: 600; color: var(--color-white);"><%= f.year %></td>
                    <td><%= f.quarter %></td>
                    <td><%= f.due_date %></td>
                    <td>
                      <span class="filing-badge filing-<%= f.status.toLowerCase() %>">
                        <%= f.status %>
                      </span>
                    </td>
                    <td><%= f.filed_date || '—' %></td>
                    <td style="font-size: 0.85rem; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= f.notes || '—' %></td>
                    <td style="text-align: right;">
                      <button type="button" class="portal-btn portal-btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;" 
                              onclick="openUpdateModal('<%= f.id %>', '<%= f.quarter %>', '<%= f.year %>', '<%= f.status %>', '<%= f.filed_date || '' %>', '<%= f.notes || '' %>')">
                        Update Status
                      </button>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" style="text-align: center; color: var(--color-muted); padding: 3rem;">
                    No IFTA filing records found.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <!-- Update Modal Overlay -->
  <div class="details-modal" id="updateFilingModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(5px);">
    <div class="portal-card" style="width: 100%; max-width: 500px; margin: 0 1rem;">
      <div class="portal-card-header">
        <h2 id="modalFilingTitle">Update Filing</h2>
        <button type="button" onclick="closeUpdateModal()" style="background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-white);">&times;</button>
      </div>

      <form action="/portal/compliance/ifta/update" method="POST">
        <input type="hidden" name="filing_id" id="modalFilingId">
        
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div class="portal-form-group">
            <label class="portal-label">Filing Status</label>
            <select name="status" id="modalFilingStatus" class="portal-select">
              <option value="PENDING">PENDING</option>
              <option value="FILED">FILED</option>
              <option value="OVERDUE">OVERDUE</option>
            </select>
          </div>

          <div class="portal-form-group">
            <label class="portal-label">Filing Date</label>
            <input type="date" name="filed_date" id="modalFilingDate" class="portal-input">
          </div>

          <div class="portal-form-group">
            <label class="portal-label">Filing Notes</label>
            <textarea name="notes" id="modalFilingNotes" class="portal-textarea" rows="3" placeholder="Enter registration confirmation numbers or audit records..."></textarea>
          </div>

          <div style="display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1rem;">
            <button type="button" class="portal-btn portal-btn-secondary" onclick="closeUpdateModal()">Cancel</button>
            <button type="submit" class="portal-btn portal-btn-primary">Save Changes</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <script>
    function openUpdateModal(id, quarter, year, status, date, notes) {
      document.getElementById('modalFilingId').value = id;
      document.getElementById('modalFilingTitle').innerText = 'Update IFTA filing — ' + quarter + ' ' + year;
      document.getElementById('modalFilingStatus').value = status;
      document.getElementById('modalFilingDate').value = date;
      document.getElementById('modalFilingNotes').value = notes;
      
      const modal = document.getElementById('updateFilingModal');
      modal.style.display = 'flex';
    }

    function closeUpdateModal() {
      document.getElementById('updateFilingModal').style.display = 'none';
    }
  </script>

</body>
</html>
