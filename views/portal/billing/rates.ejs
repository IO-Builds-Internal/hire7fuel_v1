<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/portal_nav') %>

    <div class="portal-dashboard">
      
      <div class="portal-btn-row" style="margin-bottom: 1.5rem;">
        <a href="/portal/billing" class="portal-btn portal-btn-secondary">
          <i class="fas fa-arrow-left"></i> Back to Invoices
        </a>
      </div>

      <div class="portal-card" style="margin-bottom: 2.5rem;">
        <div class="portal-card-header">
          <h2>Task Billing Rates Master</h2>
        </div>
        
        <p style="color: var(--color-muted); font-size: 0.95rem; margin-bottom: 2rem;">
          Configure task type pricing and taxes to automatically compute charges when compliance work orders are completed.
        </p>

        <!-- Edit / Add Rate Form -->
        <div style="background: rgba(10, 28, 28, 0.3); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 1.5rem; margin-bottom: 2.5rem;">
          <h4 style="margin: 0 0 1.25rem 0; color: var(--color-accent);">Configure / Register Billing Rate</h4>
          <form action="/portal/billing/rates/edit" method="POST" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 1rem; align-items: flex-end;">
            <div>
              <label style="display: block; font-size: 0.8rem; color: var(--color-muted); margin-bottom: 0.25rem;">TASK TYPE NAME</label>
              <input type="text" name="task_type" class="carrier-switcher-select" style="width: 100%; box-sizing: border-box;" placeholder="e.g. Annual Safety Renewal" required>
            </div>
            <div>
              <label style="display: block; font-size: 0.8rem; color: var(--color-muted); margin-bottom: 0.25rem;">DEFAULT RATE ($)</label>
              <input type="number" step="0.01" name="default_rate" class="carrier-switcher-select" style="width: 100%; box-sizing: border-box;" placeholder="e.g. 50.00" required>
            </div>
            <div>
              <label style="display: block; font-size: 0.8rem; color: var(--color-muted); margin-bottom: 0.25rem;">CURRENCY</label>
              <select name="currency" class="carrier-switcher-select" style="width: 100%; box-sizing: border-box;">
                <option value="CAD">CAD (Canadian Dollar)</option>
                <option value="USD">USD (US Dollar)</option>
              </select>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem; height: 38px;">
              <input type="checkbox" name="tax_applicable" id="tax_applicable" checked style="width: 18px; height: 18px; accent-color: var(--color-accent);">
              <label for="tax_applicable" style="font-size: 0.85rem; font-weight: 600;">TAX APPLICABLE</label>
            </div>
            <div style="grid-column: span 4; text-align: right;">
              <button type="submit" class="portal-btn portal-btn-primary" style="padding: 0.6rem 2rem;">
                <i class="fas fa-save"></i> Save Billing Rule
              </button>
            </div>
          </form>
        </div>

        <!-- Rates List Table -->
        <div class="portal-table-wrap">
          <table class="portal-table">
            <thead>
              <tr>
                <th>Task Type Name</th>
                <th>Default Billing Rate</th>
                <th>Currency</th>
                <th>Tax Status</th>
                <th>Effective Date</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (rates && rates.length > 0) { %>
                <% rates.forEach(function(r) { %>
                  <tr>
                    <td style="font-weight: 700; color: var(--color-white);"><%= r.task_type %></td>
                    <td style="font-weight: 600; color: var(--color-accent);">$<%= r.default_rate.toFixed(2) %></td>
                    <td><%= r.currency %></td>
                    <td>
                      <span class="expiry-badge <%= r.tax_applicable ? 'badge-green' : 'badge-red' %>">
                        <%= r.tax_applicable ? 'Taxable' : 'Tax Exempt' %>
                      </span>
                    </td>
                    <td><%= r.effective_date || '—' %></td>
                    <td>
                      <span class="expiry-badge <%= r.active ? 'badge-green' : 'badge-red' %>">
                        <%= r.active ? 'Active' : 'Inactive' %>
                      </span>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" style="text-align: center; color: var(--color-muted); padding: 2rem;">No billing rates registered.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

      </div>

    </div>
  </div>

</body>
</html>
