<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .checklist-row {
      display: grid;
      grid-template-columns: 2fr 1.5fr 2fr;
      gap: 1.5rem;
      align-items: center;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .checklist-row:last-child {
      border-bottom: none;
    }
    .check-label {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      cursor: pointer;
      font-weight: 600;
      color: var(--color-white);
    }
    .check-label input[type="checkbox"] {
      width: 18px;
      height: 18px;
      accent-color: var(--color-accent);
    }
  </style>
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/portal_nav') %>

    <div class="portal-dashboard">
      
      <div class="portal-btn-row" style="margin-bottom: 1.5rem;">
        <a href="/portal/tasks" class="portal-btn portal-btn-secondary">
          <i class="fas fa-arrow-left"></i> Back to Tasks List
        </a>
      </div>

      <% if (success) { %>
        <div class="expiry-badge badge-green" style="padding: 0.75rem 1.5rem; border-radius: 6px; margin-bottom: 1.5rem; display: block; font-weight: 600; text-align: center;">
          <i class="fas fa-check-circle"></i> Checklist updated successfully!
        </div>
      <% } %>

      <% if (error) { %>
        <div class="expiry-badge badge-red" style="padding: 0.75rem 1.5rem; border-radius: 6px; margin-bottom: 1.5rem; display: block; font-weight: 600; text-align: center;">
          <i class="fas fa-exclamation-triangle"></i> <%= error %>
        </div>
      <% } %>

      <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
        
        <!-- Checklist panel -->
        <div class="portal-card">
          <div class="portal-card-header">
            <h2>Compliance Checklist Items</h2>
            <span class="expiry-badge <%= task.status === 'Completed' ? 'badge-green' : 'badge-yellow' %>">
              <%= task.status %>
            </span>
          </div>

          <form action="/portal/tasks/<%= task.id %>/checklist/update" method="POST" enctype="multipart/form-data">
            <div style="margin-top: 1rem;">
              <% checklist.forEach(function(item, idx) { %>
                <div class="checklist-row">
                  <!-- Checkbox -->
                  <label class="check-label">
                    <input type="checkbox" name="item_received" value="<%= idx %>" <%= item.received ? 'checked' : '' %> <%= task.status === 'Completed' ? 'disabled' : '' %>>
                    <span><%= item.name %></span>
                  </label>
                  
                  <!-- File Attachment Upload -->
                  <div>
                    <% if (task.status !== 'Completed') { %>
                      <input type="file" name="checklist_files" class="carrier-switcher-select" style="font-size: 0.8rem; padding: 0.25rem;" onchange="this.name='file_<%= idx %>' ">
                    <% } else { %>
                      <span style="color: var(--color-muted); font-size: 0.85rem;">Locks locked (Completed)</span>
                    <% } %>
                  </div>

                  <!-- Download link -->
                  <div style="text-align: right;">
                    <% if (item.file_path) { %>
                      <a href="<%= item.file_path %>" target="_blank" class="portal-btn portal-btn-secondary" style="padding: 0.35rem 0.75rem; font-size: 0.8rem;">
                        <i class="fas fa-download"></i> View File
                      </a>
                    <% } else { %>
                      <span style="font-size: 0.85rem; color: var(--color-muted); font-style: italic;">No file attached</span>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>

            <% if (task.status !== 'Completed') { %>
              <div style="text-align: right; margin-top: 2rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem;">
                <button type="submit" class="portal-btn portal-btn-primary" style="padding: 0.6rem 1.5rem;">
                  <i class="fas fa-save"></i> Save Checklist State
                </button>
              </div>
            <% } %>
          </form>
        </div>

        <!-- Task Metadata / Actions -->
        <div>
          <!-- Details Card -->
          <div class="portal-card" style="margin-bottom: 2rem;">
            <h3 style="margin-top: 0; color: var(--color-white); font-weight: 600; font-size: 1.15rem; margin-bottom: 1.25rem;">Work Order Metadata</h3>
            
            <div style="display: flex; flex-direction: column; gap: 1rem; font-size: 0.9rem;">
              <div>
                <span style="color: var(--color-muted); display: block; font-size: 0.75rem;">TASK ID</span>
                <strong>WO-00<%= task.id %></strong>
              </div>
              <div>
                <span style="color: var(--color-muted); display: block; font-size: 0.75rem;">COMPLIANCE CATEGORY</span>
                <strong><%= task.task_type %></strong>
              </div>
              <div>
                <span style="color: var(--color-muted); display: block; font-size: 0.75rem;">FLEET REPRESENTATIVE</span>
                <strong><%= task.assigned_to %></strong>
              </div>
              <div>
                <span style="color: var(--color-muted); display: block; font-size: 0.75rem;">BILLABLE INVOICE CHARGE</span>
                <strong><%= task.is_billable ? `$${task.amount || 'Pending Completion'} CAD` : 'Non-billable administrative' %></strong>
              </div>
              <% if (task.completed_at) { %>
                <div>
                  <span style="color: var(--color-muted); display: block; font-size: 0.75rem;">COMPLETED AT</span>
                  <strong><%= new Date(task.completed_at).toLocaleString() %></strong>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Actions Card -->
          <% if (task.status !== 'Completed') { %>
            <div class="portal-card">
              <h3 style="margin-top: 0; color: var(--color-white); font-weight: 600; font-size: 1.15rem; margin-bottom: 1.25rem;">Compliance Actions</h3>
              
              <div style="display: flex; flex-direction: column; gap: 1rem;">
                <!-- Email missing docs -->
                <form action="/portal/tasks/<%= task.id %>/email-missing" method="POST">
                  <button type="submit" class="portal-btn portal-btn-secondary" style="width: 100%; justify-content: center; border-color: var(--color-highlight); color: var(--color-highlight);">
                    <i class="fas fa-envelope-open-text" style="margin-right: 0.5rem;"></i> Send Missing Docs Email
                  </button>
                </form>

                <!-- Complete Task -->
                <% 
                  const allDone = checklist.every(item => item.received);
                %>
                <form action="/portal/tasks/<%= task.id %>/complete" method="POST">
                  <button type="submit" class="portal-btn portal-btn-primary" style="width: 100%; justify-content: center;" <%= !allDone ? 'disabled title="Please receive all checklist items first."' : '' %>>
                    <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i> Approve & Complete Task
                  </button>
                </form>
                <% if (!allDone) { %>
                  <p style="font-size: 0.75rem; color: var(--color-muted); margin: 0; text-align: center;">
                    Complete button is disabled until all checklist items are marked received.
                  </p>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>

      </div>

    </div>
  </div>

</body>
</html>
