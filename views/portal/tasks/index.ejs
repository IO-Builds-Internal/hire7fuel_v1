<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | <%= config.brand.name %></title>
  <link rel="stylesheet" href="/css/styles.css?v=2.0">
  <link rel="stylesheet" href="/css/portal.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="admin-body">

  <div class="portal-layout">
    <%- include('../../partials/portal_nav') %>

    <div class="portal-dashboard">
      
      <div class="portal-card" style="margin-bottom: 2rem;">
        <div class="portal-card-header">
          <h2>Tasks & Work Orders</h2>
        </div>
        <p style="color: var(--color-muted); font-size: 0.95rem; margin-bottom: 2rem;">
          Generate compliance checklists, track missing documents, send client reminders, and approve completed work orders.
        </p>

        <% if (success) { %>
          <div class="expiry-badge badge-green" style="padding: 0.75rem 1.5rem; border-radius: 6px; margin-bottom: 1.5rem; display: block; font-weight: 600; text-align: center;">
            <i class="fas fa-check-circle"></i> Task updated successfully!
          </div>
        <% } %>

        <% if (error) { %>
          <div class="expiry-badge badge-red" style="padding: 0.75rem 1.5rem; border-radius: 6px; margin-bottom: 1.5rem; display: block; font-weight: 600; text-align: center;">
            <i class="fas fa-exclamation-triangle"></i> <%= error %>
          </div>
        <% } %>

        <!-- Filter and Create Grid -->
        <div style="display: grid; grid-template-columns: 3fr 2fr; gap: 2rem; margin-bottom: 2.5rem;">
          
          <!-- Create Task Form -->
          <div style="background: rgba(10, 28, 28, 0.3); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 1.5rem;">
            <h4 style="margin: 0 0 1.25rem 0; color: var(--color-accent);">Create / Generate Compliance Task</h4>
            <form action="/portal/tasks/new" method="POST">
              <div class="form-group">
                <label style="color: var(--color-white); font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem; display: block;">TASK TYPE</label>
                <select name="task_type" class="carrier-switcher-select" style="width: 100%; box-sizing: border-box;" onchange="toggleCustomItems(this.value)">
                  <option value="Annual Safety Renewal">Annual Safety Renewal (Default checklist)</option>
                  <option value="Driver Document Follow-Up">Driver Document Follow-Up (Default checklist)</option>
                  <option value="Custom Task">Custom Task (Define checklists below)</option>
                </select>
              </div>

              <div class="form-group">
                <label style="color: var(--color-white); font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem; display: block;">ASSIGN TO</label>
                <input type="text" name="assigned_to" class="carrier-switcher-select" style="width: 100%; box-sizing: border-box;" placeholder="e.g. Safety Coordinator / Driver Name">
              </div>

              <div id="customChecklistGroup" style="display: none; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem; margin-top: 1rem;">
                <label style="color: var(--color-white); font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem; display: block;">CHECKLIST ITEMS</label>
                <input type="text" name="checklist_item_name" class="carrier-switcher-select" style="width: 100%; box-sizing: border-box; margin-bottom: 0.5rem;" placeholder="e.g. Medical Certificate Doc">
                <input type="text" name="checklist_item_name" class="carrier-switcher-select" style="width: 100%; box-sizing: border-box; margin-bottom: 0.5rem;" placeholder="e.g. Drug and Alcohol Consent Form">
                <input type="text" name="checklist_item_name" class="carrier-switcher-select" style="width: 100%; box-sizing: border-box;" placeholder="e.g. Road Test Certificate">
              </div>

              <div style="text-align: right; margin-top: 1.5rem;">
                <button type="submit" class="portal-btn portal-btn-primary" style="padding: 0.6rem 1.5rem;">
                  <i class="fas fa-plus"></i> Generate Work Order
                </button>
              </div>
            </form>
          </div>

          <!-- Quick Filters Card -->
          <div style="background: rgba(10, 28, 28, 0.3); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 1.5rem;">
            <h4 style="margin: 0 0 1.25rem 0; color: var(--color-white);">Filter by Status</h4>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              <a href="/portal/tasks" class="portal-btn <%= !statusFilter ? 'portal-btn-primary' : 'portal-btn-secondary' %>" style="text-align: left; justify-content: flex-start;">
                <i class="fas fa-list" style="margin-right: 0.5rem;"></i> All Tasks
              </a>
              <a href="/portal/tasks?status=Pending" class="portal-btn <%= statusFilter === 'Pending' ? 'portal-btn-primary' : 'portal-btn-secondary' %>" style="text-align: left; justify-content: flex-start;">
                <i class="fas fa-clock" style="margin-right: 0.5rem; color: var(--color-highlight);"></i> Pending Checklists
              </a>
              <a href="/portal/tasks?status=Completed" class="portal-btn <%= statusFilter === 'Completed' ? 'portal-btn-primary' : 'portal-btn-secondary' %>" style="text-align: left; justify-content: flex-start;">
                <i class="fas fa-check-circle" style="margin-right: 0.5rem; color: var(--color-accent);"></i> Completed & Invoiced
              </a>
            </div>
          </div>

        </div>

        <!-- Tasks Table -->
        <div class="portal-table-wrap">
          <table class="portal-table">
            <thead>
              <tr>
                <th>Task ID</th>
                <th>Task / Work Order Type</th>
                <th>Assigned To</th>
                <th>Checklists Received</th>
                <th>Status</th>
                <th>Created Date</th>
                <th style="text-align: right;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (tasks && tasks.length > 0) { %>
                <% tasks.forEach(function(t) { %>
                  <tr>
                    <td style="font-weight: 700; color: var(--color-white);">WO-00<%= t.id %></td>
                    <td style="font-weight: 600;"><%= t.task_type %></td>
                    <td><%= t.assigned_to || 'Unassigned' %></td>
                    <td>
                      <% 
                        const total = t.checklist.length;
                        const rec = t.checklist.filter(i => i.received).length;
                      %>
                      <span style="font-weight: 700; color: <%= rec === total ? 'var(--color-accent)' : 'var(--color-highlight)' %>">
                        <%= rec %> / <%= total %>
                      </span>
                    </td>
                    <td>
                      <span class="expiry-badge <%= t.status === 'Completed' ? 'badge-green' : 'badge-yellow' %>">
                        <%= t.status %>
                      </span>
                    </td>
                    <td style="font-size: 0.85rem; color: var(--color-muted);">
                      <%= new Date(t.created_at).toLocaleDateString() %>
                    </td>
                    <td style="text-align: right;">
                      <a href="/portal/tasks/<%= t.id %>" class="portal-btn portal-btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">
                        <i class="fas fa-eye"></i> View Checklist
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" style="text-align: center; color: var(--color-muted); padding: 4rem 2rem;">
                    <i class="fas fa-tasks" style="font-size: 2.5rem; color: rgba(20,160,119,0.1); margin-bottom: 1rem; display: block;"></i>
                    <p style="margin: 0; font-weight: 600; color: var(--color-white);">No tasks registered</p>
                    <p style="margin: 0; font-size: 0.85rem;">Select options above to generate checklists.</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <script>
    function toggleCustomItems(val) {
      const group = document.getElementById('customChecklistGroup');
      if (val === 'Custom Task') {
        group.style.display = 'block';
      } else {
        group.style.display = 'none';
      }
    }
  </script>

</body>
</html>
